#!/usr/bin/env bash
# Pre-commit hook for CrispyTivi
# Runs the same checks as CI: formatting, linting, static analysis.
#
# Install: git config core.hooksPath .githooks
# Or:      make hooks
#
# Skip (emergency only): git commit --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

errors=0

step() {
  printf "${YELLOW}► %s${NC}\n" "$1"
}

pass() {
  printf "${GREEN}  ✓ %s${NC}\n" "$1"
}

fail() {
  printf "${RED}  ✗ %s${NC}\n" "$1"
  errors=$((errors + 1))
}

# ── Rust checks ──────────────────────────────────────────
if [ -d "rust" ]; then
  step "cargo fmt --check"
  if (cd rust && cargo fmt --check 2>&1); then
    pass "Rust formatting"
  else
    fail "Rust formatting — run: cd rust && cargo fmt --all"
  fi

  step "cargo clippy --workspace -- -D warnings"
  if (cd rust && cargo clippy --workspace -- -D warnings 2>&1); then
    pass "Clippy"
  else
    fail "Clippy — fix warnings in rust/"
  fi
fi

# ── Dart/Flutter checks ─────────────────────────────────
if [ -f "pubspec.yaml" ]; then
  step "dart format --set-exit-if-changed lib/ test/"
  if dart format --set-exit-if-changed lib/ test/ > /dev/null 2>&1; then
    pass "Dart formatting"
  else
    fail "Dart formatting — run: dart format lib/ test/"
  fi

  step "flutter analyze"
  if flutter analyze 2>&1 | tail -1 | grep -q "No issues found"; then
    pass "Flutter analyze"
  else
    fail "Flutter analyze — fix issues reported above"
  fi
fi

# ── Result ───────────────────────────────────────────────
echo ""
if [ "$errors" -gt 0 ]; then
  printf "${RED}Pre-commit failed with %d error(s). Fix and retry.${NC}\n" "$errors"
  exit 1
else
  printf "${GREEN}All pre-commit checks passed.${NC}\n"
fi
