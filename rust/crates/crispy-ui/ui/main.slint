component IconCC inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M19 4H5c-1.11 0-2 .9-2 2v12c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-8 7H9.5v-.5h-2v3h2V13H11v1.5c0 .28-.22.5-.5.5h-3c-.28 0-.5-.22-.5-.5v-4c0-.28.22-.5.5-.5h3c.28 0 .5.22.5.5V11zm7 0h-1.5v-.5h-2v3h2V13H18v1.5c0 .28-.22.5-.5.5h-3c-.28 0-.5-.22-.5-.5v-4c0-.28.22-.5.5-.5h3c.28 0 .5.22.5.5V11z"; }
component IconSettings inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M19.4 13c0-.3.1-.6.1-.9s-.1-.6-.1-.9l2.1-1.6c.2-.2.3-.5.1-.7l-2-3.5c-.1-.2-.4-.3-.6-.2l-2.5 1c-.5-.4-1.1-.7-1.7-1l-.4-2.6c0-.3-.3-.4-.5-.4h-4c-.2 0-.5.2-.5.4l-.4 2.6c-.6.3-1.2-.6-1.7 1l-2.5-1c-.2-.1-.5 0-.6.2l-2 3.5c-.1.2 0 .5.1.7l2.1 1.6c0 .3-.1.6-.1.9s.1.6.1.9l-2.1 1.6c-.2.2-.3.5-.1.7l2 3.5c.1.2.4.3.6.2l2.5-1c.5.4 1.1.7 1.7 1l.4 2.6c0 .3.3.4.5.4h4c.2 0 .5-.2.5-.4l.4-2.6c.6-.3 1.2-.6 1.7-1l2.5 1c.2.1.5 0 .6-.2l2-3.5c.1-.2 0-.5-.1-.7l-2.1-1.6zm-7.4 2.5c-1.9 0-3.5-1.6-3.5-3.5s1.6-3.5 3.5-3.5 3.5 1.6 3.5 3.5-1.6 3.5-3.5 3.5z"; }
component IconTv inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 1.99-.9 1.99-2L23 5c0-1.1-.9-2-2-2zm0 14H3V5h18v12z"; }


component NavItem inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked;

    width: label.preferred-width + 32px;
    height: 40px;
    border-radius: 20px;
    
    label := Text {
        text: root.text;
        color: root.active ? Theme.text-primary : Theme.text-secondary;
        font-weight: root.active ? 700 : 500;
        font-size: 20px;
        font-family: Theme.display-font;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    
    TouchArea {
        clicked => { root.clicked() }
    }
}

component HorizontalCard inherits Rectangle {
    in property <string> title;
    in property <float> progress: 0.0;
    callback clicked;

    width: 300px;
    height: 160px;
    border-radius: 12px;
    background: @linear-gradient(135deg, #2c2c30 0%, #1a1a20 100%);
    border-width: 1px;
    border-color: Theme.border-light;

    // Simulate artwork gradient
    Rectangle {
        y: 0; width: 100%; height: 100%; border-radius: 12px; clip: true;
        background: @linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(0,0,0,0.85) 100%);
    }

    Text {
        text: root.title;
        color: Theme.text-primary;
        font-weight: 700;
        font-family: Theme.display-font;
        font-size: 18px;
        x: 15px;
        y: parent.height - 40px;
    }

    if root.progress > 0.0 : Rectangle {
        y: parent.height - 4px;
        height: 4px;
        width: parent.width;
        background: rgba(255, 255, 255, 0.3);
        border-bottom-left-radius: 12px;
        border-bottom-right-radius: 12px;
        clip: true;
        Rectangle {
            x: 0; y: 0; height: 100%;
            width: parent.width * root.progress;
            background: Theme.brand;
        }
    }

    TouchArea { clicked => { root.clicked() } }
}

component VerticalCard inherits Rectangle {
    in property <string> title;
    callback clicked;

    width: 160px;
    height: 240px;
    border-radius: 12px;
    background: @linear-gradient(135deg, #2c2c30 0%, #1a1a20 100%);
    border-width: 1px;
    border-color: Theme.border-light;

    // Simulate artwork
    Rectangle {
        y: 0; width: 100%; height: 100%; border-radius: 12px; clip: true;
        background: @linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(0,0,0,0.85) 100%);
    }

    Text {
        text: root.title;
        color: Theme.text-primary;
        font-weight: 700;
        font-family: Theme.display-font;
        font-size: 16px;
        x: 15px;
        y: parent.height - 35px;
    }

    TouchArea { clicked => { root.clicked() } }
}

component DiscoverScreen inherits Rectangle {
    callback watch-clicked;

    ScrollView {
        VerticalLayout {
            padding: 40px;
            padding-top: 100px; // Space for the top nav
            spacing: 50px;

            // Hero
            VerticalLayout {
                spacing: 20px;
                height: 400px;
                alignment: center;

                Text {
                    text: "DUNE\nPART TWO";
                    font-family: Theme.display-font;
                    font-size: 80px;
                    font-weight: 800;
                    color: Theme.text-primary;
                }
                Text {
                    text: "A boy becomes the Messiah of nomads on a desert planet...";
                    font-family: Theme.default-font;
                    font-size: 18px;
                    color: Theme.text-secondary;
                    wrap: word-wrap;
                    width: 600px;
                }
                HorizontalLayout {
                    spacing: 15px;
                    Rectangle {
                        width: 170px; height: 50px;
                        border-radius: 8px;
                        background: Theme.text-primary;
                        HorizontalLayout {
                            alignment: center; spacing: 8px; padding: 12px;
                            IconPlay { fill: black; width: 20px; height: 20px; }
                            Text { text: "Watch Now"; color: black; font-weight: 700; font-size: 18px; vertical-alignment: center; }
                        }
                        TouchArea { clicked => { root.watch-clicked() } }
                    }
                    Rectangle {
                        width: 150px; height: 50px;
                        border-radius: 8px;
                        background: rgba(255, 255, 255, 0.15);
                        border-width: 2px;
                        border-color: transparent;
                        HorizontalLayout {
                            alignment: center; spacing: 8px; padding: 12px;
                            IconInfo { fill: white; width: 22px; height: 22px; }
                            Text { text: "More Info"; color: white; font-weight: 700; font-size: 18px; vertical-alignment: center; }
                        }
                    }
                }
            }

            // Continue Watching
            VerticalLayout {
                spacing: 15px;
                Text { text: "Continue Watching"; font-family: Theme.display-font; font-size: 24px; font-weight: 700; color: Theme.text-primary; }
                HorizontalLayout {
                    spacing: 20px;
                    HorizontalCard { title: "Planet Earth III"; progress: 0.4; clicked => { root.watch-clicked() } }
                    HorizontalCard { title: "Stranger Things S4"; progress: 0.85; clicked => { root.watch-clicked() } }
                    HorizontalCard { title: "The Last Of Us"; progress: 0.15; clicked => { root.watch-clicked() } }
                }
            }

            // Top Picks
            VerticalLayout {
                spacing: 15px;
                Text { text: "Top Picks for You"; font-family: Theme.display-font; font-size: 24px; font-weight: 700; color: Theme.text-primary; }
                HorizontalLayout {
                    spacing: 20px;
                    VerticalCard { title: "The Batman"; clicked => { root.watch-clicked() } }
                    VerticalCard { title: "Oppenheimer"; clicked => { root.watch-clicked() } }
                    VerticalCard { title: "Dune Part Two"; clicked => { root.watch-clicked() } }
                    VerticalCard { title: "Interstellar"; clicked => { root.watch-clicked() } }
                }
            }
        }
    }
}

component EpgProgram inherits Rectangle {
    in property <string> title;
    in property <string> time: "20:00 - 21:00";
    in property <length> prog-width;
    callback clicked;

    width: root.prog-width;
    height: 65px;
    background: Theme.card-surface;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.border-light;

    VerticalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: center;
        Text { text: root.title; color: Theme.text-primary; font-weight: 600; font-size: 16px; overflow: elide; }
        Text { text: root.time; color: Theme.text-secondary; font-size: 12px; }
    }
    
    TouchArea { clicked => { root.clicked() } }
}

component LiveTvScreen inherits Rectangle {
    callback play-program;
    
    VerticalLayout {
        padding: 40px;
        padding-top: 100px;
        alignment: start;
        spacing: 30px;

        // Header Row with Title and PiP
        HorizontalLayout {
            vertical-stretch: 0;
            alignment: space-between;
            
            HorizontalLayout {
                spacing: 15px;
                alignment: start;
                IconTv { fill: Theme.text-primary; width: 40px; height: 40px; }
                Text {
                    text: "Channel Guide";
                    font-family: Theme.display-font;
                    font-size: 36px;
                    font-weight: 800;
                    color: Theme.text-primary;
                    vertical-alignment: center;
                }
            }

            // PiP Box representation attached cleanly to the right
            Rectangle {
                width: 340px;
                height: 190px;
                background: #000;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.border-light;
                Text { text: "Live Video Playing..."; color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
            }
        }

        // The Grid Area
        ScrollView {
            VerticalLayout {
                spacing: 12px;
                alignment: start;
                vertical-stretch: 0; // Prevent rows from spacing out vertically
                
                // Row 1
                HorizontalLayout {
                    spacing: 10px; height: 65px; vertical-stretch: 0;
                    Rectangle { width: 100px; background: rgba(28,28,32,0.4); border-radius: 8px; Text { text: "BBC 1"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; } }
                    EpgProgram { title: "News at Ten"; prog-width: 200px; clicked => { root.play-program() } }
                    EpgProgram { title: "Match of the Day"; prog-width: 400px; clicked => { root.play-program() } }
                    Rectangle { horizontal-stretch: 1; } // Push everything left
                }
                // Row 2
                HorizontalLayout {
                    spacing: 10px; height: 65px; vertical-stretch: 0;
                    Rectangle { width: 100px; background: rgba(28,28,32,0.4); border-radius: 8px; Text { text: "BBC 2"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; } }
                    EpgProgram { title: "Top Gear: Special"; prog-width: 400px; clicked => { root.play-program() } }
                    EpgProgram { title: "QI"; prog-width: 200px; clicked => { root.play-program() } }
                    Rectangle { horizontal-stretch: 1; }
                }
                // Row 3
                HorizontalLayout {
                    spacing: 10px; height: 65px; vertical-stretch: 0;
                    Rectangle { width: 100px; background: rgba(28,28,32,0.4); border-radius: 8px; Text { text: "ITV 1"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; } }
                    EpgProgram { title: "Coronation St"; prog-width: 200px; clicked => { root.play-program() } }
                    EpgProgram { title: "I'm a Celebrity..."; prog-width: 400px; clicked => { root.play-program() } }
                    Rectangle { horizontal-stretch: 1; }
                }
                // Row 4
                HorizontalLayout {
                    spacing: 10px; height: 65px; vertical-stretch: 0;
                    Rectangle { width: 100px; background: rgba(28,28,32,0.4); border-radius: 8px; Text { text: "CH 4"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; } }
                    EpgProgram { title: "Gogglebox"; prog-width: 610px; clicked => { root.play-program() } } // 200+400+10
                    Rectangle { horizontal-stretch: 1; }
                }
            }
        }
    }
}

component ContentGridScreen inherits Rectangle {
    in property <string> title;
    callback item-clicked;

    ScrollView {
        VerticalLayout {
            padding: 40px;
            padding-top: 100px;
            spacing: 30px;

            Text { text: root.title; font-family: Theme.display-font; font-size: 32px; font-weight: 700; color: Theme.text-primary; }

            // Mock grid rows
            for row in [1, 2, 3] : HorizontalLayout {
                spacing: 20px;
                for col in [1, 2, 3, 4] : VerticalCard {
                    title: "Item " + row + "-" + col;
                    clicked => { root.item-clicked() }
                }
            }
        }
    }
}

component PlayerScreen inherits Rectangle {
    callback stop-clicked;
    
    // Gradient dark bottom overlay fixed
    Rectangle {
        y: parent.height - 350px;
        height: 350px;
        width: parent.width;
        background: @linear-gradient(180deg, rgba(10,10,12,0) 0%, rgba(10,10,12,0.8) 50%, rgba(10,10,12,1) 100%);
    }

    // Absolute positioning for controls to anchor nicely
    VerticalLayout {
        y: parent.height - 180px;
        height: 140px;
        padding-left: 60px; padding-right: 60px;
        padding-bottom: 30px;
        alignment: end;
        spacing: 15px;

        // Centered Controls
        HorizontalLayout {
            alignment: center;
            spacing: 30px;
            
            Rectangle {
                width: 50px; height: 50px; border-radius: 25px; background: rgba(255,255,255,0.1); 
                IconPause { fill: white; width: 20px; height: 20px; x: 15px; y: 15px; }
            }
            Rectangle {
                width: 60px; height: 60px; border-radius: 30px; background: white; 
                IconStop { fill: black; width: 24px; height: 24px; x: 18px; y: 18px; }
                TouchArea { clicked => { root.stop-clicked() } }
            }
            Rectangle {
                width: 50px; height: 50px; border-radius: 25px; background: rgba(255,255,255,0.1); 
                IconCC { fill: white; width: 22px; height: 22px; x: 14px; y: 14px; }
            }
        }

        // Progress Bar Line
        HorizontalLayout {
            spacing: 20px;
            Text { text: "20:45"; color: white; font-family: Theme.display-font; font-weight: 600; vertical-alignment: center;}
            Rectangle {
                height: 4px;
                background: rgba(255,255,255,0.3);
                border-radius: 2px;
                horizontal-stretch: 1;
                Rectangle {
                    x: 0; width: 45%; height: 100%; background: Theme.brand; border-radius: 2px;
                }
                Rectangle {
                    x: parent.width * 0.45 - 8px;
                    y: -6px;
                    width: 16px; height: 16px; border-radius: 8px; background: white;
                }
            }
            Text { text: "22:00"; color: white; font-family: Theme.display-font; font-weight: 600; vertical-alignment: center;}
        }

        // Metadata beneath
        HorizontalLayout {
            alignment: start;
            VerticalLayout {
                spacing: 4px;
                Text { text: "CH 4 • Live"; color: Theme.brand; font-family: Theme.display-font; font-weight: 700; font-size: 16px; }
                Text { text: "Gogglebox"; color: Theme.text-primary; font-family: Theme.display-font; font-weight: 800; font-size: 32px; }
            }
        }
    }
}

export component AppWindow inherits Window {
    // Make window fully responsive
    preferred-width: 1280px;
    preferred-height: 720px;
    min-width: 800px;
    min-height: 600px;
    title: "CrispyTivi";
    background: #000;

    in-out property <int> active-screen: 0; // 0=Discover, 1=LiveTV, 2=Player, 3=Movies, 4=Shows, 5=Library
    in-out property <int> active-tab: 0; 
    
    // Base layer for standard views with Ken Burns placeholder gradient
    Rectangle {
        background: @radial-gradient(circle, #2a111a 0%, #0a0a0c 100%);
        visible: active-screen != 2;
        width: 100%; height: 100%;
    }

    if (active-screen == 0) : DiscoverScreen { watch-clicked => { active-screen = 2; } }
    if (active-screen == 1) : LiveTvScreen { play-program => { active-screen = 2; } }
    if (active-screen == 2) : PlayerScreen { stop-clicked => { active-screen = 0; active-tab = 0; } }
    if (active-screen == 3) : ContentGridScreen { title: "Movies"; item-clicked => { active-screen = 2; } }
    if (active-screen == 4) : ContentGridScreen { title: "TV Shows"; item-clicked => { active-screen = 2; } }
    if (active-screen == 5) : ContentGridScreen { title: "My Library"; item-clicked => { active-screen = 2; } }

    // Google TV Nav Rail
    if (active-screen != 2) : Rectangle {
        y: 30px; height: 60px;
        x: 40px; width: parent.width - 80px;

        HorizontalLayout {
            Rectangle {
                horizontal-stretch: 1;
                HorizontalLayout {
                    spacing: 20px;
                    
                    // Profile Bubble with icon
                    Rectangle {
                        width: 44px; height: 44px;
                        border-radius: 22px;
                        background: rgba(255,255,255,0.15); 
                        IconUser { fill: white; width: 24px; height: 24px; x: 10px; y: 10px; }
                        TouchArea { } // mock profile click
                    }
                    NavItem { text: "For You"; active: active-tab == 0; clicked => { active-tab = 0; active-screen = 0; } }
                    NavItem { text: "Live"; active: active-tab == 1; clicked => { active-tab = 1; active-screen = 1; } }
                    NavItem { text: "Movies"; active: active-tab == 2; clicked => { active-tab = 2; active-screen = 3; } }
                    NavItem { text: "Shows"; active: active-tab == 3; clicked => { active-tab = 3; active-screen = 4; } }
                    NavItem { text: "Library"; active: active-tab == 4; clicked => { active-tab = 4; active-screen = 5; } }
                }
            }
            
            // Search Pill
            Rectangle {
                width: 160px;
                height: 44px;
                background: rgba(255,255,255,0.1);
                border-width: 1px;
                border-color: rgba(255,255,255,0.15);
                border-radius: 22px;
                
                HorizontalLayout {
                    alignment: center;
                    spacing: 12px;
                    padding-left: 12px; padding-right: 12px;
                    IconSearch { fill: Theme.text-secondary; width: 18px; height: 18px; y: 13px; }
                    Text { text: "Search"; color: Theme.text-secondary; font-family: Theme.display-font; font-weight: 500; font-size: 16px; vertical-alignment: center; }
                    Rectangle { width: 1px; height: 20px; background: rgba(255,255,255,0.2); y: 12px; }
                    IconMic { fill: Theme.text-primary; width: 18px; height: 18px; y: 13px; }
                }

                TouchArea {
                    clicked => { /* Focus search */ }
                }
            }
        }
    }
}
