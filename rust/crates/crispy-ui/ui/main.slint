component IconPlay inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M8 5v14l11-7z"; }
component IconPause inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M6 19h4V5H6v14zm8-14v14h4V5h-4z"; }
component IconStop inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M6 6h12v12H6z"; }
