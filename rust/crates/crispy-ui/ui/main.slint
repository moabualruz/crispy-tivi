import { Theme } from "globals/theme.slint";
import { AppState } from "globals/app-state.slint";
import { TopNav } from "components/top-nav.slint";

// Re-export globals so Rust can access them via ui.global::<T>()
export { Theme, AppState }
import { HomeScreen } from "screens/home.slint";
import { LiveTvScreen } from "screens/live-tv.slint";
import { EpgScreen } from "screens/epg.slint";
import { MoviesScreen } from "screens/movies.slint";
import { SeriesScreen } from "screens/series.slint";
import { SearchScreen } from "screens/search.slint";
import { SettingsScreen } from "screens/settings.slint";
import { PlayerScreen, PlayerState } from "screens/player.slint";
import { OnboardingScreen, OnboardingState } from "screens/onboarding.slint";
import { SourceDialog } from "components/source-dialog.slint";
import { DiagnosticsPanel, DiagnosticsState } from "components/diagnostics-panel.slint";

// Re-export for Rust access
export { PlayerState, OnboardingState, DiagnosticsState }

export component AppWindow inherits Window {
  title: "CrispyTivi";
  min-width: 320px;
  min-height: 480px;
  preferred-width: 1280px;
  preferred-height: 720px;
  background: Theme.background;

  // Global keyboard shortcuts
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.F12 { DiagnosticsState.toggle(); return accept; }
      if event.text == Key.Escape {
        if DiagnosticsState.visible { DiagnosticsState.visible = false; return accept; }
        if AppState.show-source-dialog { AppState.show-source-dialog = false; return accept; }
        if PlayerState.is-fullscreen {
          PlayerState.is-fullscreen = false;
          return accept;
        }
        if PlayerState.is-playing { PlayerState.stop(); return accept; }
      }
      return reject;
    }
  }

  // Onboarding (fullscreen, above everything — mandatory, no skip)
  if OnboardingState.is-active: OnboardingScreen { width: 100%; height: 100%; }

  // ── 3-Layer Architecture (when not onboarding) ──
  if !OnboardingState.is-active: Rectangle {
    width: 100%; height: 100%;

    // Layer 0: Video underlay — always present, behind everything
    // libmpv renders into this area via OpenGL FBO in main.rs
    PlayerScreen {
      width: 100%;
      height: 100%;
      // When not playing, this is just a black rectangle (the app background)
      // When playing fullscreen, OSD shows on top
    }

    // Layer 1: UI content — transparent over video when playing
    if !PlayerState.is-fullscreen: Rectangle {
      width: 100%; height: 100%;
      // Semi-transparent background only when NOT playing video
      background: PlayerState.is-playing ? transparent : Theme.background;

      // Screen content (full-width, no side rail)
      if AppState.active-screen == 0: HomeScreen { width: 100%; height: 100%; }
      if AppState.active-screen == 1: LiveTvScreen { width: 100%; height: 100%; }
      if AppState.active-screen == 2: EpgScreen { width: 100%; height: 100%; }
      if AppState.active-screen == 3: MoviesScreen { width: 100%; height: 100%; }
      if AppState.active-screen == 4: SeriesScreen { width: 100%; height: 100%; }
      if AppState.active-screen == 5: SearchScreen { width: 100%; height: 100%; }
      if AppState.active-screen == 6: SettingsScreen { width: 100%; height: 100%; }

      // Top nav overlay (floats OVER content, z-index 20 equivalent)
      if AppState.nav-visible: TopNav {
        y: 0;
        width: 100%;
      }
    }
  }

  // Modals (above everything except onboarding)
  if !OnboardingState.is-active: SourceDialog {}
  DiagnosticsPanel {}
}
