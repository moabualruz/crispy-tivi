import { ScrollView, HorizontalBox, VerticalBox, ListView } from "std-widgets.slint";

global Theme {
    out property <color> surface: rgba(10, 10, 12, 0.65);
    out property <color> card-surface: rgba(28, 28, 32, 0.8);
    out property <color> border-light: rgba(255, 255, 255, 0.15);
    out property <color> text-primary: rgba(255, 255, 255, 0.95);
    out property <color> text-secondary: rgba(255, 255, 255, 0.6);
    out property <color> accent: #FFFFFF;
    out property <color> brand: #FF4B2B;
    out property <string> default-font: "Inter";
    out property <string> display-font: "Outfit";
}

// Custom Icon Components using SVG Paths to replace emojis
component IconSearch inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"; }
component IconMic inherits Path { viewbox-width: 24; viewbox-height: 24; commands: "M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3s-3 1.34-3 3v6c0 1.66 1.34 3 3 3zm5-3c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"; }
