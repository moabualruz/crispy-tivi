import { Theme } from "globals/theme.slint";
import { AppState } from "globals/app-state.slint";
import { NavRail } from "components/nav-rail.slint";

// Re-export globals so Rust can access them via ui.global::<T>()
export { Theme, AppState }
import { HomeScreen } from "screens/home.slint";
import { LiveTvScreen } from "screens/live-tv.slint";
import { EpgScreen } from "screens/epg.slint";
import { MoviesScreen } from "screens/movies.slint";
import { SeriesScreen } from "screens/series.slint";
import { SearchScreen } from "screens/search.slint";
import { SettingsScreen } from "screens/settings.slint";
import { PlayerScreen, PlayerState } from "screens/player.slint";
import { OnboardingScreen, OnboardingState } from "screens/onboarding.slint";
import { SourceDialog } from "components/source-dialog.slint";
import { DiagnosticsPanel, DiagnosticsState } from "components/diagnostics-panel.slint";

// Re-export for Rust access
export { PlayerState, OnboardingState, DiagnosticsState }

export component AppWindow inherits Window {
  title: "CrispyTivi";
  min-width: 800px;
  min-height: 600px;
  preferred-width: 1280px;
  preferred-height: 720px;
  background: Theme.background;

  // Global keyboard shortcut handler
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      // F12 = toggle diagnostics
      if event.text == Key.F12 {
        DiagnosticsState.toggle();
        return accept;
      }
      // Escape = stop player or close dialogs
      if event.text == Key.Escape {
        if DiagnosticsState.visible {
          DiagnosticsState.visible = false;
          return accept;
        }
        if AppState.show-source-dialog {
          AppState.show-source-dialog = false;
          return accept;
        }
        if PlayerState.is-playing {
          PlayerState.stop();
          return accept;
        }
      }
      return reject;
    }
  }

  // Onboarding overlay (first-run)
  if OnboardingState.is-active: OnboardingScreen {
    width: 100%;
    height: 100%;
  }

  // Layer 0: Player (always present, behind UI)
  if !OnboardingState.is-active: PlayerScreen {
    visible: PlayerState.is-playing || PlayerState.is-buffering;
    width: 100%;
    height: 100%;
  }

  // Layer 1: UI (hidden when player is fullscreen or onboarding active)
  if !PlayerState.is-playing && !PlayerState.is-buffering && !OnboardingState.is-active: HorizontalLayout {
    NavRail {}

    Rectangle {
      background: Theme.background;
      horizontal-stretch: 1;

      if AppState.active-screen == 0: HomeScreen {}
      if AppState.active-screen == 1: LiveTvScreen {}
      if AppState.active-screen == 2: EpgScreen {}
      if AppState.active-screen == 3: MoviesScreen {}
      if AppState.active-screen == 4: SeriesScreen {}
      if AppState.active-screen == 5: SearchScreen {}
      if AppState.active-screen == 6: SettingsScreen {}
    }
  }

  // Modal overlays
  if !OnboardingState.is-active: SourceDialog {}
  DiagnosticsPanel {}
}
