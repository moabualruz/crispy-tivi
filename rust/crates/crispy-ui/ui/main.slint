import { Theme } from "globals/theme.slint";
import { AppState } from "globals/app-state.slint";
import { TopNav } from "components/top-nav.slint";

// Re-export globals so Rust can access them via ui.global::<T>()
export { Theme, AppState }
import { HomeScreen } from "screens/home.slint";
import { LiveTvScreen } from "screens/live-tv.slint";
import { EpgScreen } from "screens/epg.slint";
import { MoviesScreen } from "screens/movies.slint";
import { SeriesScreen } from "screens/series.slint";
import { SearchScreen } from "screens/search.slint";
import { SettingsScreen } from "screens/settings.slint";
import { LibraryScreen } from "screens/library.slint";
import { PlayerScreen, PlayerState } from "screens/player.slint";
import { OnboardingScreen, OnboardingState } from "screens/onboarding.slint";
import { VodDetailScreen } from "screens/vod-detail.slint";
import { SeriesDetailScreen } from "screens/series-detail.slint";
import { SourceDialog } from "components/source-dialog.slint";
import { DiagnosticsPanel, DiagnosticsState } from "components/diagnostics-panel.slint";
import { ProfileMenu, ProfilePickerScreen } from "components/profile-menu.slint";
import { ButtonLegend } from "components/button-legend.slint";
import { CastPicker } from "components/cast-picker.slint";
// M-019: DeviceManager import removed — component not instantiated.
// Will be re-added when Epoch 10 cast/device infrastructure is implemented.
import { ResumePrompt } from "components/resume-prompt.slint";
import { PrivacyConsent } from "components/privacy-consent.slint";
import { GuidedTour } from "components/guided-tour.slint";
import { PinDialog } from "components/pin-dialog.slint";

// Re-export for Rust access
export { PlayerState, OnboardingState, DiagnosticsState }

export component AppWindow inherits Window {
  title: "CrispyTivi";
  min-width: 320px;
  min-height: 480px;
  preferred-width: 1280px;
  preferred-height: 720px;

  // Window background transparent so mpv OpenGL underlay (VideoLayer) is visible
  background: transparent;

  // ════════════════════════════════════════════════════════════════════════
  // 4-LAYER ARCHITECTURE
  //
  // Each layer is a distinct full-size view, independently shown/hidden.
  // Layer names are for isolation — z-order is determined by declaration order.
  //
  //   1. VideoLayer   — mpv OpenGL underlay (rendered by main.rs, behind Slint canvas)
  //                     Always present at the GL level. Transparent window bg lets it show.
  //
  //   2. ScreenLayer  — App screens (Home, Live, Movies, etc.) + TopNav
  //                     OPAQUE background. Shown when browsing. Hidden when video is fullscreen.
  //
  //   3. OsdLayer     — Player OSD controls (play/pause, seek, volume, title)
  //                     TRANSPARENT background. Shown when playing video. Hidden when browsing.
  //
  //   4. OverlayLayer — Full-screen overlays (Onboarding, Profile Menu, Source Dialog, Diagnostics)
  //                     Shown/hidden independently per overlay. Always on top when visible.
  //
  // Visibility rules:
  //   Browsing (not playing):  ScreenLayer=VISIBLE, OsdLayer=HIDDEN
  //   Playing fullscreen:      ScreenLayer=HIDDEN,  OsdLayer=VISIBLE  (video shows through)
  //   Onboarding:              OverlayLayer only (everything else hidden)
  //   Profile/Source dialog:   OverlayLayer on top of whatever is below
  // ════════════════════════════════════════════════════════════════════════

  // ── Layer control properties ──
  // Each layer has: visibility, opacity, position (x/y), size (w/h)
  // Set these from outside (Rust or Slint logic) — layers just react.
  // Defaults: full-size, full-opacity, origin (0,0).
  // Animate on change for smooth transitions (e.g. PiP mini-player).

  // ScreenLayer
  property <bool>   show-screen-layer: !PlayerState.is-fullscreen && !OnboardingState.is-active;
  property <float>  screen-layer-opacity: 1.0;
  property <length> screen-layer-x: 0;
  property <length> screen-layer-y: 0;
  property <length> screen-layer-w: root.width;
  property <length> screen-layer-h: root.height;

  // OsdLayer — M-019: hidden when an overlay is showing (mutually exclusive with OverlayLayer)
  // C-006: also hidden when mandatory overlays (privacy consent, PIN dialog, guided tour,
  // attribution) are active — prevents key events leaking through to OSD controls.
  property <bool>   show-osd-layer: PlayerState.is-playing && !OnboardingState.is-active &&
    !AppState.show-privacy-consent && !AppState.show-pin-dialog &&
    !AppState.show-guided-tour && !AppState.show-attribution &&
    !(AppState.show-vod-detail || AppState.show-series-detail ||
      AppState.show-source-dialog || AppState.show-profile-menu || AppState.show-profile-picker ||
      AppState.show-cast-picker);
  property <float>  osd-layer-opacity: 1.0;
  property <length> osd-layer-x: 0;
  property <length> osd-layer-y: 0;
  property <length> osd-layer-w: root.width;
  property <length> osd-layer-h: root.height;

  // OverlayLayer — only active when at least one overlay is actually showing
  // M-015: must not capture input when no overlay is visible
  property <bool>   show-overlay-layer: !OnboardingState.is-active &&
    (AppState.show-vod-detail || AppState.show-series-detail ||
     AppState.show-source-dialog || AppState.show-profile-menu || AppState.show-profile-picker ||
     AppState.show-cast-picker);
  property <float>  overlay-layer-opacity: 1.0;
  property <length> overlay-layer-x: 0;
  property <length> overlay-layer-y: 0;
  property <length> overlay-layer-w: root.width;
  property <length> overlay-layer-h: root.height;

  // Global keyboard shortcuts
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.F12 { DiagnosticsState.toggle(); return accept; }
      // M-006: pressing Up from any screen reveals TopNav so Settings (gear icon) is reachable
      if event.text == Key.UpArrow { AppState.nav-visible = true; return reject; }
      if event.text == Key.Escape {
        if DiagnosticsState.visible { DiagnosticsState.visible = false; return accept; }
        if AppState.show-profile-picker { AppState.show-profile-picker = false; return accept; }
        if AppState.show-cast-picker { AppState.show-cast-picker = false; return accept; }
        if AppState.show-profile-menu { AppState.show-profile-menu = false; return accept; }
        if AppState.show-source-dialog { AppState.show-source-dialog = false; return accept; }
        if AppState.show-vod-detail { AppState.show-vod-detail = false; return accept; }
        if AppState.show-series-detail { AppState.show-series-detail = false; return accept; }
        if PlayerState.is-fullscreen {
          PlayerState.is-fullscreen = false;
          return accept;
        }
        if PlayerState.is-playing {
          // M-005 + M-016: dismiss all overlays when playback stops
          AppState.show-vod-detail = false;
          AppState.show-series-detail = false;
          AppState.show-source-dialog = false;
          AppState.show-profile-menu = false;
          PlayerState.stop();
          return accept;
        }
      }
      return reject;
    }
  }

  // ── LAYER 2: ScreenLayer ──────────────────────────────────────────────
  // All screens are singleton sublayers — always instantiated (pre-rendered),
  // shown/hidden via `visible:`. Enables instant navigation and smooth transitions.
  Rectangle {
    x: screen-layer-x;
    y: screen-layer-y;
    width: screen-layer-w;
    height: screen-layer-h;
    opacity: screen-layer-opacity;
    visible: show-screen-layer;
    clip: true;
    background: Theme.background; // OPAQUE — covers VideoLayer
    animate x, y, width, height { duration: 300ms; easing: ease-in-out; }
    animate opacity { duration: 300ms; easing: ease-in-out; }

    // Singleton sublayers — each screen always exists, only one visible at a time
    // M-009: a companion FocusScope per screen receives focus when the screen becomes active,
    //        transferring D-pad focus from TopNav into screen content on navigation.
    home-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 0; }
    HomeScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 0;
      changed visible => { if self.visible { home-fs.focus(); } }
    }
    live-tv-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 1; }
    LiveTvScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 1;
      changed visible => { if self.visible { live-tv-fs.focus(); } }
    }
    epg-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 2; }
    EpgScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 2;
      changed visible => { if self.visible { epg-fs.focus(); } }
    }
    movies-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 3; }
    MoviesScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 3;
      changed visible => { if self.visible { movies-fs.focus(); } }
    }
    series-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 4; }
    SeriesScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 4;
      changed visible => { if self.visible { series-fs.focus(); } }
    }
    search-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 5; }
    SearchScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 5;
      changed visible => { if self.visible { search-fs.focus(); } }
    }
    library-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 6; }
    LibraryScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 6;
      changed visible => { if self.visible { library-fs.focus(); } }
    }
    settings-fs := FocusScope { width: 0; height: 0; visible: AppState.active-screen == 7; }
    SettingsScreen {
      width: 100%; height: 100%;
      visible: AppState.active-screen == 7;
      changed visible => { if self.visible { settings-fs.focus(); } }
    }

    // Top nav bar (floats over all screen sublayers)
    // nav-visible drives the y-translation animation inside TopNav (not `visible`,
    // so the slide-out animation plays before the element disappears).
    TopNav {
      width: 100%;
      nav-visible: AppState.nav-visible;
    }

    // Button legend bar — contextual D-pad hints, pinned to screen bottom
    ButtonLegend {
      y: parent.height - self.height;
      width: 100%;
    }

    // ── Offline banner (Epoch 8.2) ─────────────────────────────────────
    // Persistent, non-dismissible. Floats above content at bottom, above
    // ButtonLegend. Hidden when online (is-offline == false).
    if AppState.is-offline: Rectangle {
      y: parent.height - 36px - 48px; // sit above ButtonLegend (48px)
      width: 100%;
      height: 36px;
      background: Theme.status-warning;
      HorizontalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-sm;
        alignment: center;
        Text {
          text: AppState.network-status == 1 ? "No internet connection"
              : AppState.network-status == 2 ? "Internet unreachable"
              : AppState.network-status == 3 ? "Source unavailable — showing cached content"
              : "Offline — showing cached content";
          color: Theme.focus-ring;
          font-family: Theme.font-body;
          font-size: Theme.font-size-caption;
          font-weight: 600;
          vertical-alignment: center;
          horizontal-alignment: center;
        }
      }
    }
  }

  // ── LAYER 3: OsdLayer ─────────────────────────────────────────────────
  Rectangle {
    x: osd-layer-x;
    y: osd-layer-y;
    width: osd-layer-w;
    height: osd-layer-h;
    opacity: osd-layer-opacity;
    visible: show-osd-layer;
    clip: true;
    background: transparent;
    animate x, y, width, height { duration: 300ms; easing: ease-in-out; }
    animate opacity { duration: 300ms; easing: ease-in-out; }

    // C-022: OsdLayer no longer owns an Escape handler — the global FocusScope
    // above already routes Escape correctly (checks all overlays before stopping
    // playback). A local handler here would race with the global one and could
    // intercept Escape meant for ProfilePickerScreen or other overlays.

    PlayerScreen {
      width: 100%;
      height: 100%;
    }
  }

  // ── LAYER 4: OverlayLayer ─────────────────────────────────────────────
  // Onboarding — singleton, visibility controlled
  OnboardingScreen {
    width: 100%; height: 100%;
    visible: OnboardingState.is-active;
  }

  // Modals — singleton sublayers within OverlayLayer
  Rectangle {
    x: overlay-layer-x;
    y: overlay-layer-y;
    width: overlay-layer-w;
    height: overlay-layer-h;
    opacity: overlay-layer-opacity;
    visible: show-overlay-layer;
    clip: true;
    background: transparent;
    animate x, y, width, height { duration: 300ms; easing: ease-in-out; }
    animate opacity { duration: 200ms; easing: ease-in-out; }

    // Detail screens — full-screen overlays above the browse screens
    // M-007: each overlay owns a FocusScope that grabs focus when the overlay becomes visible
    vod-detail-fs := FocusScope { width: 0; height: 0; visible: AppState.show-vod-detail; }
    VodDetailScreen {
      width: 100%; height: 100%;
      visible: AppState.show-vod-detail;
      changed visible => { if self.visible { vod-detail-fs.focus(); } }
    }
    series-detail-fs := FocusScope { width: 0; height: 0; visible: AppState.show-series-detail; }
    SeriesDetailScreen {
      width: 100%; height: 100%;
      visible: AppState.show-series-detail;
      changed visible => { if self.visible { series-detail-fs.focus(); } }
    }

    SourceDialog {
      validate-state <=> AppState.source-validate-state;
      field-url <=> AppState.source-field-url;
      field-user <=> AppState.source-field-user;
      field-pass <=> AppState.source-field-pass;
      cancel-source => { AppState.cancel-source-dialog(); }
      validate-source => { AppState.validate-source-dialog(); }
      commit-source => { AppState.commit-source-dialog(); }
      source-type-changed(idx) => { AppState.source-type-changed(idx); }
    }
    ProfileMenu {
      visible: AppState.show-profile-menu;
      close => { AppState.show-profile-menu = false; }
    }

    // 10.6: Cast picker — full-screen scrim + centred panel
    CastPicker {
      width: 100%; height: 100%;
      visible: AppState.show-cast-picker;
      devices: AppState.cast-devices;
      device-selected(id) => {
        AppState.show-cast-picker = false;
        AppState.cast-to-device(id);
      }
      dismissed => { AppState.show-cast-picker = false; }
    }

    // M-033: ProfilePickerScreen as last child of OverlayLayer (highest z-order)
    ProfilePickerScreen {
      width: 100%; height: 100%;
    }
  }

  // 10.9: Resume prompt — bottom-centre toast, above OSD layer
  ResumePrompt {
    width: 100%; height: 100%;
    visible: AppState.show-resume-prompt;
    source-device: AppState.resume-source-device;
    resume-position: AppState.resume-position-label;
    resume => { AppState.show-resume-prompt = false; AppState.resume-playback(); }
    start-over => { AppState.show-resume-prompt = false; AppState.start-over-playback(); }
    // M-005: dismissed fires when Escape is pressed — just close the prompt, no action
    dismissed => { AppState.show-resume-prompt = false; }
  }
  // Sync progress overlay — visible only while sync is in progress (0 < progress < 1)
  if AppState.sync-progress > 0.0 && AppState.sync-progress < 1.0: Rectangle {
    width: 100%;
    height: Theme.top-nav-height;
    y: root.height - Theme.top-nav-height;
    background: Theme.card-surface;
    border-width: 1px;
    border-color: Theme.border-subtle;

    VerticalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      padding-top: Theme.spacing-xs;
      padding-bottom: Theme.spacing-xs;
      spacing: Theme.spacing-xs;
      alignment: center;

      Text {
        text: AppState.sync-message;
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        overflow: elide;
      }

      // Progress bar
      Rectangle {
        height: 3px;
        width: 100%;
        background: Theme.border-subtle;
        border-radius: 2px;

        Rectangle {
          x: 0;
          width: parent.width * AppState.sync-progress;
          height: 100%;
          background: @linear-gradient(90deg, #FF4B2B, #FF416C);
          border-radius: 2px;
        }
      }
    }
  }

  DiagnosticsPanel {}

  // Privacy consent — must-accept overlay, shown after onboarding on first launch.
  // Sits above everything so it cannot be bypassed.
  PrivacyConsent {
    width: 100%; height: 100%;
  }

  // Guided tour — full-screen walkthrough overlay, shown on demand after first launch.
  GuidedTour {
    width: 100%; height: 100%;
  }

  // PIN entry dialog — shown when switching to a PIN-protected profile.
  if AppState.show-pin-dialog: PinDialog {
    width: 100%; height: 100%;
    profile-name: AppState.pin-target-profile-name;
    verify-pin(pin) => { AppState.verify-pin(pin); }
    cancelled => { AppState.show-pin-dialog = false; }
  }
}
