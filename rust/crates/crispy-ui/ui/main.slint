import { Theme } from "globals/theme.slint";
import { AppState } from "globals/app-state.slint";
import { TopNav } from "components/top-nav.slint";

// Re-export globals so Rust can access them via ui.global::<T>()
export { Theme, AppState }
import { HomeScreen } from "screens/home.slint";
import { LiveTvScreen } from "screens/live-tv.slint";
import { EpgScreen } from "screens/epg.slint";
import { MoviesScreen } from "screens/movies.slint";
import { SeriesScreen } from "screens/series.slint";
import { SearchScreen } from "screens/search.slint";
import { SettingsScreen } from "screens/settings.slint";
import { LibraryScreen } from "screens/library.slint";
import { PlayerScreen, PlayerState } from "screens/player.slint";
import { OnboardingScreen, OnboardingState } from "screens/onboarding.slint";
import { VodDetailScreen } from "screens/vod-detail.slint";
import { SeriesDetailScreen } from "screens/series-detail.slint";
import { SourceDialog } from "components/source-dialog.slint";
import { DiagnosticsPanel, DiagnosticsState } from "components/diagnostics-panel.slint";
import { ProfileMenu, ProfilePickerScreen } from "components/profile-menu.slint";

// Re-export for Rust access
export { PlayerState, OnboardingState, DiagnosticsState }

export component AppWindow inherits Window {
  title: "CrispyTivi";
  min-width: 320px;
  min-height: 480px;
  preferred-width: 1280px;
  preferred-height: 720px;

  // Window background transparent so mpv OpenGL underlay (VideoLayer) is visible
  background: transparent;

  // ════════════════════════════════════════════════════════════════════════
  // 4-LAYER ARCHITECTURE
  //
  // Each layer is a distinct full-size view, independently shown/hidden.
  // Layer names are for isolation — z-order is determined by declaration order.
  //
  //   1. VideoLayer   — mpv OpenGL underlay (rendered by main.rs, behind Slint canvas)
  //                     Always present at the GL level. Transparent window bg lets it show.
  //
  //   2. ScreenLayer  — App screens (Home, Live, Movies, etc.) + TopNav
  //                     OPAQUE background. Shown when browsing. Hidden when video is fullscreen.
  //
  //   3. OsdLayer     — Player OSD controls (play/pause, seek, volume, title)
  //                     TRANSPARENT background. Shown when playing video. Hidden when browsing.
  //
  //   4. OverlayLayer — Full-screen overlays (Onboarding, Profile Menu, Source Dialog, Diagnostics)
  //                     Shown/hidden independently per overlay. Always on top when visible.
  //
  // Visibility rules:
  //   Browsing (not playing):  ScreenLayer=VISIBLE, OsdLayer=HIDDEN
  //   Playing fullscreen:      ScreenLayer=HIDDEN,  OsdLayer=VISIBLE  (video shows through)
  //   Onboarding:              OverlayLayer only (everything else hidden)
  //   Profile/Source dialog:   OverlayLayer on top of whatever is below
  // ════════════════════════════════════════════════════════════════════════

  // ── Layer control properties ──
  // Each layer has: visibility, opacity, position (x/y), size (w/h)
  // Set these from outside (Rust or Slint logic) — layers just react.
  // Defaults: full-size, full-opacity, origin (0,0).
  // Animate on change for smooth transitions (e.g. PiP mini-player).

  // ScreenLayer
  property <bool>   show-screen-layer: !PlayerState.is-fullscreen && !OnboardingState.is-active;
  property <float>  screen-layer-opacity: 1.0;
  property <length> screen-layer-x: 0;
  property <length> screen-layer-y: 0;
  property <length> screen-layer-w: root.width;
  property <length> screen-layer-h: root.height;

  // OsdLayer — M-019: hidden when an overlay is showing (mutually exclusive with OverlayLayer)
  property <bool>   show-osd-layer: PlayerState.is-playing && !OnboardingState.is-active &&
    !(AppState.show-vod-detail || AppState.show-series-detail ||
      AppState.show-source-dialog || AppState.show-profile-menu || AppState.show-profile-picker);
  property <float>  osd-layer-opacity: 1.0;
  property <length> osd-layer-x: 0;
  property <length> osd-layer-y: 0;
  property <length> osd-layer-w: root.width;
  property <length> osd-layer-h: root.height;

  // OverlayLayer — only active when at least one overlay is actually showing
  // M-015: must not capture input when no overlay is visible
  property <bool>   show-overlay-layer: !OnboardingState.is-active &&
    (AppState.show-vod-detail || AppState.show-series-detail ||
     AppState.show-source-dialog || AppState.show-profile-menu || AppState.show-profile-picker);
  property <float>  overlay-layer-opacity: 1.0;
  property <length> overlay-layer-x: 0;
  property <length> overlay-layer-y: 0;
  property <length> overlay-layer-w: root.width;
  property <length> overlay-layer-h: root.height;

  // Global keyboard shortcuts
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.F12 { DiagnosticsState.toggle(); return accept; }
      if event.text == Key.Escape {
        if DiagnosticsState.visible { DiagnosticsState.visible = false; return accept; }
        if AppState.show-profile-picker { AppState.show-profile-picker = false; return accept; }
        if AppState.show-profile-menu { AppState.show-profile-menu = false; return accept; }
        if AppState.show-source-dialog { AppState.show-source-dialog = false; return accept; }
        if AppState.show-vod-detail { AppState.show-vod-detail = false; return accept; }
        if AppState.show-series-detail { AppState.show-series-detail = false; return accept; }
        if PlayerState.is-fullscreen {
          PlayerState.is-fullscreen = false;
          return accept;
        }
        if PlayerState.is-playing {
          // M-005 + M-016: dismiss all overlays when playback stops
          AppState.show-vod-detail = false;
          AppState.show-series-detail = false;
          AppState.show-source-dialog = false;
          AppState.show-profile-menu = false;
          PlayerState.stop();
          return accept;
        }
      }
      return reject;
    }
  }

  // ── LAYER 2: ScreenLayer ──────────────────────────────────────────────
  // All screens are singleton sublayers — always instantiated (pre-rendered),
  // shown/hidden via `visible:`. Enables instant navigation and smooth transitions.
  Rectangle {
    x: screen-layer-x;
    y: screen-layer-y;
    width: screen-layer-w;
    height: screen-layer-h;
    opacity: screen-layer-opacity;
    visible: show-screen-layer;
    clip: true;
    background: Theme.background; // OPAQUE — covers VideoLayer
    animate x, y, width, height { duration: 300ms; easing: ease-in-out; }
    animate opacity { duration: 300ms; easing: ease-in-out; }

    // Singleton sublayers — each screen always exists, only one visible at a time
    HomeScreen     { width: 100%; height: 100%; visible: AppState.active-screen == 0; }
    LiveTvScreen   { width: 100%; height: 100%; visible: AppState.active-screen == 1; }
    EpgScreen      { width: 100%; height: 100%; visible: AppState.active-screen == 2; }
    MoviesScreen   { width: 100%; height: 100%; visible: AppState.active-screen == 3; }
    SeriesScreen   { width: 100%; height: 100%; visible: AppState.active-screen == 4; }
    SearchScreen   { width: 100%; height: 100%; visible: AppState.active-screen == 5; }
    LibraryScreen  { width: 100%; height: 100%; visible: AppState.active-screen == 6; }
    SettingsScreen { width: 100%; height: 100%; visible: AppState.active-screen == 7; }

    // Top nav bar (floats over all screen sublayers)
    TopNav {
      y: 0;
      width: 100%;
      visible: AppState.nav-visible;
    }
  }

  // ── LAYER 3: OsdLayer ─────────────────────────────────────────────────
  Rectangle {
    x: osd-layer-x;
    y: osd-layer-y;
    width: osd-layer-w;
    height: osd-layer-h;
    opacity: osd-layer-opacity;
    visible: show-osd-layer;
    clip: true;
    background: transparent;
    animate x, y, width, height { duration: 300ms; easing: ease-in-out; }
    animate opacity { duration: 300ms; easing: ease-in-out; }

    // C-001: Escape/Back hides OSD and returns to screen layer
    FocusScope {
      width: 0; height: 0;
      key-pressed(event) => {
        if event.text == Key.Escape || event.text == Key.Back {
          PlayerState.stop();
          return accept;
        }
        return reject;
      }
    }

    PlayerScreen {
      width: 100%;
      height: 100%;
    }
  }

  // ── LAYER 4: OverlayLayer ─────────────────────────────────────────────
  // Profile Picker — full-screen, above OverlayLayer, below Onboarding
  ProfilePickerScreen {}

  // Onboarding — singleton, visibility controlled
  OnboardingScreen {
    width: 100%; height: 100%;
    visible: OnboardingState.is-active;
  }

  // Modals — singleton sublayers within OverlayLayer
  Rectangle {
    x: overlay-layer-x;
    y: overlay-layer-y;
    width: overlay-layer-w;
    height: overlay-layer-h;
    opacity: overlay-layer-opacity;
    visible: show-overlay-layer;
    clip: true;
    background: transparent;
    animate x, y, width, height { duration: 300ms; easing: ease-in-out; }
    animate opacity { duration: 200ms; easing: ease-in-out; }

    // Detail screens — full-screen overlays above the browse screens
    VodDetailScreen {
      width: 100%; height: 100%;
      visible: AppState.show-vod-detail;
    }
    SeriesDetailScreen {
      width: 100%; height: 100%;
      visible: AppState.show-series-detail;
    }

    SourceDialog {}
    ProfileMenu {
      visible: AppState.show-profile-menu;
      close => { AppState.show-profile-menu = false; }
    }
  }
  DiagnosticsPanel {}
}
