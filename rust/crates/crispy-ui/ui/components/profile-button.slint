import { Theme } from "../globals/theme.slint";

export component ProfileButton inherits FocusScope {
  in property <string> initial: "P";
  callback clicked();

  width: 44px;
  height: 44px;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 44px;
    height: 44px;
    border-radius: Theme.radius-pill;
    background: Theme.btn-primary-bg;
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    Text {
      text: root.initial;
      color: Theme.btn-primary-fg;
      font-family: Theme.font-display;
      font-size: Theme.font-size-body;
      font-weight: 700;
      horizontal-alignment: center;
      vertical-alignment: center;
    }

    TouchArea {
      clicked => {
        root.clicked();
      }
    }
  }
}
