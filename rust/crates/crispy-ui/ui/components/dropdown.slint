import { Theme } from "../globals/theme.slint";

component SegmentTab inherits FocusScope {
  in property <string> label;
  in property <bool> active: false;
  callback activated();

  width: label-text.preferred-width + 24px;
  height: 36px;

  key-pressed(event) => {
    if event.text == Key.Return { root.activated(); return accept; }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-sm;
    background: root.active
      ? rgba(255, 255, 255, 0.15)
      : parent.has-focus
        ? rgba(255, 255, 255, 0.08)
        : transparent;
    border-width: parent.has-focus ? Theme.focus-ring-width : root.active ? 1px : 0px;
    border-color: parent.has-focus ? Theme.focus-ring : rgba(255, 255, 255, 0.2);

    animate background { duration: 150ms; }

    label-text := Text {
      text: root.label;
      color: root.active ? Theme.text-primary : Theme.text-secondary;
      font-family: root.active ? Theme.font-display : Theme.font-body;
      font-size: Theme.font-size-caption;
      font-weight: root.active ? 700 : 500;
      horizontal-alignment: center;
      vertical-alignment: center;
    }
    TouchArea { clicked => { root.activated(); } }
  }
}

export component Dropdown inherits VerticalLayout {
  in property <string> label;
  in property <[string]> model;
  in-out property <int> current-index;
  in-out property <string> current-value: model[current-index];

  callback selected(string);

  spacing: Theme.spacing-sm;

  Text {
    text: root.label;
    color: Theme.text-secondary;
    font-size: Theme.font-size-caption;
    font-family: Theme.font-body;
  }

  Rectangle {
    height: 48px;
    border-radius: Theme.radius-md;
    background: Theme.card-surface;
    border-width: 1px;
    border-color: Theme.card-border;

    HorizontalLayout {
      padding: 6px;
      spacing: 6px;

      for item[idx] in root.model: SegmentTab {
        label: item;
        active: root.current-index == idx;
        activated => {
          root.current-index = idx;
          root.selected(item);
        }
      }
    }
  }
}
