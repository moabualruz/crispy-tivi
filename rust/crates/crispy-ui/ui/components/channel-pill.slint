import { Theme } from "../globals/theme.slint";
import { ChannelData } from "../globals/app-state.slint";
import { IconPlay } from "icons.slint";

export component ChannelPill inherits FocusScope {
  in property <ChannelData> channel;
  callback clicked();

  width: 200px;
  height: 48px;

  key-pressed(event) => {
    if event.text == Key.Return { root.clicked(); return accept; }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-md;
    background: Theme.card-surface;
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.card-border;

    animate background { duration: 150ms; }

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-sm;

      Text {
        text: root.channel.name;
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        vertical-alignment: center;
        overflow: elide;
        horizontal-stretch: 1;
      }
      IconPlay {
        size: 14px;
        fill: Theme.accent;
      }
    }
    TouchArea { clicked => { root.clicked(); } }
  }
}
