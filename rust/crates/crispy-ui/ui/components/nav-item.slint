import { Theme } from "../globals/theme.slint";

export component NavItem inherits FocusScope {
  in property <string> label;
  in property <string> icon-text;
  in property <bool> active: false;

  callback clicked();

  height: 40px;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%;
    height: 100%;
    border-radius: Theme.radius-pill;
    background: root.active
      ? Theme.btn-secondary-bg
      : root.has-focus
        ? Theme.border-subtle
        : transparent;
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: root.has-focus ? Theme.focus-ring : transparent;

    animate background { duration: 150ms; }
    animate border-width { duration: 150ms; }

    HorizontalLayout {
      padding-left: 16px;
      padding-right: 16px;
      padding-top: 8px;
      padding-bottom: 8px;
      spacing: Theme.spacing-sm;
      alignment: center;

      if icon-text != "": Text {
        text: icon-text;
        color: root.active ? Theme.text-primary : Theme.text-secondary;
        font-size: 18px;
        vertical-alignment: center;
      }

      Text {
        text: label;
        color: root.active ? Theme.text-primary : Theme.text-secondary;
        font-family: root.active ? Theme.font-display : Theme.font-body;
        font-size: Theme.font-size-body;
        font-weight: root.active ? 700 : 500;
        vertical-alignment: center;
      }
    }

    TouchArea {
      clicked => {
        root.clicked();
      }
    }
  }
}
