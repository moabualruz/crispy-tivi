import { Theme } from "../globals/theme.slint";

export component NavItem inherits FocusScope {
  in property <string> label;
  in property <string> icon-text;
  in property <bool> active: false;

  callback clicked();

  height: 40px;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%;
    height: 100%;
    border-radius: 20px;
    background: root.has-focus ? rgba(255, 255, 255, 0.1) : transparent;
    border-width: 2px;
    border-color: root.has-focus ? rgba(255, 255, 255, 0.5) : transparent;

    HorizontalLayout {
      padding-left: 16px;
      padding-right: 16px;
      padding-top: 8px;
      padding-bottom: 8px;
      spacing: Theme.spacing-sm;
      alignment: center;

      if icon-text != "": Text {
        text: icon-text;
        color: active ? #FFFFFF : rgba(255, 255, 255, 0.60);
        font-size: 18px;
        font-weight: active ? 700 : 500;
        vertical-alignment: center;
      }

      Text {
        text: label;
        color: active ? #FFFFFF : rgba(255, 255, 255, 0.60);
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        font-weight: active ? 700 : 500;
        vertical-alignment: center;
      }
    }

    TouchArea {
      clicked => {
        root.clicked();
      }
    }
  }
}
