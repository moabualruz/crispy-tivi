import { Theme } from "../globals/theme.slint";

export component NavItem inherits FocusScope {
  in property <string> label;
  in property <string> icon-text;
  in property <bool> active: false;
  in property <bool> nav-expanded: false;

  callback clicked();

  width: nav-expanded ? Theme.nav-rail-expanded : Theme.nav-rail-collapsed;
  height: 48px;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%;
    height: 100%;
    border-radius: Theme.radius-pill;
    background: active ? Theme.surface : (root.has-focus ? Theme.surface-glass : transparent);
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-sm;
      alignment: nav-expanded ? start : center;

      Text {
        text: icon-text;
        color: active ? Theme.accent : Theme.text-secondary;
        font-size: 24px;
        vertical-alignment: center;
      }

      if nav-expanded: Text {
        text: label;
        color: active ? Theme.text-primary : Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        vertical-alignment: center;
      }
    }

    TouchArea {
      clicked => {
        root.clicked();
      }
    }
  }
}
