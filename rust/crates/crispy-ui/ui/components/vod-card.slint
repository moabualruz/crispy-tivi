import { Theme } from "../globals/theme.slint";
import { AppState, VodData } from "../globals/app-state.slint";
import { IconMovie, IconStar } from "icons.slint";

export component VodCard inherits FocusScope {
  in property <VodData> item;

  accessible-role: button;
  accessible-label: item.name;

  callback clicked();

  width: 160px;
  height: 280px;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%;
    height: 100%;
    border-radius: Theme.radius-md;
    background: Theme.card-surface;
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.card-border;
    clip: true;

    // Card lift on focus: glow + upward shadow offset simulates scale lift
    drop-shadow-blur: root.has-focus ? 20px : 0px;
    drop-shadow-offset-y: root.has-focus ? -6px : 0px;
    drop-shadow-color: root.has-focus ? Theme.focus-glow : transparent;

    animate border-color { duration: 150ms; }
    animate border-width { duration: 150ms; }
    animate drop-shadow-blur {
      duration: 300ms;
      easing: cubic-bezier(0.19, 1.0, 0.22, 1.0);
    }
    animate drop-shadow-offset-y {
      duration: 300ms;
      easing: cubic-bezier(0.19, 1.0, 0.22, 1.0);
    }

    VerticalLayout {
      // Poster area
      Rectangle {
        height: 220px;
        background: @linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(0,0,0,0.6) 100%);

        // Loaded poster image
        if item.poster.width > 0 && item.poster.height > 0: Image {
          source: item.poster;
          width: 100%;
          height: 100%;
          image-fit: cover;
        }

        // Text fallback (shown when no poster loaded)
        if item.poster.width == 0 || item.poster.height == 0: Rectangle {
          width: 100%;
          height: 100%;
          background: transparent;

          Text {
            text: item.name;
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            font-weight: 600;
            wrap: word-wrap;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
            width: parent.width - Theme.spacing-md * 2;
            x: Theme.spacing-md;
          }
        }

        // Year badge
        if item.year != "": Rectangle {
          x: Theme.spacing-xs;
          y: Theme.spacing-xs;
          width: yr-text.preferred-width + 12px;
          height: 20px;
          border-radius: Theme.radius-pill;
          background: Theme.overlay;

          yr-text := Text {
            text: item.year;
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }

        // Rating badge
        if item.rating != "": Rectangle {
          x: parent.width - self.width - Theme.spacing-xs;
          y: Theme.spacing-xs;
          width: rating-text.preferred-width + 12px;
          height: 20px;
          border-radius: Theme.radius-pill;
          background: Theme.accent;

          rating-text := Text {
            text: item.rating;
            color: Theme.btn-secondary-fg;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }

        // Favorite star (bottom-right of poster)
        if item.is-favorite: Rectangle {
          x: parent.width - self.width - Theme.spacing-xs;
          y: parent.height - self.height - Theme.spacing-xs;
          width: 24px; height: 24px;
          border-radius: Theme.radius-pill;
          background: Theme.overlay;
          IconStar {
            size: 14px;
            fill: Theme.accent;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
          }
        }

        // Duration badge (bottom-left of poster)
        if item.duration-minutes > 0: Rectangle {
          x: Theme.spacing-xs;
          y: parent.height - self.height - Theme.spacing-xs;
          width: dur-text.preferred-width + 10px;
          height: 20px;
          border-radius: Theme.radius-pill;
          background: Theme.overlay;
          dur-text := Text {
            text: item.duration-minutes + "m";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }
      }

      // Title area
      VerticalLayout {
        padding: Theme.spacing-sm;
        spacing: Theme.spacing-2xs;

        Text {
          text: item.name;
          color: Theme.text-primary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-caption;
          font-weight: 600;
          overflow: elide;
          wrap: no-wrap;
        }
        if item.genre != "": Text {
          text: item.genre;
          color: Theme.text-secondary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-small;
          overflow: elide;
          wrap: no-wrap;
        }
      }
    }

    TouchArea {
      clicked => { root.clicked(); }
    }
  }
}
