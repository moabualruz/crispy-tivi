import { Theme } from "../globals/theme.slint";
import { VodData } from "../globals/app-state.slint";

export component VodCard inherits FocusScope {
  in property <VodData> item;

  callback clicked();

  width: 160px;
  height: 280px;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%;
    height: 100%;
    border-radius: Theme.radius-md;
    background: Theme.card-surface;
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.card-border;
    clip: true;

    // Focus glow effect
    drop-shadow-blur: root.has-focus ? 12px : 0px;
    drop-shadow-color: root.has-focus ? Theme.focus-glow : transparent;

    animate border-color { duration: 150ms; }
    animate drop-shadow-blur { duration: 200ms; }

    VerticalLayout {
      // Poster area
      Rectangle {
        height: 220px;
        background: @linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(0,0,0,0.6) 100%);

        // Year badge
        if item.year != "": Rectangle {
          x: Theme.spacing-xs;
          y: Theme.spacing-xs;
          width: yr-text.preferred-width + 12px;
          height: 20px;
          border-radius: 10px;
          background: rgba(0, 0, 0, 0.6);

          yr-text := Text {
            text: item.year;
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }

        // Rating badge
        if item.rating != "": Rectangle {
          x: parent.width - self.width - Theme.spacing-xs;
          y: Theme.spacing-xs;
          width: rating-text.preferred-width + 12px;
          height: 20px;
          border-radius: 10px;
          background: Theme.accent;

          rating-text := Text {
            text: item.rating;
            color: #FFFFFF;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }
      }

      // Title area
      VerticalLayout {
        padding: Theme.spacing-sm;
        spacing: 2px;

        Text {
          text: item.name;
          color: Theme.text-primary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-caption;
          font-weight: 600;
          overflow: elide;
          wrap: no-wrap;
        }
        if item.genre != "": Text {
          text: item.genre;
          color: Theme.text-secondary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-small;
          overflow: elide;
          wrap: no-wrap;
        }
      }
    }

    TouchArea {
      clicked => { root.clicked(); }
    }
  }
}
