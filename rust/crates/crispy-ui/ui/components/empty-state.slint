import { Theme } from "../globals/theme.slint";
import { ActionButton } from "./action-button.slint";

export component EmptyState inherits Rectangle {
  in property <string> title: "Nothing here yet";
  in property <string> subtitle: "";
  in property <string> cta-text: "";

  callback cta-clicked();

  VerticalLayout {
    alignment: center;
    spacing: Theme.spacing-lg;

    // Icon circle
    HorizontalLayout {
      alignment: center;

      Rectangle {
        width: 80px;
        height: 80px;
        border-radius: 40px;
        background: Theme.btn-secondary-bg;
        border-width: 1px;
        border-color: Theme.card-border;

        @children
      }
    }

    // Title
    Text {
      text: title;
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-h2;
      font-weight: 700;
      horizontal-alignment: center;
    }

    // Subtitle
    if subtitle != "": Text {
      text: subtitle;
      color: Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-body;
      horizontal-alignment: center;
      wrap: word-wrap;
      max-width: 400px;
    }

    // CTA button (primary: white bg, black text)
    if cta-text != "": HorizontalLayout {
      alignment: center;

      ActionButton {
        label: cta-text;
        is-primary: true;
        width: 200px;
        clicked => { root.cta-clicked(); }
      }
    }
  }
}
