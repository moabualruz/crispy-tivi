import { Theme } from "../globals/theme.slint";

export component ActionButton inherits FocusScope {
  in property <string> label;
  in property <bool> is-primary: false;
  
  callback clicked();

  height: 44px;

  key-pressed(event) => {
    if event.text == Key.Return { root.clicked(); return accept; }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-sm;
    background: root.is-primary
      ? Theme.accent-gradient
      : Theme.btn-secondary-bg;
      
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    animate background { duration: 150ms; }

    Text {
      text: root.label;
      color: root.is-primary ? #FFFFFF : Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-caption;
      font-weight: root.is-primary ? 700 : 500;
      horizontal-alignment: center;
      vertical-alignment: center;
    }

    TouchArea { clicked => { root.clicked(); } }
  }
}
