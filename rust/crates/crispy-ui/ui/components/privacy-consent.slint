// Privacy Policy Consent Overlay (Epoch 13.15)
// Shown on first launch after onboarding completes.
// User must accept to proceed. Decline exits the app.

import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { ActionButton } from "action-button.slint";
import { ScrollView } from "std-widgets.slint";

export component PrivacyConsent inherits Rectangle {
  visible: AppState.show-privacy-consent;
  width: 100%; height: 100%;

  // C-007: tracks whether the full policy text panel is open within this overlay.
  // "View Full Privacy Policy" reveals it; "Back" hides it. No navigation away.
  property <bool> show-policy-text: false;

  // M-054: Root focus trap — grabs focus when visible so no key events leak to
  // layers below. Consent is mandatory; Escape is intentionally rejected here
  // (no dismiss — user must Accept or Decline explicitly per design rules).
  privacy-trap := FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      // C-007: if policy text panel is open, Escape closes it back to summary view
      if event.text == Key.Escape && root.show-policy-text {
        root.show-policy-text = false;
        return accept;
      }
      // Otherwise trap Escape — consent cannot be bypassed by keyboard
      if event.text == Key.Escape { return accept; }
      return reject;
    }
  }

  changed visible => {
    if root.visible { privacy-trap.focus(); }
  }

  // Full-screen semi-transparent dim — no tap-to-dismiss (consent is mandatory)
  Rectangle {
    width: 100%; height: 100%;
    background: Theme.overlay-heavy;
  }

  // Consent card
  Rectangle {
    width: min(560px, root.width - Theme.spacing-2xl * 2);
    height: min(480px, root.height - Theme.spacing-2xl * 2);
    x: (root.width - self.width) / 2;
    y: (root.height - self.height) / 2;
    border-radius: Theme.radius-md;
    background: Theme.card-surface;
    border-width: 1px;
    border-color: Theme.card-border;

    VerticalLayout {
      padding: Theme.spacing-lg;
      spacing: Theme.spacing-lg;

      // Header
      Text {
        text: "Privacy Policy";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h2;
        font-weight: 700;
        horizontal-alignment: center;
      }

      // Summary bullets
      VerticalLayout {
        spacing: Theme.spacing-sm;

        for bullet in [
          "· Your media sources and watch history are stored locally on this device only.",
          "· No personal data is sent to CrispyTivi servers without your explicit consent.",
          "· Optional crash reports help us fix bugs — you can opt in or out at any time in Settings.",
          "· CrispyTivi never sells or shares your data with third parties.",
        ]: Text {
          text: bullet;
          color: Theme.text-secondary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          wrap: word-wrap;
        }
      }

      // C-007: "View Full Policy" — toggles inline policy text within this overlay.
      // No navigation away; user stays in consent flow.
      if !root.show-policy-text: view-btn := FocusScope {
        height: 32px;
        width: 100%;
        key-pressed(event) => {
          if event.text == Key.Return { root.show-policy-text = true; return accept; }
          return reject;
        }
        Rectangle {
          width: 100%; height: 100%;
          background: view-btn.has-focus ? Theme.focus-bg : transparent;
          border-radius: Theme.radius-sm;
          border-width: view-btn.has-focus ? Theme.focus-ring-width : 0px;
          border-color: view-btn.has-focus ? Theme.focus-ring : transparent;
          Text {
            text: "View Full Privacy Policy →";
            color: Theme.accent;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
          TouchArea { clicked => { root.show-policy-text = true; } }
        }
      }

      // C-007: Inline policy text panel — replaces summary bullets when open.
      // "Back" returns to the summary + button view.
      if root.show-policy-text: VerticalLayout {
        spacing: Theme.spacing-sm;
        vertical-stretch: 1;

        back-btn := FocusScope {
          height: 32px;
          width: 100%;
          key-pressed(event) => {
            if event.text == Key.Return || event.text == Key.Escape {
              root.show-policy-text = false;
              return accept;
            }
            return reject;
          }
          Rectangle {
            width: 100%; height: 100%;
            background: back-btn.has-focus ? Theme.focus-bg : transparent;
            border-radius: Theme.radius-sm;
            border-width: back-btn.has-focus ? Theme.focus-ring-width : 0px;
            border-color: back-btn.has-focus ? Theme.focus-ring : transparent;
            Text {
              text: "← Back";
              color: Theme.accent;
              font-family: Theme.font-body;
              font-size: Theme.font-size-caption;
              horizontal-alignment: left;
              vertical-alignment: center;
            }
            TouchArea { clicked => { root.show-policy-text = false; } }
          }
        }

        ScrollView {
          vertical-stretch: 1;
          VerticalLayout {
            spacing: Theme.spacing-sm;
            padding: Theme.spacing-xs;
            Text {
              text: "Privacy Policy\n\nEffective date: 2025-01-01\n\nCrispyTivi stores all your media sources, watch history, and preferences locally on your device. No personal data is transmitted to CrispyTivi servers unless you explicitly opt in to crash reporting in Settings.\n\nCrash reports, if enabled, contain anonymised diagnostic data only — no media URLs, credentials, or watch history.\n\nCrispyTivi never sells, shares, or monetises your data. Third-party IPTV sources you add are subject to their own privacy terms.\n\nYou may delete all local data at any time from Settings → Storage → Clear All Data.";
              color: Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-small;
              wrap: word-wrap;
            }
          }
        }
      }

      // Spacer
      Rectangle { vertical-stretch: 1; background: transparent; }

      // Two equal-weight action buttons
      HorizontalLayout {
        spacing: Theme.spacing-md;

        decline-btn := FocusScope {
          horizontal-stretch: 1;
          height: 48px;
          key-pressed(event) => {
            if event.text == Key.Return { AppState.decline-privacy(); return accept; }
            return reject;
          }
          Rectangle {
            width: 100%; height: 100%;
            border-radius: Theme.radius-sm;
            background: decline-btn.has-focus ? Theme.focus-bg : Theme.btn-secondary-bg;
            border-width: decline-btn.has-focus ? Theme.focus-ring-width : 1px;
            border-color: decline-btn.has-focus ? Theme.focus-ring : Theme.card-border;
            Text {
              text: "Decline";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              font-weight: 600;
              horizontal-alignment: center;
              vertical-alignment: center;
            }
            TouchArea { clicked => { AppState.decline-privacy(); } }
          }
        }

        accept-btn := FocusScope {
          horizontal-stretch: 1;
          height: 48px;
          key-pressed(event) => {
            if event.text == Key.Return { AppState.accept-privacy(); return accept; }
            return reject;
          }
          Rectangle {
            width: 100%; height: 100%;
            border-radius: Theme.radius-sm;
            background: accept-btn.has-focus ? Theme.surface-glass : Theme.btn-primary-bg;
            border-width: accept-btn.has-focus ? Theme.focus-ring-width : 0px;
            border-color: accept-btn.has-focus ? Theme.focus-ring : transparent;
            Text {
              text: "Accept";
              color: Theme.btn-primary-fg;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              font-weight: 700;
              horizontal-alignment: center;
              vertical-alignment: center;
            }
            TouchArea { clicked => { AppState.accept-privacy(); } }
          }
        }
      }
    }
  }
}
