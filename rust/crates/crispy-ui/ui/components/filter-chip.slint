import { Theme } from "../globals/theme.slint";

export component FilterChip inherits FocusScope {
  in property <string> label;
  in property <bool> active: false;
  callback activated();

  width: label-text.preferred-width + 32px;
  height: 32px;

  key-pressed(event) => {
    if event.text == Key.Return {
      root.activated();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-md;
    background: root.has-focus
      ? Theme.focus-bg
      : root.active
        ? rgba(255, 255, 255, 0.2)
        : rgba(255, 255, 255, 0.08);
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.border-subtle;

    animate background { duration: 150ms; }

    label-text := Text {
      text: root.label;
      color: root.active ? Theme.text-primary : Theme.text-secondary;
      font-size: Theme.font-size-small;
      font-weight: root.active ? 700 : 500;
      horizontal-alignment: center;
      vertical-alignment: center;
    }
    TouchArea {
      clicked => { root.activated(); }
    }
  }
}
