import { Theme } from "../globals/theme.slint";

export component InputField inherits VerticalLayout {
  in property <string> label;
  in property <string> placeholder-text;
  in property <InputType> input-type: InputType.text;
  in-out property <string> text <=> input.text;

  callback edited(string);
  callback accepted(string);

  spacing: Theme.spacing-sm;

  Text {
    text: root.label;
    color: Theme.text-secondary;
    font-size: Theme.font-size-caption;
    font-family: Theme.font-body;
  }

  FocusScope {
    height: 48px;

    Rectangle {
      width: 100%; height: 100%;
      border-radius: Theme.radius-md;
      background: parent.has-focus ? Theme.border-subtle : Theme.card-surface;
      border-width: parent.has-focus ? Theme.focus-ring-width : 1px;
      border-color: parent.has-focus ? Theme.focus-ring : Theme.card-border;

      HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;

        input := TextInput {
          text: "";
          color: Theme.text-primary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          single-line: true;
          input-type: root.input-type;
          vertical-alignment: center;
          selection-background-color: Theme.text-disabled;
          selection-foreground-color: Theme.text-primary;

          edited => { root.edited(self.text); }
          accepted => { root.accepted(self.text); }
        }
      }

      // Placeholder text overlay if empty
      if input.text == "": Text {
        x: Theme.spacing-md;
        y: (parent.height - self.height) / 2;
        text: root.placeholder-text;
        color: Theme.text-disabled;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        vertical-alignment: center;
      }
    }
  }
}
