import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { NavItem } from "nav-item.slint";
import { ProfileButton } from "profile-button.slint";
import { SearchButton } from "search-button.slint";
export component TopNav inherits Rectangle {
  // Auto-hide: driven by AppState.nav-visible (set by scroll direction in Rust).
  // Slides up by its own height when hidden, slides back down when shown.
  // Using y-translation instead of `visible` so the animation plays on both directions.
  in property <bool> nav-visible: true;

  width: 100%;
  height: Theme.top-nav-height;
  background: Theme.surface-glass;

  y: nav-visible ? 0px : -Theme.top-nav-height;
  animate y {
    duration: 300ms;
    easing: ease-in-out;
  }

  HorizontalLayout {
    padding-left: Theme.content-padding-h;
    padding-right: Theme.content-padding-h;
    spacing: Theme.spacing-sm;
    alignment: start;

    // Profile bubble
    VerticalLayout {
      alignment: center;
      ProfileButton {
        initial: "P";
        clicked => {
          AppState.show-profile-picker = !AppState.show-profile-picker;
        }
      }
    }

    Rectangle { width: 8px; }

    // Nav items — For You (0), Live (1), Guide (2), Movies (3), Shows (4), Library (6)
    VerticalLayout {
      alignment: center;
      NavItem {
        label: "For You";
        active: AppState.active-screen == 0;
        clicked => { AppState.active-screen = 0; AppState.navigate(0); }
      }
    }
    VerticalLayout {
      alignment: center;
      NavItem {
        label: "Live";
        active: AppState.active-screen == 1;
        clicked => { AppState.active-screen = 1; AppState.navigate(1); }
      }
    }
    VerticalLayout {
      alignment: center;
      NavItem {
        label: "Guide";
        active: AppState.active-screen == 2;
        clicked => { AppState.active-screen = 2; AppState.navigate(2); }
      }
    }
    VerticalLayout {
      alignment: center;
      NavItem {
        label: "Movies";
        active: AppState.active-screen == 3;
        clicked => { AppState.active-screen = 3; AppState.navigate(3); }
      }
    }
    VerticalLayout {
      alignment: center;
      NavItem {
        label: "Shows";
        active: AppState.active-screen == 4;
        clicked => { AppState.active-screen = 4; AppState.navigate(4); }
      }
    }
    VerticalLayout {
      alignment: center;
      NavItem {
        label: "Library";
        active: AppState.active-screen == 6;
        clicked => { AppState.active-screen = 6; AppState.navigate(6); }
      }
    }

    // Spacer pushes search to right
    Rectangle { horizontal-stretch: 1; }

    // Right: Search pill
    VerticalLayout {
      alignment: center;
      SearchButton {
        text: "Search";
        clicked => { AppState.active-screen = 5; AppState.navigate(5); }
      }
    }
  }
}
