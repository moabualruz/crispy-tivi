import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { NavItem } from "nav-item.slint";

export component TopNav inherits Rectangle {
  width: 100%;
  height: 72px;
  background: transparent;

  HorizontalLayout {
    padding-left: 40px;
    padding-right: 40px;
    alignment: space-between;

    // Left group: profile bubble + nav items
    HorizontalLayout {
      spacing: 4px;
      alignment: start;

      // Profile bubble
      FocusScope {
        width: 44px;
        height: 44px;

        key-pressed(event) => {
          if event.text == Key.Return || event.text == " " {
            AppState.navigate(6);
            return accept;
          }
          return reject;
        }

        Rectangle {
          width: 44px;
          height: 44px;
          border-radius: 22px;
          background: Theme.accent;
          border-width: 2px;
          border-color: parent.has-focus ? #FFFFFF : transparent;

          Text {
            text: "P";
            color: #FFFFFF;
            font-family: Theme.font-body;
            font-size: 16px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
          }

          TouchArea {
            clicked => { AppState.navigate(6); }
          }
        }
      }

      Rectangle { width: 16px; }

      NavItem {
        label: "For You";
        icon-text: "";
        active: AppState.active-screen == 0;
        clicked => { AppState.navigate(0); }
      }
      NavItem {
        label: "Live";
        icon-text: "";
        active: AppState.active-screen == 1;
        clicked => { AppState.navigate(1); }
      }
      NavItem {
        label: "Movies";
        icon-text: "";
        active: AppState.active-screen == 3;
        clicked => { AppState.navigate(3); }
      }
      NavItem {
        label: "Shows";
        icon-text: "";
        active: AppState.active-screen == 4;
        clicked => { AppState.navigate(4); }
      }
      NavItem {
        label: "Library";
        icon-text: "";
        active: AppState.active-screen == 5 || AppState.active-screen == 6;
        clicked => { AppState.navigate(6); }
      }
    }

    // Right: Search pill
    FocusScope {
      width: 160px;
      height: 44px;

      key-pressed(event) => {
        if event.text == Key.Return || event.text == " " {
          AppState.navigate(5);
          return accept;
        }
        return reject;
      }

      Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.1);
        border-width: 2px;
        border-color: parent.has-focus ? #FFFFFF : rgba(255, 255, 255, 0.1);

        HorizontalLayout {
          padding-left: 16px;
          padding-right: 16px;
          spacing: 8px;
          alignment: center;

          Text {
            text: "🔍";
            font-size: 16px;
            vertical-alignment: center;
          }

          Text {
            text: "Search";
            color: rgba(255, 255, 255, 0.60);
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 500;
            vertical-alignment: center;
          }
        }

        TouchArea {
          clicked => { AppState.navigate(5); }
        }
      }
    }
  }
}
