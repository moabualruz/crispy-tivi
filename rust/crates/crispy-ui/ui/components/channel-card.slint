import { Theme } from "../globals/theme.slint";
import { AppState, ChannelData } from "../globals/app-state.slint";
import { IconStar, IconStarOutline, IconTv } from "icons.slint";

export component ChannelCard inherits FocusScope {
  in property <ChannelData> channel;

  callback clicked();

  height: 56px;
  width: 100%;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%;
    height: 100%;
    border-radius: Theme.radius-md;
    background: root.has-focus ? Theme.focus-bg : Theme.card-surface;
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.card-border;

    animate background { duration: 150ms; }
    animate border-color { duration: 150ms; }

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-md;

      // Channel number
      Text {
        text: channel.number > 0 ? channel.number : "";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        width: 32px;
        vertical-alignment: center;
        horizontal-alignment: center;
      }

      // Channel Logo
      Rectangle {
        width: 64px;
        height: 36px;
        border-radius: Theme.radius-sm;
        background: Theme.surface-glass;
        border-width: 1px;
        border-color: Theme.border-subtle;
        clip: true;

        // Loaded logo image
        if channel.logo.width > 0: Image {
          source: channel.logo;
          width: 100%;
          height: 100%;
          image-fit: contain;
        }

        // Fallback when no logo loaded
        if channel.logo.width == 0: VerticalLayout {
          alignment: center;
          if channel.number > 0: Text {
            text: channel.number;
            color: Theme.text-secondary;
            font-family: Theme.font-display;
            font-weight: 700;
            font-size: Theme.font-size-body;
            horizontal-alignment: center;
          }
          if channel.number <= 0: HorizontalLayout {
            alignment: center;
            IconTv {
              size: 20px;
              fill: Theme.text-secondary;
            }
          }
        }
      }

      // Channel info
      VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;
        spacing: Theme.spacing-2xs;

        Text {
          text: channel.name;
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-weight: 600;
          font-size: Theme.font-size-body;
          overflow: elide;
        }
        if channel.group != "": Text {
          text: channel.group;
          color: Theme.text-secondary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-small;
          overflow: elide;
        }
      }

      // Now playing text
      if channel.now-playing != "": Text {
        text: channel.now-playing;
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-small;
        vertical-alignment: center;
        overflow: elide;
        max-width: 200px;
      }

      // Quality badge
      if channel.resolution != "": Rectangle {
        width: res-lbl.preferred-width + 10px;
        height: 20px;
        border-radius: Theme.radius-xs;
        background: Theme.surface-glass;
        border-width: 1px;
        border-color: Theme.border-subtle;
        res-lbl := Text {
          text: channel.resolution;
          color: Theme.text-secondary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-small;
          font-weight: 700;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
      }

      // Catchup badge
      if channel.has-catchup: Rectangle {
        width: 26px; height: 20px;
        border-radius: Theme.radius-xs;
        background: Theme.brand-gradient;
        Text {
          text: "⏮";
          color: Theme.text-primary;
          font-size: Theme.font-size-micro;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
      }

      // Favorite star
      FocusScope {
        width: 32px;
        height: 32px;
        key-pressed(event) => {
          if event.text == Key.Return {
            AppState.toggle-favorite(channel.id);
            return accept;
          }
          return reject;
        }
        if channel.is-favorite: IconStar {
          size: 20px;
          fill: Theme.accent;
        }
        if !channel.is-favorite: IconStarOutline {
          size: 20px;
          fill: Theme.text-secondary;
        }
        TouchArea {
          clicked => { AppState.toggle-favorite(channel.id); }
        }
      }
    }

    TouchArea {
      clicked => { root.clicked(); }
    }
  }
}
