import { Theme } from "../globals/theme.slint";
import { AppState, ChannelData } from "../globals/app-state.slint";
import { IconStar, IconStarOutline } from "icons.slint";

export component ChannelCard inherits FocusScope {
  in property <ChannelData> channel;

  callback clicked();

  height: 56px;
  width: 100%;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.clicked();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%;
    height: 100%;
    border-radius: Theme.radius-md;
    background: root.has-focus ? rgba(255, 255, 255, 0.1) : Theme.card-surface;
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.card-border;

    animate background { duration: 150ms; }
    animate border-color { duration: 150ms; }

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-md;

      // Channel number
      Text {
        text: channel.number > 0 ? channel.number : "";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        width: 32px;
        vertical-alignment: center;
        horizontal-alignment: center;
      }

      // Channel Logo Placeholder
      Rectangle {
        width: 36px;
        height: 36px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.05);
        border-width: 1px;
        border-color: Theme.border-subtle;
        
        Text {
          text: channel.number > 0 ? channel.number : "";
          color: Theme.text-secondary;
          font-family: Theme.font-display;
          font-weight: 700;
          font-size: 16px;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
      }

      // Channel info
      VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;
        spacing: 2px;

        Text {
          text: channel.name;
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-weight: 600;
          font-size: Theme.font-size-body;
          overflow: elide;
        }
        if channel.group != "": Text {
          text: channel.group;
          color: Theme.text-secondary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-small;
          overflow: elide;
        }
      }

      // Now playing text
      if channel.now-playing != "": Text {
        text: channel.now-playing;
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-small;
        vertical-alignment: center;
        overflow: elide;
        max-width: 200px;
      }

      // Favorite star
      FocusScope {
        width: 32px;
        height: 32px;
        key-pressed(event) => {
          if event.text == Key.Return {
            AppState.toggle-favorite(channel.id);
            return accept;
          }
          return reject;
        }
        if channel.is-favorite: IconStar {
          size: 20px;
          fill: Theme.accent;
        }
        if !channel.is-favorite: IconStarOutline {
          size: 20px;
          fill: Theme.text-secondary;
        }
        TouchArea {
          clicked => { AppState.toggle-favorite(channel.id); }
        }
      }
    }

    TouchArea {
      clicked => { root.clicked(); }
    }
  }
}
