import { Theme } from "../globals/theme.slint";
import { IconSearch } from "icons.slint";

export component SearchBar inherits Rectangle {
  in-out property <string> text <=> input.text;
  in property <string> placeholder: "Search...";

  callback accepted(string);
  callback edited(string);

  width: 100%;
  height: 48px;
  border-radius: Theme.radius-md;
  background: focus-scope.has-focus ? rgba(255, 255, 255, 0.12) : Theme.card-surface;
  border-width: focus-scope.has-focus ? Theme.focus-ring-width : 1px;
  border-color: focus-scope.has-focus ? Theme.focus-ring : Theme.card-border;

  animate background { duration: 150ms; easing: ease-in-out; }
  animate border-color { duration: 150ms; easing: ease-in-out; }

  focus-scope := FocusScope {
    key-pressed(event) => {
      if event.text == Key.Return {
        root.accepted(input.text);
        return accept;
      }
      return reject;
    }

    HorizontalLayout {
      padding-left: Theme.spacing-lg;
      padding-right: Theme.spacing-lg;
      spacing: Theme.spacing-md;

      // Search icon
      VerticalLayout {
        alignment: center;
        IconSearch {
          width: 20px;
          height: 20px;
          fill: focus-scope.has-focus ? Theme.text-primary : Theme.text-secondary;
          animate fill { duration: 150ms; }
        }
      }

      Rectangle {
        horizontal-stretch: 1;
        input := TextInput {
          vertical-alignment: center;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          color: Theme.text-primary;
          single-line: true;

          edited => { root.edited(self.text); }
        }

        if input.text == "": Text {
          vertical-alignment: center;
          text: root.placeholder;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          color: Theme.text-secondary;
        }
      }
    }
  }

  forward-focus: focus-scope;

  TouchArea {
    clicked => { focus-scope.focus(); }
  }
}
