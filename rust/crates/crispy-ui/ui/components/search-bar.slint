import { Theme } from "../globals/theme.slint";
import { IconSearch } from "icons.slint";

export component SearchBar inherits Rectangle {
  in-out property <string> text <=> input.text;
  in property <string> placeholder: "Search...";

  callback accepted(string);
  callback edited(string);

  width: 100%;
  height: 48px;
  border-radius: Theme.radius-pill;
  background: focus-scope.has-focus ? rgba(255, 255, 255, 0.15) : Theme.card-surface;
  border-width: focus-scope.has-focus ? Theme.focus-ring-width : 2px;
  border-color: focus-scope.has-focus ? Theme.accent : Theme.card-border;

  animate background { duration: 150ms; easing: ease-in-out; }
  animate border-color { duration: 150ms; easing: ease-in-out; }

  focus-scope := FocusScope {
    key-pressed(event) => {
        if (event.text == Key.Return) {
            root.accepted(input.text);
            return accept;
        }
        return reject;
    }

    HorizontalLayout {
      padding-left: Theme.spacing-lg;
      padding-right: Theme.spacing-lg;
      spacing: Theme.spacing-md;

      // Search icon
      Rectangle {
        width: 24px;
        IconSearch {
          width: 24px;
          height: 24px;
          fill: focus-scope.has-focus ? Theme.accent : Theme.text-secondary;
          animate fill { duration: 150ms; }
        }
      }

      Rectangle {
        vertical-stretch: 1;
        input := TextInput {
          vertical-alignment: center;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          color: Theme.text-primary;
          single-line: true;

          edited => { root.edited(self.text); }
        }

        if (input.text == ""): Text {
          vertical-alignment: center;
          text: root.placeholder;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          color: rgba(255, 255, 255, 0.4);
        }
      }
    }
  }

  forward-focus: focus-scope;

  TouchArea {
    clicked => { focus-scope.focus(); }
  }
}
