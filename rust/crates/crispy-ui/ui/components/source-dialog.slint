import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { LineEdit, ComboBox } from "std-widgets.slint";
import { ActionButton } from "action-button.slint";
import { InputField } from "input-field.slint";
import { Dropdown } from "dropdown.slint";
export component SourceDialog inherits Rectangle {
  // Form state — properties bridge values out of conditional blocks
  in-out property <string> src-name: "";
  in-out property <int> src-type-idx: 0;
  in-out property <string> field-url: "";
  in-out property <string> field-user: "";
  in-out property <string> field-pass: "";

  visible: AppState.show-source-dialog;
  width: 100%;
  height: 100%;

  // Backdrop
  Rectangle {
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.7);
    TouchArea { clicked => { AppState.show-source-dialog = false; } }
  }

  // Dialog card — glassmorphic
  Rectangle {
    width: 460px;
    min-height: 360px;
    x: (parent.width - self.width) / 2;
    y: (parent.height - self.height) / 2;
    border-radius: 16px;
    background: rgba(28, 28, 32, 0.95);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);

    TouchArea {} // block click-through

    Flickable {
      VerticalLayout {
        padding: 28px;
        spacing: 20px;

        Text {
          text: "Add Source";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: 28px;
          font-weight: 700;
        }

        // Name (all types)
        InputField {
          label: "Source Name";
          placeholder-text: "My IPTV Provider";
          edited(v) => { root.src-name = v; }
        }

        // Type selector
        Dropdown {
          label: "Source Type";
          model: ["M3U / M3U8", "Xtream Codes", "Stalker Portal"];
          current-index <=> root.src-type-idx;
          selected => {
            root.field-url = "";
            root.field-user = "";
            root.field-pass = "";
          }
        }

        // ── M3U ──
        if root.src-type-idx == 0: InputField {
          label: "Playlist URL";
          placeholder-text: "http://example.com/playlist.m3u";
          edited(v) => { root.field-url = v; }
        }

        // ── Xtream Codes ──
        if root.src-type-idx == 1: InputField {
          label: "Server URL";
          placeholder-text: "http://provider.com:8080";
          edited(v) => { root.field-url = v; }
        }
        if root.src-type-idx == 1: InputField {
          label: "Username";
          placeholder-text: "username";
          edited(v) => { root.field-user = v; }
        }
        if root.src-type-idx == 1: InputField {
          label: "Password";
          placeholder-text: "password";
          input-type: password;
          edited(v) => { root.field-pass = v; }
        }

        // ── Stalker Portal ──
        if root.src-type-idx == 2: InputField {
          label: "Portal URL";
          placeholder-text: "http://portal.example.com/c/";
          edited(v) => { root.field-url = v; }
        }
        if root.src-type-idx == 2: InputField {
          label: "MAC Address";
          placeholder-text: "00:1A:79:XX:XX:XX";
          edited(v) => { root.field-user = v; }
        }

        // ── Actions ──
        HorizontalLayout {
          spacing: 12px;
          alignment: end;

          ActionButton {
            label: "Cancel";
            width: 100px;
            clicked => { AppState.show-source-dialog = false; }
          }

          ActionButton {
            label: "Add Source";
            is-primary: true;
            width: 120px;
            clicked => {
              AppState.save-source(
                root.src-name,
                root.src-type-idx == 0 ? "m3u" : root.src-type-idx == 1 ? "xtream" : "stalker",
                root.field-url, root.field-user, root.field-pass,
              );
              AppState.show-source-dialog = false;
            }
          }
        }
      }
    }
  }
}
