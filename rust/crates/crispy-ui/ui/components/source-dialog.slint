import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { LineEdit, ComboBox } from "std-widgets.slint";

export component SourceDialog inherits Rectangle {
  // Form state — properties bridge values out of conditional blocks
  in-out property <string> src-name: "";
  in-out property <int> src-type-idx: 0;
  in-out property <string> field-url: "";
  in-out property <string> field-user: "";
  in-out property <string> field-pass: "";

  visible: AppState.show-source-dialog;
  width: 100%;
  height: 100%;

  // Backdrop
  Rectangle {
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.7);
    TouchArea { clicked => { AppState.show-source-dialog = false; } }
  }

  // Dialog card — glassmorphic
  Rectangle {
    width: 460px;
    min-height: 360px;
    x: (parent.width - self.width) / 2;
    y: (parent.height - self.height) / 2;
    border-radius: 16px;
    background: rgba(28, 28, 32, 0.95);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);

    TouchArea {} // block click-through

    Flickable {
      VerticalLayout {
        padding: 28px;
        spacing: 20px;

        Text {
          text: "Add Source";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: 28px;
          font-weight: 700;
        }

        // Name (all types)
        VerticalLayout {
          spacing: 6px;
          Text { text: "Source Name"; color: Theme.text-secondary; font-size: 13px; }
          LineEdit {
            placeholder-text: "My IPTV Provider";
            edited => { root.src-name = self.text; }
          }
        }

        // Type selector
        VerticalLayout {
          spacing: 6px;
          Text { text: "Source Type"; color: Theme.text-secondary; font-size: 13px; }
          ComboBox {
            model: ["M3U / M3U8", "Xtream Codes", "Stalker Portal"];
            current-index <=> root.src-type-idx;
            selected => {
              root.field-url = "";
              root.field-user = "";
              root.field-pass = "";
            }
          }
        }

        // ── M3U ──
        if root.src-type-idx == 0: VerticalLayout {
          spacing: 6px;
          Text { text: "Playlist URL"; color: Theme.text-secondary; font-size: 13px; }
          LineEdit {
            placeholder-text: "http://example.com/playlist.m3u";
            edited => { root.field-url = self.text; }
          }
        }

        // ── Xtream Codes ──
        if root.src-type-idx == 1: VerticalLayout {
          spacing: 6px;
          Text { text: "Server URL"; color: Theme.text-secondary; font-size: 13px; }
          LineEdit {
            placeholder-text: "http://provider.com:8080";
            edited => { root.field-url = self.text; }
          }
        }
        if root.src-type-idx == 1: VerticalLayout {
          spacing: 6px;
          Text { text: "Username"; color: Theme.text-secondary; font-size: 13px; }
          LineEdit {
            placeholder-text: "username";
            edited => { root.field-user = self.text; }
          }
        }
        if root.src-type-idx == 1: VerticalLayout {
          spacing: 6px;
          Text { text: "Password"; color: Theme.text-secondary; font-size: 13px; }
          LineEdit {
            placeholder-text: "password";
            input-type: password;
            edited => { root.field-pass = self.text; }
          }
        }

        // ── Stalker Portal ──
        if root.src-type-idx == 2: VerticalLayout {
          spacing: 6px;
          Text { text: "Portal URL"; color: Theme.text-secondary; font-size: 13px; }
          LineEdit {
            placeholder-text: "http://portal.example.com/c/";
            edited => { root.field-url = self.text; }
          }
        }
        if root.src-type-idx == 2: VerticalLayout {
          spacing: 6px;
          Text { text: "MAC Address"; color: Theme.text-secondary; font-size: 13px; }
          LineEdit {
            placeholder-text: "00:1A:79:XX:XX:XX";
            edited => { root.field-user = self.text; }
          }
        }

        // ── Actions ──
        HorizontalLayout {
          spacing: 12px;
          alignment: end;

          // Cancel
          FocusScope {
            width: 100px;
            height: 44px;
            key-pressed(event) => {
              if event.text == Key.Return || event.text == Key.Escape {
                AppState.show-source-dialog = false;
                return accept;
              }
              return reject;
            }
            Rectangle {
              width: 100%; height: 100%;
              border-radius: 8px;
              background: rgba(255, 255, 255, 0.1);
              border-width: parent.has-focus ? 2px : 1px;
              border-color: parent.has-focus ? #FFFFFF : rgba(255, 255, 255, 0.1);
              Text {
                text: "Cancel";
                color: Theme.text-primary;
                font-family: Theme.font-display;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
              TouchArea { clicked => { AppState.show-source-dialog = false; } }
            }
          }

          // Save
          FocusScope {
            width: 120px;
            height: 44px;
            key-pressed(event) => {
              if event.text == Key.Return {
                AppState.save-source(
                  root.src-name,
                  root.src-type-idx == 0 ? "m3u" : root.src-type-idx == 1 ? "xtream" : "stalker",
                  root.field-url, root.field-user, root.field-pass,
                );
                AppState.show-source-dialog = false;
                return accept;
              }
              return reject;
            }
            Rectangle {
              width: 100%; height: 100%;
              border-radius: 8px;
              background: #FFFFFF;
              border-width: parent.has-focus ? 2px : 0px;
              border-color: Theme.accent;
              Text {
                text: "Add Source";
                color: #000000;
                font-family: Theme.font-display;
                font-size: 15px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
              TouchArea {
                clicked => {
                  AppState.save-source(
                    root.src-name,
                    root.src-type-idx == 0 ? "m3u" : root.src-type-idx == 1 ? "xtream" : "stalker",
                    root.field-url, root.field-user, root.field-pass,
                  );
                  AppState.show-source-dialog = false;
                }
              }
            }
          }
        }
      }
    }
  }
}
