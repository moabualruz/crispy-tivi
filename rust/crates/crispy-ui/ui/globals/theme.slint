// Design system tokens — "Cinematic Utility"
// Reference: .ai/crispy_tivi_design_spec.md

export global Theme {
  // --- Mode ---
  // 0 = System, 1 = Dark, 2 = Light
  in-out property <int> theme-mode: 1;

  // Resolved dark flag (System resolves to dark by default; Rust overrides based on OS)
  out property <bool> is-dark: theme-mode == 2 ? false : true;

  // --- Surface Colors ---
  out property <brush> background: is-dark
    ? #0A0A0C
    : #F5F5F7;
  out property <brush> surface: is-dark
    ? rgba(28, 28, 32, 0.8)
    : rgba(245, 245, 247, 0.9);
  out property <brush> surface-glass: is-dark
    ? rgba(10, 10, 12, 0.65)
    : rgba(255, 255, 255, 0.75);

  // --- Text Colors ---
  out property <brush> text-primary: is-dark
    ? rgba(255, 255, 255, 0.95)
    : rgba(10, 10, 12, 0.95);
  out property <brush> text-secondary: is-dark
    ? rgba(255, 255, 255, 0.60)
    : rgba(10, 10, 12, 0.55);

  // --- Accent ---
  out property <brush> accent: #E2E8F0;
  out property <brush> accent-gradient: @linear-gradient(135deg, #FFFFFF 0%, #94A3B8 100%);

  // --- Borders ---
  out property <brush> border-subtle: is-dark
    ? rgba(255, 255, 255, 0.1)
    : rgba(0, 0, 0, 0.08);

  // --- Focus (D-Pad first — stark white focus ring) ---
  out property <brush> focus-bg: rgba(255, 255, 255, 0.1);
  out property <brush> focus-ring: #FFFFFF;
  out property <length> focus-ring-width: 2px;
  out property <brush> focus-glow: rgba(255, 255, 255, 0.2);

  // --- Card Surface (glassmorphic) ---
  out property <brush> card-surface: is-dark
    ? rgba(28, 28, 32, 0.8)
    : rgba(245, 245, 247, 0.9);
  out property <brush> card-border: rgba(255, 255, 255, 0.1);

  // --- Button Styles ---
  out property <brush> btn-primary-bg: #FFFFFF;
  out property <brush> btn-primary-fg: #000000;
  out property <brush> btn-secondary-bg: rgba(255, 255, 255, 0.15);
  out property <brush> btn-secondary-fg: #FFFFFF;

  // --- Brand Accent Gradient (Crispy Orange/Red) ---
  // Used ONLY for progress bars, live badges, and catchup indicators
  out property <brush> brand-gradient: @linear-gradient(135deg, #FF4B2B 0%, #FF416C 100%);

  // --- Progress Bar Colors ---
  out property <brush> progress-buffered: rgba(255, 255, 255, 0.4);      // VOD buffered-ahead track
  out property <brush> progress-live-buffered: rgba(255, 255, 255, 0.55); // Live buffered track (brighter)

  // --- Live Badge ---
  out property <brush> live-badge: #EF4444; // Keep purely red for standard "live" semantics

  // --- Overlay / Scrim ---
  out property <brush> overlay: rgba(0, 0, 0, 0.5);         // standard modal scrim
  out property <brush> overlay-heavy: rgba(0, 0, 0, 0.8);   // full-screen cover (profile picker, etc.)
  out property <brush> overlay-dark: rgba(0, 0, 0, 0.75);   // icon badge backing, lock overlays

  // --- Extended Surface ---
  out property <brush> surface-highlight: rgba(255, 255, 255, 0.08); // subtle hover/inactive surface

  // --- Extended Text ---
  out property <brush> text-disabled: rgba(255, 255, 255, 0.3); // placeholder / disabled state

  // --- Status Indicators ---
  out property <brush> status-success: #16A34A;              // green-600
  out property <brush> status-warning: #CA8A04;              // amber-600
  out property <brush> status-error: #EF4444;                // red-500 (same as live-badge for consistency)
  out property <brush> status-error-bg: rgba(239, 68, 68, 0.15);      // red-500 at 15% — error state bg
  out property <brush> status-error-border: rgba(239, 68, 68, 0.4);   // red-500 at 40% — error state border
  out property <brush> status-success-text: rgba(134, 239, 172, 1.0); // green-300 — bright text on dark bg
  out property <brush> status-success-bg: rgba(34, 197, 94, 0.15);    // green-500 at 15% — done state bg
  out property <brush> status-success-border: rgba(34, 197, 94, 0.4); // green-500 at 40% — done state border
  // --- EPG Category Backgrounds ---
  out property <brush> epg-sports-bg: rgba(37, 99, 235, 0.18);   // blue-700 tint
  out property <brush> epg-movies-bg: rgba(109, 40, 217, 0.18);  // violet-700 tint
  out property <brush> epg-news-bg: rgba(220, 38, 38, 0.18);     // red-600 tint

  // --- Typography ---
  // Fallback chains cover Arabic (Noto Sans Arabic) and CJK (Noto Sans CJK SC)
  out property <string> font-display: "Outfit, Noto Sans Arabic, Noto Sans CJK SC";
  out property <string> font-body: "Inter, Noto Sans Arabic, Noto Sans CJK SC";
  out property <length> font-size-hero: 64px;
  out property <length> font-size-h1: 32px;
  out property <length> font-size-h2: 24px;
  out property <length> font-size-subtitle: 18px; // between h2 and body
  out property <length> font-size-body: 16px;
  out property <length> font-size-caption: 14px;
  out property <length> font-size-small: 12px;
  out property <length> font-size-micro: 10px;
  out property <length> font-size-nano: 9px;   // EPG badge labels (NOW, CATCHUP)

  // --- Spacing ---
  out property <length> spacing-2xs: 2px;
  out property <length> spacing-xs: 4px;
  out property <length> spacing-sm: 8px;
  // Note: design spec uses xs=4, sm=8, md=16, lg=24, xl=32, 2xl=48
  out property <length> spacing-md: 16px;
  out property <length> spacing-ml: 20px;
  out property <length> spacing-lg: 24px;
  out property <length> spacing-xl: 32px;
  out property <length> spacing-2xl: 48px;

  // --- Radii ---
  out property <length> radius-2xs: 2px;  // progress bar ends, micro indicators
  out property <length> radius-xs: 4px;
  out property <length> radius-sm: 8px;
  out property <length> radius-md: 12px;
  out property <length> radius-lg: 16px;
  out property <length> radius-nav: 20px; // nav pill items (design spec: border-radius 20px)
  out property <length> radius-pill: 8px;  // same as radius-sm — standard rounded corners, no pill shapes

  // --- Layout Constants ---
  out property <length> filter-chip-height: 48px;
  out property <length> vod-card-width: 176px;
  out property <length> scroll-load-threshold: 500px;
  out property <length> button-legend-clearance: 40px;
  out property <length> progress-bar-height: 3px;

  // --- Top Navigation Bar ---
  out property <length> top-nav-height: 72px;
  out property <length> screen-padding-top: 80px; // clearance below top nav
  out property <length> content-padding-h: 64px; // horizontal content padding (design spec: ~5% of 1280px reference)
}
