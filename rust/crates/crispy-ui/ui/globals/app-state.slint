// Data structures for Slint UI models

// Multi-source badge — one entry per IPTV source that carries this content.
export struct SourceBadge {
  source-name: string,
  quality-label: string,  // "4K", "1080p", "720p", "SD", ""
  is-preferred: bool,
}

export struct SourceData {
  id: string,
  name: string,
  source-type: string,
  url: string,
  username: string,
  password: string,
  channel-count: int,
  vod-count: int,
  sync-status: string,
}

export struct ChannelData {
  id: string,
  name: string,
  group: string,
  logo-url: string,
  stream-url: string,
  source-id: string,
  number: int,
  is-favorite: bool,
  has-catchup: bool,
  resolution: string,
  now-playing: string,
  logo: image,
}

export struct VodData {
  id: string,
  name: string,
  stream-url: string,
  item-type: string,
  poster-url: string,
  backdrop-url: string,
  description: string,
  genre: string,
  year: string,
  rating: string,
  duration-minutes: int,
  is-favorite: bool,
  source-id: string,
  series-id: string,
  season: int,
  episode: int,
  poster: image,
}

export struct EpgData {
  channel-id: string,
  channel-name: string,
  channel-logo: image,
  title: string,
  start-hour: int,
  start-minute: int,
  end-hour: int,
  end-minute: int,
  duration-minutes: int,
  progress-percent: float,
  description: string,
  category: string,
  has-catchup: bool,
  is-now: bool,
}

export struct EpgChannelRow {
  channel-id: string,
  channel-name: string,
  channel-logo: image,
  programmes: [EpgData],
}

export struct ProfileData {
  id: string,
  name: string,
  avatar-color: brush,
  is-kids: bool,
  is-active: bool,
  pin-protected: bool,
}

export struct HeroItem {
  id: string,
  title: string,
  subtitle: string,
  backdrop: image,
  content-type: string,
  is-live: bool,
}

export struct CategoryData {
  name: string,
  category-type: string,
}

// ── Casting structs (Epoch 10) ──
export struct CastDeviceData {
  id: string,
  name: string,
  // "cast" | "airplay" | "dlna"
  device-type: string,
  // "disconnected" | "connecting" | "connected"
  status: string,
}

export struct ManagedDeviceData {
  id: string,
  name: string,
  // "cast" | "airplay" | "dlna" | "remote"
  device-type: string,
  last-active: string,
}

export global AppState {
  // Current active screen index
  // 0=Home, 1=LiveTV, 2=EPG, 3=Movies, 4=Series, 5=Search, 6=Library, 7=Settings
  // 8=VodDetail, 9=SeriesDetail
  in-out property <int> active-screen: 0;

  // VOD detail screen data — multi-source awareness (Epoch 5.12)
  in-out property <[SourceBadge]> vod-detail-sources: [];
  in-out property <bool> vod-detail-has-multi-source: false;

  in-out property <bool> show-vod-detail: false;
  in-out property <VodData> vod-detail-item: {
    id: "", name: "", stream-url: "", item-type: "movie",
    poster-url: "", backdrop-url: "", description: "", genre: "",
    year: "", rating: "", duration-minutes: 0, is-favorite: false,
    source-id: "", series-id: "", season: 0, episode: 0,
    poster: @image-url(""),
  };

  // Series detail screen data
  in-out property <bool> show-series-detail: false;
  in-out property <VodData> series-detail-item: {
    id: "", name: "", stream-url: "", item-type: "series",
    poster-url: "", backdrop-url: "", description: "", genre: "",
    year: "", rating: "", duration-minutes: 0, is-favorite: false,
    source-id: "", series-id: "", season: 0, episode: 0,
    poster: @image-url(""),
  };
  in-out property <[VodData]> series-episodes: [];
  in-out property <int> series-active-season: 1;

  // EPG state
  in-out property <int> epg-selected-date-offset: 0;
  in-out property <string> epg-jump-channel-id: "";
  in-out property <[EpgChannelRow]> epg-rows: [];
  in-out property <string> epg-date-label: "Today";
  in-out property <int> epg-now-hour: 12;
  in-out property <int> epg-now-minute: 0;

  // EPG program detail sheet
  in-out property <bool> show-epg-detail: false;
  in-out property <string> epg-detail-program-id: "";
  in-out property <string> epg-detail-channel-id: "";
  in-out property <string> epg-detail-channel-name: "";
  in-out property <string> epg-detail-title: "";
  in-out property <string> epg-detail-description: "";
  in-out property <string> epg-detail-start: "";
  in-out property <string> epg-detail-end: "";
  in-out property <string> epg-detail-category: "";
  in-out property <bool>   epg-detail-has-catchup: false;
  in-out property <bool>   epg-detail-is-now: false;

  // Hero state (home screen)
  in-out property <[HeroItem]> hero-items: [];
  in-out property <int> hero-index: 0;

  // Profile state
  in-out property <[ProfileData]> profiles: [];
  in-out property <string> active-profile-name: "Default";
  in-out property <bool> show-profile-menu: false;
  in-out property <bool> show-profile-picker: false;

  // PIN dialog — shown when switching to a PIN-protected profile
  in-out property <bool>   show-pin-dialog: false;
  in-out property <string> pin-target-profile-id: "";
  in-out property <string> pin-target-profile-name: "";
  // Set by Rust to true when an incorrect PIN is entered; reset to false after shake
  in-out property <bool>   pin-wrong: false;

  // Channel overlay (Live TV glass sidebar)
  in-out property <bool> show-channel-overlay: false;

  // Navigation state
  in-out property <bool> nav-visible: true;

  // Localization
  in-out property <string> active-language: "en";
  in-out property <bool> is-rtl: false;

  // ── Loading states (async pipeline) ──
  in-out property <bool> is-loading-channels: false;
  in-out property <bool> is-loading-vod: false;
  in-out property <bool> is-searching: false;
  in-out property <int> total-channel-count: 0;   // total available in DB
  in-out property <int> total-movie-count: 0;
  in-out property <int> total-series-count: 0;

  // Source data
  in-out property <[SourceData]> sources: [];

  // Channel data (WindowedModel — virtual scroll)
  in-out property <[ChannelData]> channels: [];
  in-out property <[string]> channel-groups: [];
  in-out property <string> active-channel-group: "";
  in-out property <string> channel-search-text: "";

  // Home screen preview lanes (small fixed slices, not the full model)
  in-out property <[ChannelData]> home-channels: [];
  in-out property <[VodData]> home-movies: [];
  in-out property <[VodData]> home-series: [];

  // VOD data (WindowedModel — virtual scroll)
  in-out property <[VodData]> movies: [];
  in-out property <[VodData]> series: [];
  in-out property <[CategoryData]> vod-categories: [];
  in-out property <string> active-vod-category: "";

  // Search
  in-out property <string> search-text: "";
  in-out property <[ChannelData]> search-channels: [];
  in-out property <[VodData]> search-vod: [];

  // Sync state
  in-out property <bool> is-syncing: false;
  in-out property <float> sync-progress: 0.0;
  in-out property <string> sync-message: "";

  // ── Network / offline state (Epoch 8) ──
  // Set by Rust when connectivity changes. 0 = online, 1 = device offline,
  // 2 = internet unreachable, 3 = source down.
  in-out property <int> network-status: 0;
  in-out property <bool> is-offline: false;

  // ── EPG staleness (Epoch 8) ──
  // Hours since the EPG data was last successfully refreshed.
  // When > 24 the UI shows a staleness indicator.
  in-out property <int> epg-last-updated-hours: 0;

  // ── Parental controls (Epoch 7) ──
  in-out property <bool> parental-pin-set: false;
  // Unified rating limit index (0–6 matching the 7-tier scale). -1 = no limit.
  in-out property <int> parental-rating-limit: -1;
  // Daily viewing time limit in minutes. 0 = no limit.
  in-out property <int> parental-time-limit-minutes: 0;

  // ── Analytics consent (Epoch 11) ──
  in-out property <bool> analytics-playback-consent: false;
  in-out property <bool> analytics-crash-consent: false;

  // Source dialog state
  in-out property <bool> show-source-dialog: false;
  in-out property <SourceData> editing-source: {
    id: "", name: "", source-type: "m3u", url: "",
    username: "", password: "", channel-count: 0,
    vod-count: 0, sync-status: ""
  };

  // ── Callbacks to Rust ──
  callback navigate(/* screen-index */ int);
  callback set-theme(/* theme-mode */ int);
  callback set-language(/* lang-code */ string);

  // Source management
  callback save-source(/* name */ string, /* type */ string, /* url */ string, /* user */ string, /* pass */ string);
  callback edit-source(/* source-id */ string);
  callback delete-source(/* source-id */ string);
  callback sync-source(/* source-id */ string);
  callback sync-all();

  // Channel operations
  callback toggle-favorite(/* channel-id */ string);
  callback filter-channels(/* group */ string, /* search */ string);
  callback play-channel(/* channel-id */ string);
  // Switch back to the previously watched live channel (J-06 previous-channel toggle).
  callback previous-channel();

  // Settings — playback preferences
  callback set-video-quality(/* label: "Auto"|"1080p"|"720p"|"480p" */ string);
  callback set-audio-language(/* lang-code: "auto"|"en"|"ar"|"de"|"fr" */ string);
  callback set-audio-passthrough(/* enabled */ bool);
  callback set-autoplay-next(/* enabled */ bool);
  callback set-subtitle-language(/* lang-code: "off"|"en"|"ar"|"de"|"fr" */ string);
  callback set-startup-screen(/* label */ string);
  callback open-player-settings();

  // VOD operations (filter-vod is driven internally by category chip callbacks in vod screens)
  callback play-vod(/* vod-id */ string);
  callback open-vod-detail(/* vod-id */ string);
  callback toggle-vod-favorite(/* vod-id */ string);

  // Series operations
  callback open-series-detail(/* series-id */ string);
  callback select-series-season(/* season */ int);
  callback play-episode(/* series-id */ string, /* season */ int, /* episode */ int);

  // EPG operations
  callback select-epg-date(/* offset-days */ int);
  callback jump-epg-to-channel(/* channel-id */ string);
  callback watch-program(/* program-id */ string);
  callback catch-up-program(/* program-id */ string);
  callback remind-program(/* program-id */ string);

  // Search (debounced in Rust — UI fires immediately)
  callback perform-search(/* query */ string);

  // Profile operations
  callback switch-profile(/* profile-id */ string);
  callback create-profile(/* name */ string, /* is-kids */ bool);
  // Verify PIN entered in PinDialog; Rust checks hash and either proceeds with switch or sets pin-wrong
  callback verify-pin(/* entered-pin */ string);

  // Hero operations
  callback hero-play(/* item-id */ string);
  callback hero-detail(/* item-id */ string);

  // Parental controls (Epoch 7)
  callback set-parental-pin(/* new-pin */ string);
  callback clear-parental-pin();
  callback set-content-rating(/* rating-index */ int);
  callback set-viewing-time-limit(/* minutes */ int);

  // Analytics consent (Epoch 11)
  callback set-analytics-playback(/* enabled */ bool);
  callback set-analytics-crash(/* enabled */ bool);

  // Backup / restore (Epoch 13)
  callback export-backup();
  callback import-backup();

  // ── Privacy consent (Epoch 13.15) ──
  // Shown on first launch after onboarding. User must accept to use the app.
  in-out property <bool> show-privacy-consent: false;
  in-out property <bool> privacy-accepted: false;
  callback accept-privacy();
  callback decline-privacy();

  // ── Open source attribution (Epoch 13.14) ──
  in-out property <bool> show-attribution: false;

  // ── Guided tour (Epoch 13.1) ──
  in-out property <bool> show-guided-tour: false;
  in-out property <int> guided-tour-step: 0;
  callback skip-guided-tour();
  callback advance-guided-tour();

  // ── Getting started checklist (Epoch 13.7) ──
  // Each bool tracks completion of a setup step.
  in-out property <bool> getting-started-dismissed: false;
  in-out property <bool> gs-source-added: false;
  in-out property <bool> gs-browsed-channels: false;
  in-out property <bool> gs-played-channel: false;
  in-out property <bool> gs-profile-set: false;
  callback dismiss-getting-started();

  // ── Virtual scroll — D-pad focus tracking ──
  callback scroll-channels(/* delta: +1 down, -1 up */ int);
  callback scroll-movies(/* delta */ int);
  callback scroll-series(/* delta */ int);
  in-out property <int> channel-focus-index: 0;
  in-out property <int> movie-focus-index: 0;
  in-out property <int> series-focus-index: 0;
  in-out property <int> channel-window-start: 0;
  in-out property <int> movie-window-start: 0;
  in-out property <int> series-window-start: 0;

  // ── Casting & multi-device (Epoch 10) ──

  // 10.6: Cast picker
  in-out property <bool> show-cast-picker: false;
  // Populated by Rust device-discovery service before showing the picker.
  in-out property <[CastDeviceData]> cast-devices: [];
  callback cast-to-device(/* device-id */ string);
  callback stop-casting();

  // 10.7: Device management (shown in Settings)
  in-out property <[ManagedDeviceData]> managed-devices: [];
  callback remove-device(/* device-id */ string);
  callback sign-out-all-devices();

  // 10.9: Cross-device resume prompt
  in-out property <bool> show-resume-prompt: false;
  // Human-readable label for the device that left the watch position, e.g. "Living Room TV"
  in-out property <string> resume-source-device: "";
  // Human-readable position label, e.g. "1h 23m"
  in-out property <string> resume-position-label: "";
  callback resume-playback();
  callback start-over-playback();
}
