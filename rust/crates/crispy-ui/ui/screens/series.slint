import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { EmptyState } from "../components/empty-state.slint";
import { VodCard } from "../components/vod-card.slint";
import { LoadingIndicator } from "../components/loading-indicator.slint";
import { IconTv } from "../components/icons.slint";
import { FilterChip } from "../components/filter-chip.slint";
import { ScrollView } from "std-widgets.slint";

export component SeriesScreen inherits Rectangle {
  background: transparent;

  // M-036: Escape navigates back to Home (screen 0)
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.Escape {
        AppState.navigate(0);
        return accept;
      }
      return reject;
    }
  }

  if AppState.is-loading-vod && AppState.series.length == 0: LoadingIndicator {
    message: "Loading series...";
  }

  if !AppState.is-loading-vod && AppState.series.length == 0: EmptyState {
    title: "No Series";
    subtitle: "TV series from your sources will appear here.";
    cta-text: "Add Source";
    cta-clicked => {
      AppState.active-screen = 0;
      AppState.navigate(0);
    }
    IconTv { size: 32px; fill: Theme.text-secondary; }
  }

  if AppState.series.length > 0: VerticalLayout {
    padding-top: Theme.screen-padding-top;
    padding-left: Theme.content-padding-h;
    padding-right: Theme.content-padding-h;
    padding-bottom: Theme.spacing-lg;
    spacing: Theme.spacing-md;

    Text {
      text: "Series";
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-h1;
      font-weight: 700;
    }

    // Category filter chips
    if AppState.vod-categories.length > 0: Rectangle {
      height: Theme.filter-chip-height;
      clip: true;
      HorizontalLayout {
        padding-top: Theme.spacing-xs;
        padding-bottom: Theme.spacing-xs;
        spacing: Theme.spacing-sm;

        FilterChip {
          label: "All";
          active: AppState.active-vod-category == "";
          activated => {
            AppState.active-vod-category = "";
            AppState.filter-vod-category("");
          }
        }

        for cat in AppState.vod-categories: FilterChip {
          label: cat.name;
          active: AppState.active-vod-category == cat.name;
          activated => {
            AppState.active-vod-category = cat.name;
            AppState.filter-vod-category(cat.name);
          }
        }
      }
    }

    ScrollView {
      vertical-stretch: 1;

      scrolled() => {
        if self.viewport-height > 0px
          && (-self.viewport-y + self.visible-height > self.viewport-height - Theme.scroll-load-threshold) {
          AppState.scroll-series(45);
        }
        if self.viewport-y < 0px
          && (-self.viewport-y < Theme.scroll-load-threshold)
          && AppState.series-window-start > 0 {
          AppState.scroll-series(-45);
        }
      }

      VerticalLayout {
        spacing: Theme.spacing-md;

        property <int> columns: max(2, floor((root.width - Theme.content-padding-h * 2 + Theme.spacing-md) / Theme.vod-card-width));

        GridLayout {
          spacing: Theme.spacing-md;

          for show[idx] in AppState.series: VodCard {
            row: floor(idx / columns);
            col: mod(idx, columns);
            item: show;
            clicked => { AppState.open-series-detail(show.id); }
          }
        }
      }
    }
  }
}
