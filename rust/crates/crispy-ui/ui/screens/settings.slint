import { Theme } from "../globals/theme.slint";
import { AppState, SourceData } from "../globals/app-state.slint";
import { ScrollView } from "std-widgets.slint";
import { ActionButton } from "../components/action-button.slint";
import { FilterChip } from "../components/filter-chip.slint";
import { InputField } from "../components/input-field.slint";

component SourceRow inherits FocusScope {
  in property <SourceData> source;

  height: 64px;
  width: 100%;

  key-pressed(event) => {
    if event.text == Key.Delete {
      AppState.delete-source(source.id);
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-sm;
    background: root.has-focus ? rgba(255, 255, 255, 0.08) : transparent;
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-md;

      // Type badge
      VerticalLayout {
        alignment: center;
        Rectangle {
          width: 48px;
          height: 28px;
          border-radius: Theme.radius-sm;
          background: Theme.card-surface;
          border-width: 1px;
          border-color: Theme.card-border;

          Text {
            text: source.source-type == "m3u" ? "M3U"
              : source.source-type == "xtream" ? "XC"
              : source.source-type == "stalker" ? "STK"
              : source.source-type;
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }
      }

      // Source info
      VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;
        spacing: 2px;

        Text {
          text: source.name != "" ? source.name : source.url;
          color: Theme.text-primary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          overflow: elide;
        }
        HorizontalLayout {
          spacing: Theme.spacing-sm;
          Text {
            text: source.channel-count + " channels";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
          }
          Text {
            text: "·";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
          Text {
            text: source.vod-count + " VOD";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
          }
        }
      }

      // Actions
      HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: end;

        ActionButton {
          label: "Sync";
          width: 72px;
          height: 32px;
          clicked => { AppState.sync-source(source.id); }
        }

        ActionButton {
          label: "Delete";
          width: 72px;
          height: 32px;
          clicked => { AppState.delete-source(source.id); }
        }
      }
    }
  }
}

// Glass card — reusable section container
component SettingsCard inherits Rectangle {
  border-radius: Theme.radius-md;
  background: Theme.card-surface;
  border-width: 1px;
  border-color: Theme.card-border;
}

export component SettingsScreen inherits Rectangle {
  background: transparent;

  // Local search filter — hides sections that don't match
  property <string> settings-search: "";

  ScrollView {
    width: 100%; height: 100%;

    VerticalLayout {
      padding-top: Theme.screen-padding-top;
      padding-left: Theme.content-padding-h;
      padding-right: Theme.content-padding-h;
      padding-bottom: Theme.spacing-2xl;
      spacing: Theme.spacing-lg;

      // Header
      HorizontalLayout {
        spacing: Theme.spacing-md;
        alignment: space-between;

        Text {
          text: "Settings";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: Theme.font-size-h1;
          font-weight: 700;
          vertical-alignment: center;
          horizontal-stretch: 1;
        }

        // Back button
        VerticalLayout {
          alignment: center;
          back-btn := FocusScope {
            width: 36px;
            height: 36px;
            key-pressed(event) => {
              if event.text == Key.Return || event.text == Key.Escape {
                AppState.active-screen = 0;
                AppState.navigate(0);
                return accept;
              }
              return reject;
            }
            Rectangle {
              width: 100%; height: 100%;
              border-radius: 18px;
              background: back-btn.has-focus ? Theme.surface-glass : Theme.card-surface;
              border-width: 1px;
              border-color: back-ta.has-hover ? Theme.text-secondary : Theme.card-border;

              Text {
                text: "✕";
                color: back-ta.has-hover ? Theme.text-primary : Theme.text-secondary;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
              }

              back-ta := TouchArea {
                clicked => {
                  AppState.active-screen = 0;
                  AppState.navigate(0);
                }
              }
            }
          }
        }
      }

      // ── Keyword search ──
      InputField {
        label: "";
        placeholder-text: "Search settings...";
        edited(v) => { root.settings-search = v; }
      }

      // ── Playback Section ──
      // Note: keyword search filters are applied in Rust; all sections always rendered in Slint
      SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Playback";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Hardware decode info
          HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
              horizontal-stretch: 1;
              spacing: 2px;
              Text {
                text: "Hardware Decode";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Uses GPU decode (hwdec=auto-safe) with automatic CPU fallback.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }
            Rectangle {
              width: hw-lbl.preferred-width + Theme.spacing-md;
              height: 28px;
              border-radius: Theme.radius-sm;
              background: Theme.card-surface;
              border-width: 1px;
              border-color: Theme.card-border;
              hw-lbl := Text {
                text: "AUTO";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-small;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
            }
          }

          // Video renderer info
          HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
              horizontal-stretch: 1;
              spacing: 2px;
              Text {
                text: "Video Renderer";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "libplacebo Vulkan renderer (vo=gpu-next) with ewa_lanczossharp upscaling.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }
            Rectangle {
              width: vr-lbl.preferred-width + Theme.spacing-md;
              height: 28px;
              border-radius: Theme.radius-sm;
              background: Theme.card-surface;
              border-width: 1px;
              border-color: Theme.card-border;
              vr-lbl := Text {
                text: "GPU";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-small;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
            }
          }
        }
      }

      // ── EPG Section ──
      SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Programme Guide (EPG)";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Refresh EPG data manually or configure auto-refresh via your source settings.";
              color: Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-caption;
              wrap: word-wrap;
              horizontal-stretch: 1;
            }
            ActionButton {
              label: "Refresh EPG";
              height: 36px;
              clicked => { AppState.sync-all(); }
            }
          }
        }
      }

      // ── Sources Section ──
      SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          HorizontalLayout {
            Text {
              text: "Sources & Library";
              color: Theme.text-primary;
              font-family: Theme.font-display;
              font-size: Theme.font-size-h2;
              font-weight: 700;
              horizontal-stretch: 1;
              vertical-alignment: center;
            }
            ActionButton {
              label: "+ Add Source";
              height: 36px;
              is-primary: true;
              clicked => { AppState.show-source-dialog = true; }
            }
          }

          if AppState.sources.length == 0: Text {
            text: "No sources configured. Add an IPTV source or media server to get started.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          for src in AppState.sources: SourceRow {
            source: src;
          }
        }
      }

      // ── Appearance Section ──
      SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-lg;

          Text {
            text: "Appearance";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Theme selector
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Theme";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for item in [
                { label: "System", mode: 0 },
                { label: "Dark", mode: 1 },
                { label: "Light", mode: 2 },
              ]: FilterChip {
                label: item.label;
                active: Theme.theme-mode == item.mode;
                activated => {
                  Theme.theme-mode = item.mode;
                  AppState.set-theme(item.mode);
                }
              }
            }
          }

          // Language selector
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Language";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for lang in [
                { code: "en", label: "English" },
                { code: "ar", label: "العربية" },
                { code: "de", label: "Deutsch" },
                { code: "fr", label: "Français" },
                { code: "es", label: "Español" },
              ]: FilterChip {
                label: lang.label;
                active: AppState.active-language == lang.code;
                activated => {
                  AppState.set-language(lang.code);
                  AppState.active-language = lang.code;
                }
              }
            }
          }
        }
      }

      // ── About Section ──
      SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-sm;

          Text {
            text: "About";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }
          Text {
            text: "CrispyTivi v0.1.1";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
          }
          Text {
            text: "Cross-platform IPTV & media player";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
          }
        }
      }
    }
  }
}
