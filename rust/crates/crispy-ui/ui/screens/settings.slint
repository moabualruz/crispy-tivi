import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";

export component SettingsScreen inherits Rectangle {
  background: transparent;

  Flickable {
    VerticalLayout {
      padding: Theme.spacing-xl;
      spacing: Theme.spacing-lg;

      // Header
      Text {
        text: "Settings";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
      }

      // Sources section
      Rectangle {
        border-radius: Theme.radius-md;
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.border-subtle;

        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-sm;

          Text {
            text: "Sources";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }
          Text {
            text: "No sources configured. Add an IPTV source or media server to get started.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }
          FocusScope {
            height: 40px;
            key-pressed(event) => {
              if event.text == Key.Return || event.text == " " {
                // Add source action (Phase 2)
                return accept;
              }
              return reject;
            }
            Rectangle {
              width: 100%;
              height: 100%;
              border-radius: Theme.radius-sm;
              background: Theme.accent;
              border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
              border-color: Theme.focus-ring;

              Text {
                text: "+ Add Source";
                color: #FFFFFF;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
              TouchArea { }
            }
          }
        }
      }

      // Appearance section
      Rectangle {
        border-radius: Theme.radius-md;
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.border-subtle;

        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-md;

          Text {
            text: "Appearance";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }

          // Theme selector: System / Dark / Light
          HorizontalLayout {
            spacing: Theme.spacing-md;

            Text {
              text: "Theme";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }

            HorizontalLayout {
              spacing: Theme.spacing-xs;

              for item[idx] in [
                { label: "System", mode: 0 },
                { label: "Dark", mode: 1 },
                { label: "Light", mode: 2 },
              ]: FocusScope {
                width: 72px;
                height: 32px;

                key-pressed(event) => {
                  if event.text == Key.Return || event.text == " " {
                    Theme.theme-mode = item.mode;
                    AppState.set-theme(item.mode);
                    return accept;
                  }
                  return reject;
                }

                Rectangle {
                  width: 100%;
                  height: 100%;
                  border-radius: Theme.radius-pill;
                  background: Theme.theme-mode == item.mode ? Theme.accent : Theme.surface-glass;
                  border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
                  border-color: Theme.focus-ring;

                  Text {
                    text: item.label;
                    color: Theme.theme-mode == item.mode ? #FFFFFF : Theme.text-secondary;
                    font-family: Theme.font-body;
                    font-size: Theme.font-size-small;
                    font-weight: 500;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                  }

                  TouchArea {
                    clicked => {
                      Theme.theme-mode = item.mode;
                      AppState.set-theme(item.mode);
                    }
                  }
                }
              }
            }
          }

          // Language row
          HorizontalLayout {
            spacing: Theme.spacing-md;

            Text {
              text: "Language";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }

            Text {
              text: AppState.active-language == "en" ? "English"
                : AppState.active-language == "ar" ? "العربية"
                : AppState.active-language == "de" ? "Deutsch"
                : AppState.active-language == "fr" ? "Français"
                : AppState.active-language == "es" ? "Español"
                : "English";
              color: Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
            }
          }
        }
      }

      // About section
      Rectangle {
        border-radius: Theme.radius-md;
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.border-subtle;

        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-sm;

          Text {
            text: "About";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }
          Text {
            text: "CrispyTivi v0.1.1";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
          }
          Text {
            text: "Cross-platform IPTV & media player";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
          }
        }
      }
    }
  }
}
