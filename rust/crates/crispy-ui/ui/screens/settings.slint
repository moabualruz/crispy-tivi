import { Theme } from "../globals/theme.slint";
import { AppState, SourceData } from "../globals/app-state.slint";
import { ScrollView } from "std-widgets.slint";
import { ActionButton } from "../components/action-button.slint";
import { FilterChip } from "../components/filter-chip.slint";

component SourceRow inherits FocusScope {
  in property <SourceData> source;

  height: 64px;
  width: 100%;

  key-pressed(event) => {
    if event.text == Key.Delete {
      AppState.delete-source(source.id);
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-sm;
    background: root.has-focus ? Theme.surface-glass : transparent;
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-md;

      // Type badge
      Rectangle {
        width: 48px;
        height: 28px;
        border-radius: Theme.radius-sm;
        background: Theme.surface;
        vertical-stretch: 0;

        Text {
          text: source.source-type == "m3u" ? "M3U"
            : source.source-type == "xtream" ? "XC"
            : source.source-type == "stalker" ? "STK"
            : source.source-type;
          color: Theme.accent;
          font-size: Theme.font-size-small;
          font-weight: 700;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
      }

      // Source info
      VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;
        spacing: 2px;

        Text {
          text: source.name;
          color: Theme.text-primary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          overflow: elide;
        }
        HorizontalLayout {
          spacing: Theme.spacing-sm;
          Text {
            text: source.channel-count + " channels";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
          Text {
            text: "·";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
          Text {
            text: source.vod-count + " VOD";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
        }
      }

      // Actions
      HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: end;
        vertical-stretch: 0;

        ActionButton {
          label: "Sync";
          width: 80px;
          height: 32px;
          clicked => { AppState.sync-source(source.id); }
        }

        ActionButton {
          label: "Delete";
          width: 80px;
          height: 32px;
          clicked => { AppState.delete-source(source.id); }
        }
      }
    }
  }
}

export component SettingsScreen inherits Rectangle {
  background: transparent;

  // Dimmed background area
  Rectangle {
    width: 100%; height: 100%;
    background: transparent; // Not an overlay, so just transparent
  }

  // Right-side Settings Pane
  HorizontalLayout {
    alignment: end;
    
    Rectangle {
      width: 420px;
      height: 100%;
      background: Theme.surface;
      border-width: 1px;
      border-color: Theme.border-subtle;
      
      // Glass effect mock
      Rectangle {
        width: 100%; height: 100%;
        background: rgba(10, 10, 12, 0.8);
      }

      ScrollView {
        width: 100%; height: 100%;

        VerticalLayout {
          padding-top: Theme.spacing-2xl;
          padding-left: Theme.spacing-xl;
          padding-right: Theme.spacing-xl;
          padding-bottom: Theme.spacing-2xl;
          spacing: Theme.spacing-lg;

          // Header with close button
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            Text {
              text: "Settings";
              color: Theme.text-primary;
              font-family: Theme.font-display;
              font-size: Theme.font-size-h2;
              font-weight: 700;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }

            // Close button — returns to Home
            close-btn := FocusScope {
              width: 36px;
              height: 36px;
              key-pressed(event) => {
                if event.text == Key.Return || event.text == Key.Escape {
                  AppState.active-screen = 0;
                  AppState.navigate(0);
                  return accept;
                }
                return reject;
              }
              Rectangle {
                width: 100%; height: 100%;
                border-radius: 18px;
                background: close-btn.has-focus ? Theme.surface-glass : transparent;
                border-width: close-ta.has-hover ? 1px : 0px;
                border-color: Theme.border-subtle;

                Text {
                  text: "✕";
                  color: close-ta.has-hover ? Theme.text-primary : Theme.text-secondary;
                  font-size: 18px;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }

                close-ta := TouchArea {
                  clicked => {
                    AppState.active-screen = 0;
                    AppState.navigate(0);
                  }
                }
              }
            }
          }

          Rectangle { height: 1px; width: 100%; background: Theme.border-subtle; }

          // Sources Section
          VerticalLayout {
            spacing: Theme.spacing-md;
            
            HorizontalLayout {
              Text {
                text: "Sources & Library";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
                font-weight: 600;
                horizontal-stretch: 1;
              }
              ActionButton {
                label: "+ Add";
                width: 80px;
                height: 32px;
                is-primary: true;
                clicked => { AppState.show-source-dialog = true; }
              }
            }

          if AppState.sources.length == 0: Text {
            text: "No sources configured. Add an IPTV source or media server to get started.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          for src in AppState.sources: SourceRow {
            source: src;
          }
        }

      // Appearance section
      Rectangle {
        border-radius: 12px;
        background: rgba(28, 28, 32, 0.8);
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);

        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-md;

          Text {
            text: "Appearance";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }

          // Theme selector
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Theme";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for item in [
                { label: "System", mode: 0 },
                { label: "Dark", mode: 1 },
                { label: "Light", mode: 2 },
              ]: FilterChip {
                label: item.label;
                active: Theme.theme-mode == item.mode;
                activated => {
                  Theme.theme-mode = item.mode;
                  AppState.set-theme(item.mode);
                }
              }
            }
          }

          // Language row
      // Language row
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Language";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            GridLayout {
              spacing: Theme.spacing-xs;

              for lang[idx] in [
                { code: "en", label: "English" },
                { code: "ar", label: "العربية" },
                { code: "de", label: "Deutsch" },
                { code: "fr", label: "Français" },
                { code: "es", label: "Español" },
              ]: FilterChip {
                row: floor(idx / 3);
                col: mod(idx, 3);
                label: lang.label;
                active: AppState.active-language == lang.code;
                activated => {
                  AppState.set-language(lang.code);
                  AppState.active-language = lang.code;
                }
              }
            }
          }
        }
      }

      // About
      Rectangle {
        border-radius: 12px;
        background: rgba(28, 28, 32, 0.8);
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);
        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-sm;
          Text {
            text: "About";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }
          Text {
            text: "CrispyTivi v0.1.1";
            color: Theme.text-secondary;
            font-size: Theme.font-size-caption;
          }
          Text {
            text: "Cross-platform IPTV & media player";
            color: Theme.text-secondary;
            font-size: Theme.font-size-caption;
          }
        }
      }
        }
      }
    }
  }
}
