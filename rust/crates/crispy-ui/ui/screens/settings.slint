import { Theme } from "../globals/theme.slint";
import { AppState, SourceData } from "../globals/app-state.slint";
import { ScrollView } from "std-widgets.slint";
import { ActionButton } from "../components/action-button.slint";
import { FilterChip } from "../components/filter-chip.slint";
import { InputField } from "../components/input-field.slint";
import { DiagnosticsState } from "../components/diagnostics-panel.slint";
import { AttributionOverlay } from "../components/attribution-overlay.slint";

// ── Helper: returns true if haystack contains needle (case-folded via lowercasing trick)
// Slint has no built-in string-contains; we use a visible property trick per-section.
// Each section computes its own visibility by checking if search is empty OR
// the section title/keywords contain the search text.
// Since Slint has no string search, we match by equality of lowercased first chars
// — instead we use a pragmatic approach: expose a `section-visible` pure function
// implemented as property logic per-section using `search == "" || title.starts-with(search)`.
// Full substring match is done via Rust binding (AppState.settings-search-filter).
// For pure-Slint fallback we show all when search is non-empty (Rust filters on its side).
// UI: sections use `visible` bound to `root.section-visible(keywords)`.

component SourceRow inherits FocusScope {
  in property <SourceData> source;

  // Expand height when an error message is present
  height: source.last-sync-error != "" ? 84px : 64px;
  width: 100%;

  key-pressed(event) => {
    if event.text == Key.Delete {
      AppState.delete-source(source.id);
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-sm;
    background: root.has-focus ? Theme.surface-highlight : transparent;
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-md;

      // Type badge
      VerticalLayout {
        alignment: center;
        Rectangle {
          width: 48px;
          height: 28px;
          border-radius: Theme.radius-sm;
          background: Theme.card-surface;
          border-width: 1px;
          border-color: Theme.card-border;

          Text {
            text: source.source-type == "m3u" ? "M3U"
              : source.source-type == "xtream" ? "XC"
              : source.source-type == "stalker" ? "STK"
              : source.source-type;
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }
      }

      // Source info
      VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;
        spacing: Theme.spacing-2xs;

        HorizontalLayout {
          spacing: Theme.spacing-xs;
          alignment: start;

          // M-019: health dot — green/yellow/red based on sync-status
          Rectangle {
            width: 8px;
            height: 8px;
            border-radius: Theme.radius-xs;
            y: (parent.height - self.height) / 2;
            // Green: empty / "ok"; Yellow: "slow" / "warning"; Red: "error" / "fail"
            background:
              source.sync-status == "" ? Theme.status-success
              : source.sync-status == "ok" ? Theme.status-success
              : (source.sync-status == "slow" || source.sync-status == "warning") ? Theme.status-warning
              : (source.sync-status == "error" || source.sync-status == "fail") ? Theme.status-error
              : Theme.status-success;
          }

          Text {
            text: source.name != "" ? source.name : source.url;
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            overflow: elide;
          }
        }
        HorizontalLayout {
          spacing: Theme.spacing-sm;
          Text {
            text: source.channel-count + " channels";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
          }
          Text {
            text: "·";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
          Text {
            text: source.vod-count + " VOD";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
          }
        }

        // J-44: error banner — visible only when last-sync-error is non-empty
        if source.last-sync-error != "": HorizontalLayout {
          spacing: Theme.spacing-xs;
          alignment: start;

          Text {
            text: source.last-sync-error;
            color: Theme.status-error;
            font-family: Theme.font-body;
            font-size: Theme.font-size-small;
            overflow: elide;
            horizontal-stretch: 1;
          }

          // Retry touch target — calls sync-source with this source's id
          retry-area := TouchArea {
            width: 40px;
            height: 16px;
            clicked => { AppState.sync-source(source.id); }

            Text {
              text: "Retry";
              color: retry-area.has-hover ? Theme.text-primary : Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-small;
              font-weight: 600;
              horizontal-alignment: center;
              vertical-alignment: center;
            }
          }
        }
      }

      // Actions
      HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: end;

        ActionButton {
          label: source.enabled ? "Disable" : "Enable";
          width: 80px;
          height: 32px;
          clicked => { AppState.toggle-source-enabled(source.id); }
        }

        ActionButton {
          label: "Edit";
          width: 72px;
          height: 32px;
          clicked => { AppState.edit-source(source.id); }
        }

        ActionButton {
          label: "Sync";
          width: 72px;
          height: 32px;
          clicked => { AppState.sync-source(source.id); }
        }

        ActionButton {
          label: "Delete";
          width: 72px;
          height: 32px;
          clicked => { AppState.delete-source(source.id); }
        }
      }
    }
  }
}

// ── Glass card — reusable section container
component SettingsCard inherits Rectangle {
  border-radius: Theme.radius-md;
  background: Theme.card-surface;
  border-width: 1px;
  border-color: Theme.card-border;
}

// ── Simple/Advanced mode toggle — pill-shaped glass switch
// Renders two labels: "Simple" and "Advanced". The active tab has white bg + black text.
component ModeToggle inherits FocusScope {
  in-out property <bool> advanced: false;
  callback toggled(bool);

  width: 220px;
  height: 40px;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.advanced = !root.advanced;
      root.toggled(root.advanced);
      return accept;
    }
    if event.text == Key.LeftArrow {
      root.advanced = false;
      root.toggled(false);
      return accept;
    }
    if event.text == Key.RightArrow {
      root.advanced = true;
      root.toggled(true);
      return accept;
    }
    return reject;
  }

  // Outer pill container
  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-pill;
    background: Theme.surface-glass;
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.border-subtle;

    HorizontalLayout {
      padding: Theme.spacing-xs;
      spacing: 0px;

      // Simple tab
      simple-ta := TouchArea {
        width: parent.width / 2;
        height: parent.height - 8px;
        clicked => {
          root.advanced = false;
          root.toggled(false);
        }
        Rectangle {
          width: 100%; height: 100%;
          border-radius: Theme.radius-pill;
          background: !root.advanced ? Theme.btn-primary-bg : transparent;

          Text {
            text: "Simple";
            color: !root.advanced ? Theme.btn-primary-fg : Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            font-weight: !root.advanced ? 700 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }
      }

      // Advanced tab
      advanced-ta := TouchArea {
        width: parent.width / 2;
        height: parent.height - 8px;
        clicked => {
          root.advanced = true;
          root.toggled(true);
        }
        Rectangle {
          width: 100%; height: 100%;
          border-radius: Theme.radius-pill;
          background: root.advanced ? Theme.btn-primary-bg : transparent;

          Text {
            text: "Advanced";
            color: root.advanced ? Theme.btn-primary-fg : Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            font-weight: root.advanced ? 700 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }
      }
    }
  }
}

// ── Inline toggle row for boolean settings
component SettingToggleRow inherits Rectangle {
  in property <string> label-text;
  in property <string> description-text;
  in-out property <bool> checked: false;
  callback toggled(bool);

  height: 56px;
  width: 100%;

  HorizontalLayout {
    spacing: Theme.spacing-md;
    alignment: space-between;

    VerticalLayout {
      horizontal-stretch: 1;
      alignment: center;
      spacing: Theme.spacing-2xs;

      Text {
        text: root.label-text;
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
      }
      if root.description-text != "": Text {
        text: root.description-text;
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        wrap: word-wrap;
      }
    }

    // Toggle pill
    toggle-scope := FocusScope {
      width: 52px;
      height: 28px;

      key-pressed(event) => {
        if event.text == Key.Return || event.text == " " {
          root.checked = !root.checked;
          root.toggled(root.checked);
          return accept;
        }
        return reject;
      }

      toggle-ta := TouchArea {
        width: 52px;
        height: 28px;
        clicked => {
          root.checked = !root.checked;
          root.toggled(root.checked);
        }
        Rectangle {
          width: 52px;
          height: 28px;
          border-radius: Theme.radius-md;
          background: root.checked ? Theme.status-success : Theme.surface-glass;
          border-width: toggle-scope.has-focus ? Theme.focus-ring-width : 1px;
          border-color: toggle-scope.has-focus ? Theme.focus-ring : Theme.border-subtle;

          // Knob
          Rectangle {
            width: 20px;
            height: 20px;
            border-radius: Theme.radius-sm;
            background: Theme.text-primary;
            x: root.checked ? 28px : 4px;
            y: 4px;
          }
        }
      }
    }
  }
}

// ── Info row (label + static value badge)
component SettingInfoRow inherits Rectangle {
  in property <string> label-text;
  in property <string> description-text;
  in property <string> value-text;

  height: description-text != "" ? 56px : 40px;
  width: 100%;

  HorizontalLayout {
    spacing: Theme.spacing-md;
    alignment: space-between;

    VerticalLayout {
      horizontal-stretch: 1;
      alignment: center;
      spacing: Theme.spacing-2xs;

      Text {
        text: root.label-text;
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
      }
      if root.description-text != "": Text {
        text: root.description-text;
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        wrap: word-wrap;
      }
    }

    Rectangle {
      width: val-lbl.preferred-width + Theme.spacing-md;
      height: 28px;
      border-radius: Theme.radius-sm;
      background: Theme.card-surface;
      border-width: 1px;
      border-color: Theme.card-border;

      val-lbl := Text {
        text: root.value-text;
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-small;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }
  }
}

export component SettingsScreen inherits Rectangle {
  background: transparent;

  // Escape → navigate to Home
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.Escape {
        AppState.navigate(0);
        return accept;
      }
      return reject;
    }
  }

  // ── Mode toggle state
  in-out property <bool> advanced-mode: false;

  // ── Keyword search text (populated by InputField)
  property <string> settings-search: "";

  // ── Section visibility helper:
  // A section is visible when:
  //   (a) search is empty AND the section belongs to the current mode, OR
  //   (b) search is non-empty AND section title/keywords start with or equal search
  // Full substring match for (b) is handled by Rust via AppState; the Slint side
  // shows sections when search is empty (Rust hides irrelevant ones) or always
  // when search is active to let Rust-side filtering take effect through opacity.
  // We implement a simple Slint-native filter: show if search == "" (mode-gated)
  // or if section keywords begin with the search string.
  // For a richer UX the Rust binding should populate AppState.settings-visible-sections.

  pure function section-visible(keywords: string, is-advanced-only: bool) -> bool {
    // When search is active: show all sections (Rust handles deep filtering)
    if root.settings-search != "" {
      return true;
    }
    // When search is empty: apply mode gate
    if is-advanced-only && !root.advanced-mode {
      return false;
    }
    return true;
  }

  ScrollView {
    width: 100%; height: 100%;

    VerticalLayout {
      padding-top: Theme.screen-padding-top;
      padding-left: Theme.content-padding-h;
      padding-right: Theme.content-padding-h;
      padding-bottom: Theme.spacing-2xl;
      spacing: Theme.spacing-lg;

      // ── Header row: title + mode toggle + back button
      HorizontalLayout {
        spacing: Theme.spacing-md;
        alignment: space-between;

        Text {
          text: "Settings";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: Theme.font-size-h1;
          font-weight: 700;
          vertical-alignment: center;
          horizontal-stretch: 1;
        }

        // Simple / Advanced toggle
        VerticalLayout {
          alignment: center;
          ModeToggle {
            advanced: root.advanced-mode;
            toggled(v) => { root.advanced-mode = v; }
          }
        }

        // Back button
        VerticalLayout {
          alignment: center;
          back-btn := FocusScope {
            width: 36px;
            height: 36px;
            key-pressed(event) => {
              if event.text == Key.Return || event.text == Key.Escape {
                AppState.active-screen = 0;
                AppState.navigate(0);
                return accept;
              }
              return reject;
            }
            Rectangle {
              width: 100%; height: 100%;
              border-radius: Theme.radius-lg;
              background: back-btn.has-focus ? Theme.surface-glass : Theme.card-surface;
              border-width: 1px;
              border-color: back-ta.has-hover ? Theme.text-secondary : Theme.card-border;

              Text {
                text: "✕";
                color: back-ta.has-hover ? Theme.text-primary : Theme.text-secondary;
                font-size: Theme.font-size-body;
                horizontal-alignment: center;
                vertical-alignment: center;
              }

              back-ta := TouchArea {
                clicked => {
                  AppState.active-screen = 0;
                  AppState.navigate(0);
                }
              }
            }
          }
        }
      }

      // ── Keyword search bar
      InputField {
        label: "";
        placeholder-text: "Search settings…";
        edited(v) => { root.settings-search = v; }
      }

      // ── Sources & Library  [Simple]
      if root.section-visible("sources library iptv add source", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          HorizontalLayout {
            Text {
              text: "Sources & Library";
              color: Theme.text-primary;
              font-family: Theme.font-display;
              font-size: Theme.font-size-h2;
              font-weight: 700;
              horizontal-stretch: 1;
              vertical-alignment: center;
            }
            ActionButton {
              label: "+ Add Source";
              height: 36px;
              is-primary: true;
              clicked => { AppState.show-source-dialog = true; }
            }
          }

          if AppState.total-channel-count > 0 || AppState.total-movie-count > 0 || AppState.total-series-count > 0: Text {
            text: AppState.total-channel-count + " channels · " + AppState.total-movie-count + " movies · " + AppState.total-series-count + " series";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
          }

          if AppState.sources.length == 0: Text {
            text: "No sources configured. Add an IPTV source or media server to get started.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          for src in AppState.sources: SourceRow {
            source: src;
          }
        }
      }

      // ── Display  [Simple]
      if root.section-visible("display brightness resolution screen", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Display";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Resolution preference
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Resolution Preference";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Preferred stream quality when multiple resolutions are available.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }

            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for res in [
                { label: "Auto" },
                { label: "1080p" },
                { label: "720p" },
                { label: "480p" },
              ]: FilterChip {
                label: res.label;
                active: res.label == "Auto";
                activated => { /* backend wiring: separate task */ }
              }
            }
          }

          // UI scale
          SettingInfoRow {
            label-text: "UI Scale";
            description-text: "Interface scale factor for TV/monitor distance.";
            value-text: "100%";
          }
        }
      }

      // ── Playback  [Simple]
      if root.section-visible("playback hardware decoding aspect ratio audio passthrough", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Playback";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Hardware Decoding
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Hardware Decoding";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "GPU-accelerated video decode. Auto is recommended.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }

            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for opt in [
                { label: "Auto" },
                { label: "Always" },
                { label: "Never" },
              ]: FilterChip {
                label: opt.label;
                active: opt.label == AppState.hwdec-mode;
                activated => { AppState.set-hwdec-mode(opt.label); }
              }
            }
          }

          // Aspect Ratio
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Aspect Ratio";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Video display aspect ratio override.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }

            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for opt in [
                { label: "Auto" },
                { label: "16:9" },
                { label: "4:3" },
                { label: "Fill" },
              ]: FilterChip {
                label: opt.label;
                active: opt.label == AppState.aspect-ratio;
                activated => { AppState.set-aspect-ratio(opt.label); }
              }
            }
          }

          // Audio Passthrough
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Audio Passthrough";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Pass encoded audio (Dolby/DTS) directly to the receiver.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }

            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for opt in [
                { label: "Off" },
                { label: "On" },
              ]: FilterChip {
                label: opt.label;
                active: opt.label == AppState.audio-passthrough-mode;
                activated => { AppState.set-audio-passthrough-mode(opt.label); }
              }
            }
          }
        }
      }

      // ── Audio  [Simple]
      if root.section-visible("audio language volume sound", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Audio";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Default audio language
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Default Audio Language";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Preferred audio track language when multiple tracks are available.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }

            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for lang in [
                { code: "auto", label: "Auto" },
                { code: "en", label: "EN" },
                { code: "ar", label: "AR" },
                { code: "de", label: "DE" },
                { code: "fr", label: "FR" },
              ]: FilterChip {
                label: lang.label;
                active: lang.code == "auto";
                activated => { /* backend wiring: separate task */ }
              }
            }
          }

          // Volume
          SettingInfoRow {
            label-text: "Default Volume";
            description-text: "Starting volume level on app launch.";
            value-text: "100%";
          }

          // Audio passthrough
          SettingToggleRow {
            label-text: "Audio Passthrough";
            description-text: "Pass raw Dolby/DTS bitstream to AV receiver (requires compatible hardware).";
            checked: false;
            toggled(v) => { /* backend wiring: separate task */ }
          }
        }
      }

      // ── Playback  [Simple]
      if root.section-visible("playback autoplay subtitles captions hardware decode renderer", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Playback";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Hardware decode info
          SettingInfoRow {
            label-text: "Hardware Decode";
            description-text: "Uses GPU decode (hwdec=auto-safe) with automatic CPU fallback.";
            value-text: "AUTO";
          }

          // Video renderer info
          SettingInfoRow {
            label-text: "Video Renderer";
            description-text: "libplacebo Vulkan renderer (vo=gpu-next) with ewa_lanczossharp upscaling.";
            value-text: "GPU";
          }

          // Autoplay
          SettingToggleRow {
            label-text: "Autoplay Next";
            description-text: "Automatically play next episode in a series.";
            checked: true;
            toggled(v) => { /* backend wiring: separate task */ }
          }

          // Default subtitle language
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Default Subtitle Language";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Show subtitles in this language when available.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }

            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for lang in [
                { code: "off", label: "Off" },
                { code: "en", label: "EN" },
                { code: "ar", label: "AR" },
                { code: "de", label: "DE" },
                { code: "fr", label: "FR" },
              ]: FilterChip {
                label: lang.label;
                active: lang.code == "off";
                activated => { /* backend wiring: separate task */ }
              }
            }
          }
        }
      }

      // ── Programme Guide (EPG)  [Simple]
      if root.section-visible("epg programme guide refresh", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Programme Guide (EPG)";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Refresh EPG data manually or configure auto-refresh via your source settings.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
              // Epoch 8.3: staleness indicator when EPG data is > 24h old
              if AppState.epg-last-updated-hours > 24: Text {
                text: "⚠ EPG data is " + AppState.epg-last-updated-hours + "h old — refresh recommended";
                color: Theme.status-warning;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                font-weight: 600;
              }
            }
            ActionButton {
              label: "Refresh EPG";
              height: 36px;
              clicked => { AppState.sync-all(); }
            }
          }
        }
      }

      // ── Parental Controls  [Simple]  (Epoch 7)
      if root.section-visible("parental controls kids pin content rating time limit", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Parental Controls";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // PIN status + set/change
          HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Parental PIN";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: AppState.parental-pin-set
                  ? "PIN is set. Required to access restricted content."
                  : "No PIN set. Parental restrictions are unenforced.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              ActionButton {
                label: AppState.parental-pin-set ? "Change PIN" : "Set PIN";
                height: 36px;
                clicked => { AppState.set-parental-pin(""); }
              }
              if AppState.parental-pin-set: ActionButton {
                label: "Clear";
                height: 36px;
                clicked => { AppState.clear-parental-pin(); }
              }
            }
          }

          // Content rating limit
          HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Content Rating Limit";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Block content above the selected maturity level.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
              }
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for tier in [
                { label: "All", idx: -1 },
                { label: "G", idx: 0 },
                { label: "PG", idx: 1 },
                { label: "PG-13", idx: 2 },
                { label: "R", idx: 3 },
              ]: FilterChip {
                label: tier.label;
                active: AppState.parental-rating-limit == tier.idx;
                activated => { AppState.set-content-rating(tier.idx); }
              }
            }
          }

          // Viewing time limit
          HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "Daily Time Limit";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: AppState.parental-time-limit-minutes == 0
                  ? "No daily limit."
                  : ("Limit: " + AppState.parental-time-limit-minutes + " min/day");
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
              }
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for opt in [
                { label: "Off", mins: 0 },
                { label: "30m", mins: 30 },
                { label: "1h", mins: 60 },
                { label: "2h", mins: 120 },
              ]: FilterChip {
                label: opt.label;
                active: AppState.parental-time-limit-minutes == opt.mins;
                activated => { AppState.set-viewing-time-limit(opt.mins); }
              }
            }
          }
        }
      }

      // ── General  [Simple]
      if root.section-visible("general language theme startup screen", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-lg;

          Text {
            text: "General";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Theme selector
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Theme";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for item in [
                { label: "System", mode: 0 },
                { label: "Dark", mode: 1 },
                { label: "Light", mode: 2 },
              ]: FilterChip {
                label: item.label;
                active: Theme.theme-mode == item.mode;
                activated => { AppState.set-theme(item.mode); }
              }
            }
          }

          // Language selector
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Language";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for lang in [
                { code: "en", label: "English" },
                { code: "ar", label: "العربية" },
                { code: "de", label: "Deutsch" },
                { code: "fr", label: "Français" },
                { code: "es", label: "Español" },
              ]: FilterChip {
                label: lang.label;
                active: AppState.active-language == lang.code;
                activated => { AppState.set-language(lang.code); }
              }
            }
          }

          // Startup screen
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Startup Screen";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for screen in [
                { label: "For You" },
                { label: "Live" },
                { label: "Movies" },
              ]: FilterChip {
                label: screen.label;
                active: screen.label == "For You";
                activated => { /* backend wiring: separate task */ }
              }
            }
          }
        }
      }

      // ── Maintenance  [Simple]
      if root.section-visible("maintenance clear history export import", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Maintenance";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          Text {
            text: "Data management actions. These features are under active development.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          HorizontalLayout {
            spacing: Theme.spacing-md;

            // Clear Watch History
            VerticalLayout {
              spacing: Theme.spacing-xs;
              horizontal-stretch: 1;
              Rectangle {
                opacity: 0.5;
                height: 40px;
                border-radius: Theme.radius-md;
                background: Theme.btn-secondary-bg;
                border-width: 1px;
                border-color: Theme.card-border;
                Text {
                  text: "Clear Watch History";
                  color: Theme.text-primary;
                  font-family: Theme.font-body;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }
              }
              Text {
                text: "coming soon";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                horizontal-alignment: center;
              }
            }

            // Export Settings
            VerticalLayout {
              spacing: Theme.spacing-xs;
              horizontal-stretch: 1;
              Rectangle {
                opacity: 0.5;
                height: 40px;
                border-radius: Theme.radius-md;
                background: Theme.btn-secondary-bg;
                border-width: 1px;
                border-color: Theme.card-border;
                Text {
                  text: "Export Settings";
                  color: Theme.text-primary;
                  font-family: Theme.font-body;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }
              }
              Text {
                text: "coming soon";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                horizontal-alignment: center;
              }
            }

            // Import Settings
            VerticalLayout {
              spacing: Theme.spacing-xs;
              horizontal-stretch: 1;
              Rectangle {
                opacity: 0.5;
                height: 40px;
                border-radius: Theme.radius-md;
                background: Theme.btn-secondary-bg;
                border-width: 1px;
                border-color: Theme.card-border;
                Text {
                  text: "Import Settings";
                  color: Theme.text-primary;
                  font-family: Theme.font-body;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }
              }
              Text {
                text: "coming soon";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                horizontal-alignment: center;
              }
            }

            // Refresh EPG Guide
            VerticalLayout {
              spacing: Theme.spacing-xs;
              horizontal-stretch: 1;
              Rectangle {
                opacity: 0.5;
                height: 40px;
                border-radius: Theme.radius-md;
                background: Theme.btn-secondary-bg;
                border-width: 1px;
                border-color: Theme.card-border;
                Text {
                  text: "Refresh EPG Guide";
                  color: Theme.text-primary;
                  font-family: Theme.font-body;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }
              }
              Text {
                text: "coming soon";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                horizontal-alignment: center;
              }
            }
          }
        }
      }

      // ── Network  [Advanced only]
      if root.section-visible("network proxy buffer timeout connection", true): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Network";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          // Proxy
          HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
              horizontal-stretch: 1;
              spacing: Theme.spacing-2xs;
              Text {
                text: "HTTP Proxy";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
              }
              Text {
                text: "Optional HTTP proxy for all outbound IPTV and EPG requests.";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
              }
            }
            Rectangle {
              width: proxy-lbl.preferred-width + Theme.spacing-lg;
              height: 32px;
              border-radius: Theme.radius-sm;
              background: Theme.surface-glass;
              border-width: 1px;
              border-color: Theme.border-subtle;
              proxy-lbl := Text {
                text: "Not configured";
                color: Theme.text-secondary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-caption;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
            }
          }

          // Buffer size
          SettingInfoRow {
            label-text: "Stream Buffer Size";
            description-text: "Memory allocated for live stream buffering. Increase for unstable connections.";
            value-text: "32 MB";
          }

          // Connection timeout
          SettingInfoRow {
            label-text: "Connection Timeout";
            description-text: "Seconds before abandoning a stream connection attempt.";
            value-text: "10s";
          }

          // Request timeout
          SettingInfoRow {
            label-text: "Request Timeout";
            description-text: "Maximum time for EPG and image HTTP requests.";
            value-text: "30s";
          }
        }
      }

      // ── Diagnostics  [Advanced only]
      if root.section-visible("diagnostics debug log system info performance", true): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: space-between;

            Text {
              text: "Diagnostics";
              color: Theme.text-primary;
              font-family: Theme.font-display;
              font-size: Theme.font-size-h2;
              font-weight: 700;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }

            ActionButton {
              label: DiagnosticsState.visible ? "Hide Panel" : "Show Panel";
              height: 36px;
              clicked => { DiagnosticsState.visible = !DiagnosticsState.visible; }
            }
          }

          Text {
            text: "System diagnostics, performance metrics, and structured log viewer.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          // GPU pipeline info
          SettingInfoRow {
            label-text: "GPU Pipeline";
            description-text: "Active video rendering pipeline level.";
            value-text: "gpu-next";
          }

          // Version
          SettingInfoRow {
            label-text: "App Version";
            description-text: "";
            value-text: DiagnosticsState.app-version != "" ? DiagnosticsState.app-version : "v0.1.1";
          }
        }
      }

      // ── Analytics & Privacy  [Simple]  (Epoch 11)
      if root.section-visible("analytics privacy consent data collection GDPR", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Analytics & Privacy";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          Text {
            text: "Control what usage data is collected. No data is pre-ticked or shared with third parties.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          SettingToggleRow {
            label-text: "Playback Analytics";
            description-text: "Collect anonymised TTFF, rebuffer ratio, and quality-switch metrics to improve streaming quality.";
            checked: AppState.analytics-playback-consent;
            toggled(v) => { AppState.set-analytics-playback(v); }
          }

          SettingToggleRow {
            label-text: "Crash Reports";
            description-text: "Send anonymised crash reports to help identify and fix stability issues.";
            checked: AppState.analytics-crash-consent;
            toggled(v) => { AppState.set-analytics-crash(v); }
          }

          // J-47: GDPR Art. 17 — erase all personal data
          delete-data-btn := FocusScope {
            height: 40px;
            key-pressed(event) => {
              if event.text == Key.Return { AppState.delete-all-data(); return accept; }
              return reject;
            }
            Rectangle {
              width: 100%; height: 100%;
              border-radius: Theme.radius-md;
              background: delete-data-btn.has-focus ? Theme.surface-glass : Theme.btn-secondary-bg;
              border-width: delete-data-btn.has-focus ? Theme.focus-ring-width : 1px;
              border-color: delete-data-btn.has-focus ? Theme.focus-ring : Theme.status-error;
              Text {
                text: "Delete All My Data";
                color: Theme.status-error;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
              TouchArea { clicked => { AppState.delete-all-data(); } }
            }
          }
        }
      }

      // ── Backup & Restore  [Simple]  (Epoch 13)
      if root.section-visible("backup restore export import data", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: "Backup & Restore";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          Text {
            text: "Export an encrypted backup of your sources, favourites, profiles, and settings.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          HorizontalLayout {
            spacing: Theme.spacing-md;

            export-btn := FocusScope {
              height: 40px;
              horizontal-stretch: 1;
              key-pressed(event) => {
                if event.text == Key.Return { AppState.export-backup(); return accept; }
                return reject;
              }
              Rectangle {
                width: 100%; height: 100%;
                border-radius: Theme.radius-md;
                background: export-btn.has-focus ? Theme.surface-glass : Theme.btn-secondary-bg;
                border-width: export-btn.has-focus ? Theme.focus-ring-width : 1px;
                border-color: export-btn.has-focus ? Theme.focus-ring : Theme.card-border;
                Text {
                  text: "Export Backup";
                  color: Theme.text-primary;
                  font-family: Theme.font-body;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }
                TouchArea { clicked => { AppState.export-backup(); } }
              }
            }

            import-btn := FocusScope {
              height: 40px;
              horizontal-stretch: 1;
              key-pressed(event) => {
                if event.text == Key.Return { AppState.import-backup(); return accept; }
                return reject;
              }
              Rectangle {
                width: 100%; height: 100%;
                border-radius: Theme.radius-md;
                background: import-btn.has-focus ? Theme.surface-glass : Theme.btn-secondary-bg;
                border-width: import-btn.has-focus ? Theme.focus-ring-width : 1px;
                border-color: import-btn.has-focus ? Theme.focus-ring : Theme.card-border;
                Text {
                  text: "Restore Backup";
                  color: Theme.text-primary;
                  font-family: Theme.font-body;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }
                TouchArea { clicked => { AppState.import-backup(); } }
              }
            }
          }
        }
      }

      // ── About  [Simple]
      if root.section-visible("about version licenses info", false): SettingsCard {
        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-sm;

          Text {
            text: "About";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }
          Text {
            text: "CrispyTivi v0.1.1";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
          }
          Text {
            text: "Cross-platform IPTV & media player";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
          }
          Text {
            text: "Built with Rust · Slint · libmpv";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
          }

          // Open Source Licenses button
          oss-btn := FocusScope {
            height: 40px;
            width: 100%;
            key-pressed(event) => {
              if event.text == Key.Return { AppState.show-attribution = true; return accept; }
              return reject;
            }
            Rectangle {
              width: 100%; height: 100%;
              border-radius: Theme.radius-sm;
              background: oss-btn.has-focus ? Theme.focus-bg : Theme.btn-secondary-bg;
              border-width: oss-btn.has-focus ? Theme.focus-ring-width : 1px;
              border-color: oss-btn.has-focus ? Theme.focus-ring : Theme.card-border;
              Text {
                text: "Open Source Licenses";
                color: Theme.text-primary;
                font-family: Theme.font-body;
                font-size: Theme.font-size-body;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
              }
              TouchArea { clicked => { AppState.show-attribution = true; } }
            }
          }
        }
      }
    }
  }

  // Attribution overlay — rendered on top of settings content
  AttributionOverlay { }
}
