import { Theme } from "../globals/theme.slint";
import { AppState, SourceData } from "../globals/app-state.slint";
import { ScrollView } from "std-widgets.slint";

component SourceRow inherits FocusScope {
  in property <SourceData> source;

  height: 64px;
  width: 100%;

  key-pressed(event) => {
    if event.text == Key.Delete {
      AppState.delete-source(source.id);
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-sm;
    background: root.has-focus ? Theme.surface-glass : transparent;
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-md;

      // Type badge
      Rectangle {
        width: 48px;
        height: 28px;
        border-radius: Theme.radius-sm;
        background: Theme.surface;
        vertical-stretch: 0;

        Text {
          text: source.source-type == "m3u" ? "M3U"
            : source.source-type == "xtream" ? "XC"
            : source.source-type == "stalker" ? "STK"
            : source.source-type;
          color: Theme.accent;
          font-size: Theme.font-size-small;
          font-weight: 700;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
      }

      // Source info
      VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;
        spacing: 2px;

        Text {
          text: source.name;
          color: Theme.text-primary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          overflow: elide;
        }
        HorizontalLayout {
          spacing: Theme.spacing-sm;
          Text {
            text: source.channel-count + " channels";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
          Text {
            text: "·";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
          Text {
            text: source.vod-count + " VOD";
            color: Theme.text-secondary;
            font-size: Theme.font-size-small;
          }
        }
      }

      // Sync button
      Rectangle {
        width: 32px;
        height: 32px;
        border-radius: 16px;
        background: Theme.surface;
        vertical-stretch: 0;

        Text {
          text: "🔄";
          font-size: 16px;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
        TouchArea {
          clicked => { AppState.sync-source(source.id); }
        }
      }

      // Delete button
      Rectangle {
        width: 32px;
        height: 32px;
        border-radius: 16px;
        background: Theme.surface;
        vertical-stretch: 0;

        Text {
          text: "🗑";
          font-size: 16px;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
        TouchArea {
          clicked => { AppState.delete-source(source.id); }
        }
      }
    }
  }
}

export component SettingsScreen inherits Rectangle {
  background: transparent;

  ScrollView {
    VerticalLayout {
      padding-top: Theme.screen-padding-top;
      padding-left: Theme.spacing-xl;
      padding-right: Theme.spacing-xl;
      padding-bottom: Theme.spacing-xl;
      spacing: Theme.spacing-lg;

      // Header
      Text {
        text: "Settings";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
      }

      // Sources section
      Rectangle {
        border-radius: 12px;
        background: rgba(28, 28, 32, 0.8);
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);

        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-sm;

          HorizontalLayout {
            Text {
              text: "Sources";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              font-weight: 600;
              horizontal-stretch: 1;
              vertical-alignment: center;
            }

            // Add source button
            FocusScope {
              width: 100px;
              height: 32px;
              key-pressed(event) => {
                if event.text == Key.Return {
                  AppState.show-source-dialog = true;
                  return accept;
                }
                return reject;
              }
              Rectangle {
                width: 100%; height: 100%;
                border-radius: Theme.radius-sm;
                background: #FFFFFF;
                border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
                border-color: Theme.focus-ring;
                Text {
                  text: "+ Add";
                  color: #000000;
                  font-size: Theme.font-size-caption;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }
                TouchArea {
                  clicked => { AppState.show-source-dialog = true; }
                }
              }
            }
          }

          if AppState.sources.length == 0: Text {
            text: "No sources configured. Add an IPTV source or media server to get started.";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
          }

          for src in AppState.sources: SourceRow {
            source: src;
          }
        }
      }

      // Appearance section
      Rectangle {
        border-radius: 12px;
        background: rgba(28, 28, 32, 0.8);
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);

        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-md;

          Text {
            text: "Appearance";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }

          // Theme selector
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Theme";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            HorizontalLayout {
              spacing: Theme.spacing-xs;
              for item[idx] in [
                { label: "System", mode: 0 },
                { label: "Dark", mode: 1 },
                { label: "Light", mode: 2 },
              ]: FocusScope {
                width: 72px;
                height: 32px;
                key-pressed(event) => {
                  if event.text == Key.Return {
                    Theme.theme-mode = item.mode;
                    AppState.set-theme(item.mode);
                    return accept;
                  }
                  return reject;
                }
                Rectangle {
                  width: 100%; height: 100%;
                  border-radius: Theme.radius-pill;
                  background: Theme.theme-mode == item.mode ? Theme.accent : rgba(255, 255, 255, 0.15);
                  border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
                  border-color: Theme.focus-ring;
                  Text {
                    text: item.label;
                    color: Theme.theme-mode == item.mode ? #FFFFFF : rgba(255, 255, 255, 0.60);
                    font-size: Theme.font-size-small;
                    font-weight: 500;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                  }
                  TouchArea {
                    clicked => {
                      Theme.theme-mode = item.mode;
                      AppState.set-theme(item.mode);
                    }
                  }
                }
              }
            }
          }

          // Language row
          HorizontalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Language";
              color: Theme.text-primary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
              horizontal-stretch: 1;
            }
            Text {
              text: AppState.active-language == "en" ? "English"
                : AppState.active-language == "ar" ? "العربية"
                : AppState.active-language == "de" ? "Deutsch"
                : AppState.active-language == "fr" ? "Français"
                : AppState.active-language == "es" ? "Español"
                : "English";
              color: Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              vertical-alignment: center;
            }
          }
        }
      }

      // About
      Rectangle {
        border-radius: 12px;
        background: rgba(28, 28, 32, 0.8);
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);
        VerticalLayout {
          padding: Theme.spacing-md;
          spacing: Theme.spacing-sm;
          Text {
            text: "About";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }
          Text {
            text: "CrispyTivi v0.1.1";
            color: Theme.text-secondary;
            font-size: Theme.font-size-caption;
          }
          Text {
            text: "Cross-platform IPTV & media player";
            color: Theme.text-secondary;
            font-size: Theme.font-size-caption;
          }
        }
      }
    }
  }
}
