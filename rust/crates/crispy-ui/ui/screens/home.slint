import { Theme } from "../globals/theme.slint";
import { AppState, ChannelData, VodData, ContinueWatchingData } from "../globals/app-state.slint";
import { EmptyState } from "../components/empty-state.slint";
import { VodCard } from "../components/vod-card.slint";
import { LoadingIndicator } from "../components/loading-indicator.slint";
import { IconPlay, IconTv } from "../components/icons.slint";
import { ChannelPill } from "../components/channel-pill.slint";
import { SectionHeader } from "../components/section-header.slint";
import { ActionButton } from "../components/action-button.slint";
import { GettingStartedCard } from "../components/getting-started-card.slint";
import { ScrollView } from "std-widgets.slint";

// Dynamic hero — shown when hero-items is populated
component HeroDynamic inherits Rectangle {
  property <int> idx: AppState.hero-index;

  // M-009: auto-advance hero every 8 seconds
  Timer {
    interval: 8s;
    running: AppState.hero-items.length > 1;
    triggered => {
      AppState.hero-index = Math.mod(AppState.hero-index + 1, AppState.hero-items.length);
    }
  }
  property <string> hero-id: AppState.hero-items[idx].id;
  property <string> hero-title: AppState.hero-items[idx].title;
  property <string> hero-subtitle: AppState.hero-items[idx].subtitle;
  property <bool> hero-live: AppState.hero-items[idx].is-live;
  property <image> hero-backdrop: AppState.hero-items[idx].backdrop;

  min-height: 280px;
  clip: true;

  // Backdrop image — edge-to-edge
  Image {
    source: root.hero-backdrop;
    image-fit: cover;
    width: 100%;
    height: 100%;
  }

  // Gradient overlay: transparent top → dark bottom for text readability
  Rectangle {
    width: 100%;
    height: 100%;
    background: @linear-gradient( // token: Theme.background (gradient stops — cannot use token in @linear-gradient)
      180deg,
      rgba(0, 0, 0, 0.0) 0%,
      rgba(10, 10, 12, 0.35) 40%,
      rgba(10, 10, 12, 0.85) 75%,
      rgba(10, 10, 12, 0.97) 100%
    );
  }

  // Content — bottom-aligned
  VerticalLayout {
    padding-left: Theme.content-padding-h;
    padding-right: Theme.content-padding-h;
    padding-bottom: Theme.spacing-2xl;
    alignment: end;
    spacing: Theme.spacing-sm;

    // LIVE badge
    if root.hero-live: Rectangle {
      width: 62px;
      height: 26px;
      border-radius: Theme.radius-pill;
      background: Theme.brand-gradient;

      Text {
        text: "LIVE";
        color: Theme.btn-secondary-fg;
        font-family: Theme.font-display;
        font-size: Theme.font-size-small;
        font-weight: 700;
        letter-spacing: 1.5px;
        vertical-alignment: center;
        horizontal-alignment: center;
      }
    }

    // Title
    Text {
      text: root.hero-title;
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-hero;
      font-weight: 800;
      wrap: word-wrap;
      overflow: elide;
    }

    // Subtitle
    Text {
      text: root.hero-subtitle;
      color: Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-body;
      wrap: word-wrap;
      overflow: elide;
    }

    // Action buttons
    HorizontalLayout {
      spacing: Theme.spacing-md;
      alignment: start;
      padding-top: Theme.spacing-sm;

      ActionButton {
        label: "▶  Play";
        is-primary: true;
        width: 148px;
        clicked => { AppState.hero-play(root.hero-id); }
      }

      ActionButton {
        label: "More Info";
        is-primary: false;
        width: 148px;
        clicked => { AppState.hero-detail(root.hero-id); }
      }
    }

    // Dot indicators showing active hero item
    HorizontalLayout {
      spacing: Theme.spacing-xs;
      alignment: start;
      padding-top: Theme.spacing-sm;

      for i in AppState.hero-items.length: Rectangle {
        property <bool> active: i == AppState.hero-index;
        width: active ? 24px : 8px;
        height: 8px;
        border-radius: Theme.radius-pill;
        background: active ? Theme.text-primary : Theme.border-subtle;

        animate width { duration: 200ms; easing: ease-in-out; }
        animate background { duration: 200ms; easing: ease-in-out; }
      }
    }
  }
}

// Static fallback hero — shown when hero-items is empty
component HeroStatic inherits Rectangle {
  min-height: 280px;
  background: @linear-gradient(135deg, rgba(255, 75, 43, 0.2) 0%, rgba(10, 10, 12, 0.95) 60%, rgba(255, 65, 108, 0.1) 100%); // token: Theme.background (gradient stops — cannot use token in @linear-gradient)

  VerticalLayout {
    padding-left: Theme.content-padding-h;
    padding-right: Theme.content-padding-h;
    padding-bottom: Theme.spacing-xl;
    alignment: end;
    spacing: Theme.spacing-sm;

    Text {
      text: "CrispyTivi";
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-hero;
      font-weight: 800;
    }
    Text {
      text: "Your unified streaming experience";
      color: Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-body;
    }
  }
}

// Continue Watching card — shows poster + progress bar (J-17/J-21)
component ContinueWatchingCard inherits FocusScope {
  in property <ContinueWatchingData> item;
  callback clicked();

  width: 180px;
  height: 120px;

  key-pressed(event) => {
    if event.text == Key.Return { root.clicked(); return accept; }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: Theme.radius-md;
    clip: true;
    border-width: root.has-focus ? Theme.focus-ring-width : 1px;
    border-color: root.has-focus ? Theme.focus-ring : Theme.card-border;
    background: Theme.card-surface;

    animate border-color { duration: 150ms; }
    animate border-width { duration: 150ms; }

    // Poster image
    Image {
      source: root.item.poster;
      image-fit: cover;
      width: 100%; height: 100%;
    }

    // Gradient overlay for title legibility
    Rectangle {
      width: 100%; height: 50%;
      y: parent.height / 2;
      background: @linear-gradient(180deg, rgba(0,0,0,0.0) 0%, rgba(10,10,12,0.85) 100%);
    }

    // Title
    Text {
      x: Theme.spacing-sm;
      y: root.height - 34px;
      width: root.width - Theme.spacing-sm * 2;
      text: root.item.title;
      color: Theme.text-primary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-small;
      font-weight: 600;
      overflow: elide;
    }

    // Progress bar — accent strip at bottom
    Rectangle {
      x: 0px; y: root.height - Theme.progress-bar-height;
      width: root.width * root.item.progress;
      height: Theme.progress-bar-height;
      background: Theme.brand-gradient;
    }

    TouchArea { clicked => { root.clicked(); } }
  }
}

export component HomeScreen inherits Rectangle {
  background: transparent;

  // M-034: Escape on Home is a no-op — we're already here; navigating to 0
  // would trigger an unnecessary reload. Other screens handle their own escape.
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.Escape {
        return accept; // consume the key without re-navigating (m-012 fix)
      }
      return reject;
    }
  }

  if AppState.sources.length == 0: EmptyState {
    title: "Welcome to CrispyTivi";
    subtitle: "Add a source to get started with live TV, movies, and series.";
    cta-text: "Add Source";
    cta-clicked => {
      AppState.active-screen = 6;
      AppState.navigate(6);
    }
    IconTv { size: 32px; fill: Theme.text-secondary; }
  }

  if AppState.sources.length > 0: ScrollView {
    VerticalLayout {
      padding-top: Theme.screen-padding-top;
      padding-left: 0px;
      padding-right: 0px;
      padding-bottom: Theme.button-legend-clearance; // clear ButtonLegend bar
      spacing: Theme.spacing-xl;

      // Hero — dynamic or static fallback
      if AppState.hero-items.length > 0: HeroDynamic {}
      if AppState.hero-items.length == 0: HeroStatic {}

      // Continue Watching lane (J-17/J-21)
      if AppState.continue-watching-items.length > 0: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-md;

        SectionHeader { title: "Continue Watching"; }

        ScrollView {
          height: 128px;
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: start;
            for cw-item in AppState.continue-watching-items: ContinueWatchingCard {
              item: cw-item;
              clicked => { AppState.play-vod(cw-item.id); }
            }
          }
        }
      }

      // Recent channels
      if AppState.home-channels.length > 0: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-md;

        SectionHeader {
          title: "Live Channels";
          see-all => {
            AppState.active-screen = 1;
            AppState.navigate(1);
          }
        }

        ScrollView {
          height: 70px;
          HorizontalLayout {
            spacing: Theme.spacing-sm;
            alignment: start;
            for ch in AppState.home-channels: ChannelPill {
              channel: ch;
              clicked => { AppState.play-channel(ch.id); }
            }
          }
        }
      }

      // Movies row
      if AppState.home-movies.length > 0: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-md;

        SectionHeader {
          title: "Movies";
          see-all => {
            AppState.active-screen = 3;
            AppState.navigate(3);
          }
        }

        ScrollView {
          height: 310px;
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: start;
            for movie in AppState.home-movies: VodCard {
              item: movie;
              clicked => { AppState.play-vod(movie.id); }
            }
          }
        }
      }

      // Series row
      if AppState.home-series.length > 0: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-md;

        SectionHeader {
          title: "Series";
          see-all => {
            AppState.active-screen = 4;
            AppState.navigate(4);
          }
        }

        ScrollView {
          height: 310px;
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: start;
            for show in AppState.home-series: VodCard {
              item: show;
              clicked => { AppState.play-vod(show.id); }
            }
          }
        }
      }

      // Getting Started checklist — shown until all steps complete or dismissed
      if !AppState.getting-started-dismissed: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: 0px;

        GettingStartedCard { }
      }
    }
  }
}
