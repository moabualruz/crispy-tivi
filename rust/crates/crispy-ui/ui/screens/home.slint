import { Theme } from "../globals/theme.slint";
import { AppState, ChannelData, VodData } from "../globals/app-state.slint";
import { EmptyState } from "../components/empty-state.slint";
import { VodCard } from "../components/vod-card.slint";
import { LoadingIndicator } from "../components/loading-indicator.slint";
import { IconPlay, IconTv } from "../components/icons.slint";
import { ChannelPill } from "../components/channel-pill.slint";
import { SectionHeader } from "../components/section-header.slint";
import { ScrollView } from "std-widgets.slint";

export component HomeScreen inherits Rectangle {
  background: transparent;

  if AppState.sources.length == 0: EmptyState {
    title: "Welcome to CrispyTivi";
    subtitle: "Add a source to get started with live TV, movies, and series.";
    cta-text: "Add Source";
    cta-clicked => {
      AppState.active-screen = 6;
      AppState.navigate(6);
    }
    IconTv { size: 32px; fill: Theme.text-secondary; }
  }

  if AppState.sources.length > 0: ScrollView {
    VerticalLayout {
      padding-top: Theme.screen-padding-top;
      padding-left: 0px;
      padding-right: 0px;
      padding-bottom: Theme.spacing-xl;
      spacing: Theme.spacing-xl;

      // Hero area — edge-to-edge
      Rectangle {
        min-height: 400px;
        background: @linear-gradient(135deg, rgba(255, 75, 43, 0.2) 0%, rgba(10, 10, 12, 0.95) 60%, rgba(255, 65, 108, 0.1) 100%);

        VerticalLayout {
          padding-left: Theme.content-padding-h;
          padding-right: Theme.content-padding-h;
          padding-bottom: Theme.spacing-xl;
          alignment: end;
          spacing: Theme.spacing-sm;

          Text {
            text: "CrispyTivi";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-hero;
            font-weight: 800;
          }
          Text {
            text: "Your unified streaming experience";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
          }
        }
      }

      // Recent channels
      if AppState.channels.length > 0: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-md;

        SectionHeader {
          title: "Live Channels";
          see-all => {
            AppState.active-screen = 1;
            AppState.navigate(1);
          }
        }

        ScrollView {
          height: 70px; // Accommodate 48px Pill + dropshadows/focus rings
          HorizontalLayout {
            spacing: Theme.spacing-sm;
            alignment: start;
            for ch[idx] in AppState.channels: ChannelPill {
              visible: idx < 20; // Increased limit because it's now scrollable natively!
              channel: ch;
              clicked => { AppState.play-channel(ch.id); }
            }
          }
        }
      }

      // Movies row
      if AppState.movies.length > 0: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-md;

        SectionHeader {
          title: "Movies";
          see-all => {
            AppState.active-screen = 3;
            AppState.navigate(3);
          }
        }

        ScrollView {
          height: 310px; // Accommodate 280px VodCard + focus dropshadows
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: start;
            for movie[idx] in AppState.movies: VodCard {
              visible: idx < 20;
              item: movie;
              clicked => { AppState.play-channel(movie.id); }
            }
          }
        }
      }

      // Series row
      if AppState.series.length > 0: VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        spacing: Theme.spacing-md;

        SectionHeader {
          title: "Series";
          see-all => {
            AppState.active-screen = 4;
            AppState.navigate(4);
          }
        }

        ScrollView {
          height: 310px; // Accommodate 280px VodCard + focus dropshadows
          HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: start;
            for show[idx] in AppState.series: VodCard {
              visible: idx < 20;
              item: show;
              clicked => { AppState.play-channel(show.id); }
            }
          }
        }
      }
    }
  }
}
