import { Theme } from "../globals/theme.slint";
import { AppState, VodData, ChannelData, WatchHistoryData } from "../globals/app-state.slint";
import { EmptyState } from "../components/empty-state.slint";
import { FilterChip } from "../components/filter-chip.slint";
import { VodCard } from "../components/vod-card.slint";
import { ChannelCard } from "../components/channel-card.slint";
import { ScrollView } from "std-widgets.slint";
import { IconStar, IconTv } from "../components/icons.slint";

export component LibraryScreen inherits Rectangle {
  width: 100%; height: 100%;
  background: transparent;

  // Escape → navigate to Home
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.Escape {
        AppState.navigate(0);
        return accept;
      }
      return reject;
    }
  }

  // Active library tab: 0=Favorites 1=Watchlist 2=Recordings 3=History
  property <int> active-tab: 0;

  VerticalLayout {
    padding-top: Theme.screen-padding-top;
    spacing: 0px;

    // Header + tab bar
    VerticalLayout {
      padding-left: Theme.content-padding-h;
      padding-right: Theme.content-padding-h;
      padding-bottom: Theme.spacing-md;
      spacing: Theme.spacing-md;

      Text {
        text: "Your Library";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
        font-weight: 700;
      }

      HorizontalLayout {
        spacing: Theme.spacing-xs;

        for tab-info in [
          { idx: 0, label: "Favorites" },
          { idx: 1, label: "Watchlist" },
          { idx: 2, label: "Recordings" },
          { idx: 3, label: "History" },
        ]: FilterChip {
          label: tab-info.label;
          active: root.active-tab == tab-info.idx;
          activated => { root.active-tab = tab-info.idx; }
        }
      }
    }

    // ── Favorites tab ──────────────────────────────────────────────────────
    if root.active-tab == 0: Rectangle {
      vertical-stretch: 1;

      // Empty state — shown only when both lists are empty
      if AppState.favorite-channels.length == 0 && AppState.favorite-vod.length == 0: EmptyState {
        title: "No favorites yet";
        subtitle: "Star channels and movies to find them here quickly.";
        cta-text: "Browse Live TV";
        cta-clicked => {
          AppState.active-screen = 1;
          AppState.navigate(1);
        }
        IconStar { size: 32px; fill: Theme.text-secondary; }
      }

      // Content — shown when there is at least one favorite
      if AppState.favorite-channels.length > 0 || AppState.favorite-vod.length > 0: ScrollView {
        width: 100%; height: 100%;

        VerticalLayout {
          padding-left: Theme.content-padding-h;
          padding-right: Theme.content-padding-h;
          padding-top: Theme.spacing-lg;
          padding-bottom: Theme.spacing-2xl;
          spacing: Theme.spacing-xl;

          // Favorite channels section
          if AppState.favorite-channels.length > 0: VerticalLayout {
            spacing: Theme.spacing-sm;

            Text {
              text: "Channels";
              color: Theme.text-primary;
              font-family: Theme.font-display;
              font-size: Theme.font-size-h2;
              font-weight: 700;
            }

            HorizontalLayout {
              spacing: Theme.spacing-md;
              for ch in AppState.favorite-channels: ChannelCard {
                channel: ch;
                clicked => { AppState.play-channel(ch.id); }
              }
            }
          }

          // Favorite VOD section
          if AppState.favorite-vod.length > 0: VerticalLayout {
            spacing: Theme.spacing-sm;

            Text {
              text: "Movies & Series";
              color: Theme.text-primary;
              font-family: Theme.font-display;
              font-size: Theme.font-size-h2;
              font-weight: 700;
            }

            HorizontalLayout {
              spacing: Theme.spacing-md;
              for item in AppState.favorite-vod: VodCard {
                item: item;
                clicked => { AppState.open-vod-detail(item.id); }
              }
            }
          }
        }
      }
    }

    // ── Watchlist tab ──────────────────────────────────────────────────────
    if root.active-tab == 1: ScrollView {
      width: 100%;
      vertical-stretch: 1;

      VerticalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        padding-top: Theme.spacing-lg;
        padding-bottom: Theme.spacing-2xl;
        spacing: Theme.spacing-xl;

        if AppState.series.length > 0: VerticalLayout {
          spacing: Theme.spacing-sm;

          Text {
            text: "Series";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          HorizontalLayout {
            spacing: Theme.spacing-md;
            for sr in AppState.series: VodCard {
              item: sr;
              clicked => { AppState.open-series-detail(sr.id); }
            }
          }
        }

        if AppState.series.length == 0: EmptyState {
          title: "Watchlist is empty";
          subtitle: "Add series to your watchlist to track what to watch next.";
          cta-text: "Browse Series";
          cta-clicked => {
            AppState.active-screen = 4;
            AppState.navigate(4);
          }
        }
      }
    }

    // ── Recordings tab ─────────────────────────────────────────────────────
    if root.active-tab == 2: Rectangle {
      vertical-stretch: 1;

      EmptyState {
        title: "No recordings";
        subtitle: "DVR recording is coming in v2. Catchup playback is available on supported channels.";
        cta-text: "View Live TV";
        cta-clicked => {
          AppState.active-screen = 1;
          AppState.navigate(1);
        }
      }
    }

    // ── History tab (J-40) ─────────────────────────────────────────────────
    if root.active-tab == 3: VerticalLayout {
      vertical-stretch: 1;
      spacing: 0px;

      // Header row with Clear button
      HorizontalLayout {
        padding-left: Theme.content-padding-h;
        padding-right: Theme.content-padding-h;
        padding-top: Theme.spacing-lg;
        padding-bottom: Theme.spacing-sm;

        Text {
          text: "Watch History";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: Theme.font-size-h2;
          font-weight: 700;
          horizontal-stretch: 1;
        }

        // Clear History button — visible only when history is non-empty
        if AppState.watch-history.length > 0: Rectangle {
          width: 140px;
          height: 36px;
          border-radius: Theme.radius-md;
          background: Theme.surface-glass;
          border-width: 1px;
          border-color: Theme.focus-ring;

          ta := TouchArea {
            clicked => { AppState.clear-watch-history(); }
          }

          Text {
            text: "Clear History";
            color: ta.has-hover ? Theme.text-primary : Theme.text-secondary;
            font-size: Theme.font-size-small;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
        }
      }

      // History list
      if AppState.watch-history.length > 0: ScrollView {
        width: 100%;
        vertical-stretch: 1;

        VerticalLayout {
          padding-left: Theme.content-padding-h;
          padding-right: Theme.content-padding-h;
          padding-bottom: Theme.spacing-2xl;
          spacing: Theme.spacing-sm;

          for entry in AppState.watch-history: Rectangle {
            height: 80px;
            border-radius: Theme.radius-md;
            background: Theme.card-surface;
            border-width: 1px;
            border-color: Theme.surface;

            row-ta := TouchArea {
              clicked => { AppState.play-channel(entry.stream-url); }
            }

            HorizontalLayout {
              padding: Theme.spacing-md;
              spacing: Theme.spacing-md;

              // Content info
              VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                spacing: Theme.spacing-xs;

                Text {
                  text: entry.name;
                  color: Theme.text-primary;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  overflow: elide;
                }

                HorizontalLayout {
                  spacing: Theme.spacing-sm;

                  Text {
                    text: entry.media-type;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-small;
                  }

                  Text {
                    text: "·";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-small;
                  }

                  Text {
                    text: entry.watched-at;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-small;
                  }
                }

                // Progress bar — only for VOD with known duration
                if entry.duration-ms > 0: Rectangle {
                  height: 3px;
                  width: 100%;
                  border-radius: Theme.radius-sm;
                  background: Theme.surface;

                  Rectangle {
                    width: parent.width * entry.progress;
                    height: parent.height;
                    border-radius: Theme.radius-sm;
                    background: @linear-gradient(90deg, #FF4B2B, #FF416C);
                  }
                }
              }
            }
          }
        }
      }

      // Empty state when history is empty
      if AppState.watch-history.length == 0: Rectangle {
        vertical-stretch: 1;

        EmptyState {
          title: "No watch history";
          subtitle: "Content you watch will appear here for easy resuming.";
          cta-text: "Browse Live TV";
          cta-clicked => {
            AppState.active-screen = 1;
            AppState.navigate(1);
          }
          IconTv { size: 32px; fill: Theme.text-secondary; }
        }
      }
    }
  }
}
