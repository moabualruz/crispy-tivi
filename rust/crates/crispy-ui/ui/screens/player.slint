import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { IconPlay, IconPause, IconSettings, IconVolumeUp, IconVolumeMute, IconBack } from "../components/icons.slint";

// Player state exposed from Rust
export global PlayerState {
  in-out property <bool> is-playing: false;
  in-out property <bool> is-paused: false;
  in-out property <bool> is-buffering: false;
  in-out property <bool> is-fullscreen: false;
  in-out property <string> current-title: "";
  in-out property <string> current-group: "";
  in-out property <string> current-channel-id: "";
  in-out property <float> position: 0.0;
  in-out property <float> duration: 0.0;
  in-out property <float> volume: 1.0;
  in-out property <bool> is-muted: false;
  in-out property <bool> show-osd: true;
  in-out property <bool> is-live: true;

  // OSD auto-hide timer managed by Rust
  callback play-pause();
  callback stop();
  callback seek(/* position */ float);
  callback set-volume(/* volume */ float);
  callback toggle-mute();
  callback show-controls();
}

// OSD circular button — 50px per design spec
component OsdButton inherits FocusScope {
  in property <length> btn-size: 50px;
  callback activated();

  width: btn-size;
  height: btn-size;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.activated();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: btn-size / 2;
    background: rgba(255, 255, 255, 0.15);
    border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    animate background { duration: 150ms; }

    @children

    TouchArea { clicked => { root.activated(); } }
  }
}

component VolumeSlider inherits FocusScope {
  width: 120px;
  height: 16px;

  key-pressed(event) => {
    if event.text == Key.RightArrow {
      PlayerState.set-volume(min(1.0, PlayerState.volume + 0.05));
      return accept;
    } else if event.text == Key.LeftArrow {
      PlayerState.set-volume(max(0.0, PlayerState.volume - 0.05));
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 120px;
    height: 4px;
    y: (parent.height - self.height) / 2;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.3);
    border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    Rectangle {
      x: 0;
      width: parent.width * PlayerState.volume;
      height: 100%;
      border-radius: 2px;
      background: #FFFFFF;

      animate width { duration: 100ms; }
    }

    TouchArea {
      clicked => {
        PlayerState.set-volume(self.mouse-x / parent.width);
      }
    }
  }
}

component SeekBar inherits FocusScope {
  // Razor-thin line that expands on focus/hover (per design spec)
  height: (root.has-focus || seek-area.has-hover) ? 16px : 8px;

  animate height { duration: 150ms; easing: ease-out; }

  // Left/Right D-pad: seek by 10 seconds
  key-pressed(event) => {
    if event.text == Key.RightArrow {
      if PlayerState.duration > 0 {
        PlayerState.seek(min(PlayerState.duration, PlayerState.position + 10.0));
      }
      return accept;
    } else if event.text == Key.LeftArrow {
      if PlayerState.duration > 0 {
        PlayerState.seek(max(0.0, PlayerState.position - 10.0));
      }
      return accept;
    }
    return reject;
  }

  inner := Rectangle {
    width: 100%;
    height: root.has-focus ? 8px : 3px;
    y: (parent.height - self.height) / 2;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.2);
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: Theme.focus-ring;

    animate height { duration: 150ms; easing: ease-out; }

    // Progress fill
    Rectangle {
      x: 0;
      width: PlayerState.duration > 0 ? parent.width * (PlayerState.position / PlayerState.duration) : 0;
      height: 100%;
      border-radius: 2px;
      background: Theme.accent-gradient;
    }

    // Seek knob (visible on focus/hover)
    if PlayerState.duration > 0 && (root.has-focus || seek-area.has-hover): Rectangle {
      x: parent.width * (PlayerState.position / PlayerState.duration) - 7px;
      y: (parent.height - 14px) / 2;
      width: 14px;
      height: 14px;
      border-radius: 7px;
      background: #FFFFFF;
    }

    seek-area := TouchArea {
      clicked => {
        if PlayerState.duration > 0 {
          PlayerState.seek(self.mouse-x / parent.width * PlayerState.duration);
        }
      }
    }
  }
}

// M-022: Secondary OSD tray — pill buttons for Audio / Subs / Speed / PiP
component OsdTray inherits Rectangle {
  in property <bool> visible-tray: false;

  height: visible-tray ? 64px : 0px;
  clip: true;
  background: transparent;
  animate height { duration: 200ms; easing: ease-in-out; }

  HorizontalLayout {
    alignment: center;
    spacing: Theme.spacing-md;
    padding: Theme.spacing-sm;

    Rectangle {
      width: audio-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: Theme.surface-glass;
      border-width: 1px;
      border-color: rgba(255, 255, 255, 0.2);
      audio-lbl := Text {
        text: "Audio";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { PlayerState.show-controls(); } }
    }

    Rectangle {
      width: subs-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: Theme.surface-glass;
      border-width: 1px;
      border-color: rgba(255, 255, 255, 0.2);
      subs-lbl := Text {
        text: "Subs";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { PlayerState.show-controls(); } }
    }

    Rectangle {
      width: speed-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: Theme.surface-glass;
      border-width: 1px;
      border-color: rgba(255, 255, 255, 0.2);
      speed-lbl := Text {
        text: "1x";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { PlayerState.show-controls(); } }
    }

    Rectangle {
      width: pip-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: Theme.surface-glass;
      border-width: 1px;
      border-color: rgba(255, 255, 255, 0.2);
      pip-lbl := Text {
        text: "PiP";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { PlayerState.show-controls(); } }
    }
  }
}

component OsdControls inherits Rectangle {
  // M-022: secondary tray toggle state
  property <bool> show-tray: false;

  // M-022: Down opens tray, Up closes — inner FocusScope (Rectangle has no key-pressed)
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.DownArrow && !root.show-tray {
        root.show-tray = true;
        return accept;
      }
      if event.text == Key.UpArrow && root.show-tray {
        root.show-tray = false;
        return accept;
      }
      return reject;
    }
  }

  // Gradient overlay at bottom
  Rectangle {
    y: parent.height - 240px;
    height: 240px;
    width: parent.width;
    background: @linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.85) 100%);
  }

  // M-023: Live EPG mini-strip — current programme + progress bar + "Next" label
  if PlayerState.is-live: HorizontalLayout {
    y: 0;
    x: Theme.content-padding-h;
    width: parent.width - Theme.content-padding-h * 2;
    height: 48px;
    alignment: start;
    spacing: Theme.spacing-md;

    Text {
      text: PlayerState.current-title;
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-caption;
      font-weight: 700;
      vertical-alignment: center;
      overflow: elide;
      horizontal-stretch: 1;
    }

    Rectangle {
      width: 120px;
      height: 4px;
      y: (parent.height - 4px) / 2;
      border-radius: 2px;
      background: rgba(255, 255, 255, 0.2);
      Rectangle {
        x: 0;
        width: PlayerState.duration > 0.0
          ? parent.width * (PlayerState.position / PlayerState.duration)
          : 0px;
        height: 100%;
        border-radius: 2px;
        background: Theme.accent-gradient;
      }
    }

    Text {
      text: "Next";
      color: Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-small;
      vertical-alignment: center;
    }
  }

  // Metadata (Top left of the OSD area)
  HorizontalLayout {
    y: parent.height - 180px;
    x: Theme.content-padding-h;
    width: parent.width - Theme.content-padding-h * 2;
    alignment: start;
    spacing: Theme.spacing-md;

    if PlayerState.is-live: Rectangle {
      width: 48px;
      height: 22px;
      border-radius: 4px;
      background: Theme.live-badge;
      y: 4px;
      Text {
        text: "LIVE";
        color: #FFFFFF;
        font-family: Theme.font-display;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }

    VerticalLayout {
      spacing: 4px;
      Text {
        text: PlayerState.current-title;
        color: #FFFFFF;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
        font-weight: 700;
      }
      if PlayerState.current-group != "": Text {
        text: PlayerState.current-group;
        color: rgba(255, 255, 255, 0.7);
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
      }
    }
  }

  // Transport controls (Center)
  HorizontalLayout {
    y: parent.height - 100px;
    width: parent.width;
    alignment: center;
    spacing: Theme.spacing-xl;

    // Back / Stop button — exits playback and returns to browsing
    OsdButton {
      btn-size: 48px;
      activated => { PlayerState.stop(); }
      IconBack { size: 24px; fill: #FFFFFF; }
    }

    OsdButton {
      btn-size: 48px;
      activated => { /* Open settings */ }
      IconSettings { size: 24px; fill: #FFFFFF; }
    }

    // Play/Pause (Larger central button)
    OsdButton {
      btn-size: 64px;
      activated => { PlayerState.play-pause(); }
      VerticalLayout {
        alignment: center;
        HorizontalLayout {
          alignment: center;
          if PlayerState.is-paused: IconPlay { size: 32px; fill: #FFFFFF; }
          if !PlayerState.is-paused: IconPause { size: 32px; fill: #FFFFFF; }
        }
      }
    }

    OsdButton {
      btn-size: 48px;
      activated => { PlayerState.is-fullscreen = !PlayerState.is-fullscreen; }
      Text { text: PlayerState.is-fullscreen ? "><" : "<>"; color: #FFFFFF; font-size: 18px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
    }
  }

  // Volume slider (Bottom right)
  HorizontalLayout {
    y: parent.height - 80px;
    x: parent.width - Theme.content-padding-h - 200px;
    width: 200px;
    spacing: Theme.spacing-md;
    alignment: end;

    OsdButton {
      btn-size: 40px;
      activated => { PlayerState.toggle-mute(); }
      VerticalLayout {
        alignment: center;
        HorizontalLayout {
          alignment: center;
          if PlayerState.is-muted: IconVolumeMute { size: 20px; fill: #FFFFFF; }
          if !PlayerState.is-muted: IconVolumeUp { size: 20px; fill: #FFFFFF; }
        }
      }
    }
    VerticalLayout {
      alignment: center;
      VolumeSlider {}
    }
  }

  // Seek bar (Absolute bottom edge for VOD)
  if !PlayerState.is-live: SeekBar {
    y: parent.height - self.height;
    width: parent.width;
  }

  // M-022: Secondary tray slides up from bottom
  OsdTray {
    y: parent.height - self.height;
    width: parent.width;
    visible-tray: root.show-tray;
  }
}

export component PlayerScreen inherits Rectangle {
  // MUST be transparent — mpv OpenGL underlay renders BEHIND the Slint canvas.
  // An opaque background here covers the video entirely.
  background: transparent;
  width: 100%;
  height: 100%;

  // Video surface area — transparent to let underlay show through
  Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    if PlayerState.is-buffering: VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-sm;

      Text {
        text: "Buffering...";
        color: rgba(255, 255, 255, 0.6);
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
      }
    }
  }

  // Touch/click to show OSD when it's hidden — MUST be before OsdControls so OSD buttons get clicks
  if (PlayerState.is-playing || PlayerState.is-paused) && !PlayerState.show-osd && !PlayerState.is-paused: TouchArea {
    clicked => { PlayerState.show-controls(); }
  }

  // OSD overlay (Layer 2) — auto-hides after 3s when playing (managed by Rust timer)
  // Always visible when paused so user can resume or exit
  if (PlayerState.is-playing || PlayerState.is-paused) && (PlayerState.show-osd || PlayerState.is-paused): OsdControls {
    width: 100%;
    height: 100%;
  }
}
