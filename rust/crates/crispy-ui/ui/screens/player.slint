import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { IconPlay, IconPause, IconSettings, IconVolumeUp, IconVolumeMute, IconBack } from "../components/icons.slint";

// Player state exposed from Rust
export global PlayerState {
  in-out property <bool> is-playing: false;
  in-out property <bool> is-paused: false;
  in-out property <bool> is-buffering: false;
  in-out property <bool> is-fullscreen: false;
  in-out property <string> current-title: "";
  in-out property <string> current-group: "";
  in-out property <string> current-channel-id: "";
  in-out property <float> position: 0.0;       // seconds (current position)
  in-out property <float> duration: 0.0;       // seconds (total duration, 0 for live)
  in-out property <float> buffered: 0.0;       // 0.0–1.0 fraction of total buffered ahead
  in-out property <float> volume: 1.0;
  in-out property <bool> is-muted: false;
  in-out property <bool> show-osd: true;
  in-out property <bool> is-live: true;
  // Channel info for live strip (set by Rust alongside current-title)
  in-out property <string> current-programme: "";  // current EPG programme title
  in-out property <string> channel-logo-url: "";   // URL for channel logo image

  // OSD auto-hide timer managed by Rust (Rust sets show-osd=false after 3s)
  callback play-pause();
  callback stop();
  callback seek(/* position */ float);
  callback set-volume(/* volume */ float);
  callback toggle-mute();
  callback show-controls();
  callback skip-back();   // Rust handles: seek(position - 10)
  callback skip-forward();// Rust handles: seek(position + 10)

  // 3.9: Quality/resolution badge
  in-out property <string> current-resolution: "";  // e.g. "1080p", "720p", "Auto"

  // 3.11: Skip Intro overlay
  in-out property <bool> show-skip-intro: false;
  callback skip-intro();

  // 3.12: Auto-play next episode countdown
  in-out property <bool> show-next-episode: false;
  in-out property <string> next-episode-title: "";
  in-out property <int> next-countdown: 10;
  callback play-next();
  callback cancel-next();

  // 3.13: Still Watching prompt
  in-out property <bool> show-still-watching: false;
  callback dismiss-still-watching();

  // 3.14: Post-play screen
  in-out property <bool> show-post-play: false;
  in-out property <string> post-play-next-title: "";
  callback post-play-play();
  callback post-play-back();

  // 3.15: Audio + Subtitles panel
  in-out property <bool> show-tracks-panel: false;
  callback toggle-tracks-panel();
  // Track label models populated by Rust via VecModel
  in-out property <[string]> audio-track-labels;
  in-out property <int> active-audio-track: 0;
  in-out property <[string]> subtitle-track-labels;
  in-out property <int> active-subtitle-track: 0;
  callback select-audio-track(/* index */ int);
  callback select-subtitle-track(/* index */ int);

  // M-037: Fullscreen toggle (notifies Rust)
  callback toggle-fullscreen();

  // M-038: Cycle to next audio track
  callback next-audio-track();

  // M-039: Cycle to next subtitle track
  callback next-subtitle-track();

  // M-040: Playback speed control
  in-out property <float> current-speed: 1.0;
  callback set-speed(/* speed */ float);

  // M-018: Toggle secondary controls tray
  in-out property <bool> show-secondary-controls: false;
  callback toggle-secondary-controls();
}

// ─── Helpers ─────────────────────────────────────────────────────────────────

// ─── OsdButton ───────────────────────────────────────────────────────────────

// Circular 50px glass button — D-pad navigable
component OsdButton inherits FocusScope {
  in property <length> btn-size: 50px;
  callback activated();

  width: btn-size;
  height: btn-size;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.activated();
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    border-radius: btn-size / 2;
    background: parent.has-focus ? Theme.focus-bg : Theme.btn-secondary-bg;
    border-width: parent.has-focus ? Theme.focus-ring-width : 1px;
    border-color: parent.has-focus ? Theme.focus-ring : Theme.border-subtle;

    animate background { duration: 150ms; }
    animate border-width { duration: 150ms; }

    @children

    TouchArea { clicked => { root.activated(); } }
  }
}

// ─── VolumeSlider ─────────────────────────────────────────────────────────────

component VolumeSlider inherits FocusScope {
  width: 120px;
  height: 16px;

  key-pressed(event) => {
    if event.text == Key.RightArrow {
      PlayerState.set-volume(min(1.0, PlayerState.volume + 0.05));
      return accept;
    } else if event.text == Key.LeftArrow {
      PlayerState.set-volume(max(0.0, PlayerState.volume - 0.05));
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 120px;
    height: 4px;
    y: (parent.height - self.height) / 2;
    border-radius: Theme.radius-2xs;
    background: Theme.focus-glow;
    border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
    border-color: parent.has-focus ? Theme.focus-ring : transparent;

    animate border-width { duration: 150ms; }

    // Filled portion
    Rectangle {
      x: 0;
      width: parent.width * PlayerState.volume;
      height: 100%;
      border-radius: Theme.radius-2xs;
      background: Theme.focus-ring;
      animate width { duration: 100ms; }
    }

    TouchArea {
      clicked => {
        PlayerState.set-volume(self.mouse-x / parent.width);
      }
    }
  }
}

// ─── VolumeIndicator ─────────────────────────────────────────────────────────
// Percentage label — fades in when volume changes, Rust must toggle show-volume-pct
// In practice we keep it always visible beside the slider for simplicity; Rust
// can bind show-osd to hide the whole OSD which hides this too.

component VolumeIndicator inherits Text {
  text: PlayerState.is-muted ? "Muted" : round(PlayerState.volume * 100) + "%";
  color: Theme.text-primary;
  font-family: Theme.font-body;
  font-size: Theme.font-size-caption;
  font-weight: 600;
  vertical-alignment: center;
  width: 44px;
}

// ─── SeekBar (3.6) ───────────────────────────────────────────────────────────
// 3-state seek bar: VOD (brand gradient / dim / buffered-ahead) or
//                   Live (live-edge pulsing dot / buffered / dim track)

component SeekBar inherits FocusScope {
  // Height: 2px collapsed → 6px on focus/hover (design spec: razor-thin)
  property <length> bar-h: (root.has-focus || seek-area.has-hover) ? 6px : 2px;
  height: (root.has-focus || seek-area.has-hover) ? 20px : 8px;

  animate height { duration: 150ms; easing: ease-out; }

  // D-pad left/right: seek ±10s
  key-pressed(event) => {
    if event.text == Key.RightArrow {
      if PlayerState.duration > 0 {
        PlayerState.seek(min(PlayerState.duration, PlayerState.position + 10.0));
      }
      return accept;
    } else if event.text == Key.LeftArrow {
      if PlayerState.duration > 0 {
        PlayerState.seek(max(0.0, PlayerState.position - 10.0));
      }
      return accept;
    }
    return reject;
  }

  track := Rectangle {
    width: 100%;
    height: bar-h;
    y: (parent.height - self.height) / 2;
    border-radius: bar-h / 2;
    background: Theme.focus-glow;
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: root.has-focus ? Theme.focus-ring : transparent;

    animate height { duration: 150ms; easing: ease-out; }
    animate border-width { duration: 150ms; }

    // ── VOD mode ──────────────────────────────────────────────────────────
    if !PlayerState.is-live: Rectangle {
      // Buffered-ahead (slightly brighter than dim track)
      x: 0;
      width: track.width * PlayerState.buffered;
      height: 100%;
      border-radius: bar-h / 2;
      background: Theme.progress-buffered;
    }

    if !PlayerState.is-live: Rectangle {
      // Played portion — brand gradient
      x: 0;
      width: PlayerState.duration > 0
        ? track.width * (PlayerState.position / PlayerState.duration)
        : 0px;
      height: 100%;
      border-radius: bar-h / 2;
      background: Theme.brand-gradient;
      animate width { duration: 80ms; }
    }

    // Seek knob (VOD, focus/hover only)
    if !PlayerState.is-live && PlayerState.duration > 0 && (root.has-focus || seek-area.has-hover): Rectangle {
      property <length> knob-d: 14px;
      x: track.width * (PlayerState.position / PlayerState.duration) - knob-d / 2;
      y: (parent.height - knob-d) / 2;
      width: knob-d;
      height: knob-d;
      border-radius: knob-d / 2;
      background: Theme.focus-ring;
    }

    // ── Live mode ─────────────────────────────────────────────────────────
    if PlayerState.is-live: Rectangle {
      // Buffered portion (from left up to buffered fraction)
      x: 0;
      width: track.width * PlayerState.buffered;
      height: 100%;
      border-radius: bar-h / 2;
      background: Theme.progress-live-buffered;
    }

    // Live edge marker — pulsing dot at the right edge
    if PlayerState.is-live: Rectangle {
      property <bool> pulse-state: false;
      property <float> pulse-opacity: pulse-state ? 1.0 : 0.4;
      property <length> dot-d: max(bar-h + 4px, 8px);

      x: track.width - dot-d / 2;
      y: (parent.height - dot-d) / 2;
      width: dot-d;
      height: dot-d;
      border-radius: dot-d / 2;
      background: Theme.live-badge;
      opacity: pulse-opacity;

      animate opacity { duration: 700ms; easing: ease-in-out; }

      // Trigger the pulse by toggling pulse-state on init / continuously
      // Slint has no setInterval; we chain two animations via init and changed
      init => {
        self.pulse-state = true;
      }
      changed pulse-opacity => {
        self.pulse-state = !self.pulse-state;
      }
    }

    seek-area := TouchArea {
      clicked => {
        if PlayerState.duration > 0 {
          PlayerState.seek(self.mouse-x / parent.width * PlayerState.duration);
        }
      }
    }
  }

  // Time labels below the bar (VOD only — live has no meaningful position text)
  if !PlayerState.is-live && PlayerState.duration > 0: HorizontalLayout {
    y: parent.height - 16px;
    width: 100%;
    alignment: space-between;

    Text {
      text: floor(PlayerState.position / 60) + ":" + (mod(PlayerState.position, 60) < 10 ? "0" : "") + floor(mod(PlayerState.position, 60));
      color: Theme.text-primary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-caption;
      font-weight: 500;
    }

    Text {
      text: floor(PlayerState.duration / 60) + ":" + (mod(PlayerState.duration, 60) < 10 ? "0" : "") + floor(mod(PlayerState.duration, 60));
      color: Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-caption;
      font-weight: 400;
    }
  }
}

// ─── OsdTray (M-022) ─────────────────────────────────────────────────────────
// Secondary tray — pill buttons for Audio / Subs / Speed / PiP

component OsdTray inherits Rectangle {
  in property <bool> visible-tray: false;

  height: visible-tray ? 64px : 0px;
  clip: true;
  background: transparent;
  animate height { duration: 200ms; easing: ease-in-out; }

  HorizontalLayout {
    alignment: center;
    spacing: Theme.spacing-md;
    padding: Theme.spacing-sm;

    // M-038: Audio track cycle button
    Rectangle {
      width: audio-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: PlayerState.show-tracks-panel ? Theme.focus-bg : Theme.surface-glass;
      border-width: 1px;
      border-color: PlayerState.show-tracks-panel ? Theme.focus-ring : Theme.focus-glow;
      audio-lbl := Text {
        text: "Audio";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { PlayerState.next-audio-track(); } }
    }

    // M-039: Subtitle track cycle button
    Rectangle {
      width: subs-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: PlayerState.show-tracks-panel ? Theme.focus-bg : Theme.surface-glass;
      border-width: 1px;
      border-color: PlayerState.show-tracks-panel ? Theme.focus-ring : Theme.focus-glow;
      subs-lbl := Text {
        text: "Subs";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { PlayerState.next-subtitle-track(); } }
    }

    // M-040: Speed cycle button
    Rectangle {
      width: speed-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: Theme.surface-glass;
      border-width: 1px;
      border-color: Theme.focus-glow;
      speed-lbl := Text {
        text: PlayerState.current-speed == 1.0 ? "1x"
            : PlayerState.current-speed == 0.5 ? "0.5x"
            : PlayerState.current-speed == 0.75 ? "0.75x"
            : PlayerState.current-speed == 1.25 ? "1.25x"
            : PlayerState.current-speed == 1.5 ? "1.5x"
            : "2x";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea {
        clicked => {
          // Cycle: 0.5 → 0.75 → 1.0 → 1.25 → 1.5 → 2.0 → 0.5
          if PlayerState.current-speed < 0.6 {
            PlayerState.set-speed(0.75);
          } else if PlayerState.current-speed < 0.8 {
            PlayerState.set-speed(1.0);
          } else if PlayerState.current-speed < 1.1 {
            PlayerState.set-speed(1.25);
          } else if PlayerState.current-speed < 1.3 {
            PlayerState.set-speed(1.5);
          } else if PlayerState.current-speed < 1.6 {
            PlayerState.set-speed(2.0);
          } else {
            PlayerState.set-speed(0.5);
          }
        }
      }
    }

    // PiP button (Epoch 10 — not yet implemented)
    Rectangle {
      width: pip-lbl.preferred-width + Theme.spacing-lg;
      height: 36px;
      border-radius: Theme.radius-pill;
      background: Theme.surface-glass;
      border-width: 1px;
      border-color: Theme.focus-glow;
      pip-lbl := Text {
        text: "PiP";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { PlayerState.toggle-secondary-controls(); } }
    }
  }
}

// ─── OsdControls ─────────────────────────────────────────────────────────────

component OsdControls inherits Rectangle {
  // M-022: secondary tray toggle state
  property <bool> show-tray: false;

  // D-pad Down opens tray, Up closes it
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.DownArrow && !root.show-tray {
        root.show-tray = true;
        return accept;
      }
      if event.text == Key.UpArrow && root.show-tray {
        root.show-tray = false;
        return accept;
      }
      return reject;
    }
  }

  // ── Bottom gradient overlay ───────────────────────────────────────────────
  Rectangle {
    y: parent.height - 260px;
    height: 260px;
    width: parent.width;
    background: @linear-gradient(180deg, transparent 0%, Theme.overlay-heavy 100%);
  }

  // ── Live channel info strip (M-023) ─────────────────────────────────────
  // Top of OSD: channel name + current programme + mini live-progress bar
  if PlayerState.is-live: HorizontalLayout {
    y: 0;
    x: Theme.content-padding-h;
    width: parent.width - Theme.content-padding-h * 2;
    height: 52px;
    alignment: start;
    spacing: Theme.spacing-md;

    // LIVE badge
    Rectangle {
      width: 48px;
      height: 22px;
      border-radius: Theme.radius-xs;
      background: Theme.live-badge;
      y: (52px - 22px) / 2;
      Text {
        text: "LIVE";
        color: Theme.btn-secondary-fg;
        font-family: Theme.font-display;
        font-size: Theme.font-size-micro;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }

    // Channel name
    Text {
      text: PlayerState.current-title;
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-caption;
      font-weight: 700;
      vertical-alignment: center;
      overflow: elide;
      horizontal-stretch: 0;
      max-width: parent.width * 0.35;
    }

    // Current programme title (EPG)
    if PlayerState.current-programme != "": Text {
      text: "· " + PlayerState.current-programme;
      color: Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-caption;
      font-weight: 400;
      vertical-alignment: center;
      overflow: elide;
      horizontal-stretch: 1;
    }

    // Programme mini-progress bar (right side of strip)
    Rectangle {
      width: 100px;
      height: 4px;
      y: (52px - 4px) / 2;
      border-radius: Theme.radius-2xs;
      background: Theme.focus-glow;
      Rectangle {
        x: 0;
        width: PlayerState.duration > 0.0
          ? parent.width * (PlayerState.position / PlayerState.duration)
          : 0px;
        height: 100%;
        border-radius: Theme.radius-2xs;
        background: Theme.brand-gradient;
        animate width { duration: 500ms; }
      }
    }
  }

  // ── Metadata block (title + group, top-left of lower OSD area) ───────────
  HorizontalLayout {
    y: parent.height - 190px;
    x: Theme.content-padding-h;
    width: parent.width - Theme.content-padding-h * 2;
    alignment: start;
    spacing: Theme.spacing-md;

    // Live badge (shown in metadata area only when NOT in live strip mode — i.e. always for live)
    if PlayerState.is-live: Rectangle {
      width: 48px;
      height: 22px;
      border-radius: Theme.radius-xs;
      background: Theme.live-badge;
      y: 6px;
      Text {
        text: "LIVE";
        color: Theme.btn-secondary-fg;
        font-family: Theme.font-display;
        font-size: Theme.font-size-micro;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }

    VerticalLayout {
      spacing: Theme.spacing-xs;
      Text {
        text: PlayerState.current-title;
        color: Theme.btn-secondary-fg;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
        font-weight: 700;
      }
      if PlayerState.current-group != "": Text {
        text: PlayerState.current-group;
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
      }
    }
  }

  // ── Time display (VOD only, above transport row) ──────────────────────────
  if !PlayerState.is-live && PlayerState.duration > 0: HorizontalLayout {
    y: parent.height - 118px;
    x: Theme.content-padding-h;
    width: parent.width - Theme.content-padding-h * 2;
    alignment: space-between;

    Text {
      text: floor(PlayerState.position / 60) + ":" + (mod(PlayerState.position, 60) < 10 ? "0" : "") + floor(mod(PlayerState.position, 60));
      color: Theme.text-primary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-body;
      font-weight: 500;
      vertical-alignment: center;
    }

    Text {
      text: floor(PlayerState.duration / 60) + ":" + (mod(PlayerState.duration, 60) < 10 ? "0" : "") + floor(mod(PlayerState.duration, 60));
      color: Theme.text-secondary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-body;
      font-weight: 400;
      vertical-alignment: center;
    }
  }

  // ── Transport controls row ────────────────────────────────────────────────
  HorizontalLayout {
    y: parent.height - 90px;
    width: parent.width;
    alignment: center;
    spacing: Theme.spacing-xl;

    // Stop / Back
    OsdButton {
      btn-size: 48px;
      activated => { PlayerState.stop(); }
      IconBack { size: 24px; fill: Theme.btn-secondary-fg; }
    }

    // Skip back 10s
    OsdButton {
      btn-size: 48px;
      activated => { PlayerState.skip-back(); }
      Text {
        text: "−10";
        color: Theme.btn-secondary-fg;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }

    // Play/Pause (larger central button)
    OsdButton {
      btn-size: 64px;
      activated => { PlayerState.play-pause(); }
      VerticalLayout {
        alignment: center;
        HorizontalLayout {
          alignment: center;
          if PlayerState.is-paused: IconPlay { size: 32px; fill: Theme.btn-secondary-fg; }
          if !PlayerState.is-paused: IconPause { size: 32px; fill: Theme.btn-secondary-fg; }
        }
      }
    }

    // Skip forward 10s
    OsdButton {
      btn-size: 48px;
      activated => { PlayerState.skip-forward(); }
      Text {
        text: "+10";
        color: Theme.btn-secondary-fg;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }

    // Fullscreen toggle (M-037: notify Rust via callback)
    OsdButton {
      btn-size: 48px;
      activated => { PlayerState.toggle-fullscreen(); }
      Text {
        text: PlayerState.is-fullscreen ? "><" : "<>";
        color: Theme.btn-secondary-fg;
        font-size: Theme.font-size-subtitle;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }

    // Settings
    OsdButton {
      btn-size: 48px;
      activated => { AppState.open-player-settings(); }
      IconSettings { size: 24px; fill: Theme.btn-secondary-fg; }
    }
  }

  // ── Volume row (bottom right) ─────────────────────────────────────────────
  HorizontalLayout {
    y: parent.height - 60px;
    x: parent.width - Theme.content-padding-h - 240px;
    width: 240px;
    spacing: Theme.spacing-sm;
    alignment: end;

    OsdButton {
      btn-size: 40px;
      activated => { PlayerState.toggle-mute(); }
      VerticalLayout {
        alignment: center;
        HorizontalLayout {
          alignment: center;
          if PlayerState.is-muted: IconVolumeMute { size: 20px; fill: Theme.btn-secondary-fg; }
          if !PlayerState.is-muted: IconVolumeUp { size: 20px; fill: Theme.btn-secondary-fg; }
        }
      }
    }

    VerticalLayout {
      alignment: center;
      VolumeSlider {}
    }

    VolumeIndicator {}
  }

  // ── Seek bar (VOD: absolute bottom edge; Live: hidden) ────────────────────
  if !PlayerState.is-live: SeekBar {
    y: parent.height - self.height - 8px;
    x: Theme.content-padding-h;
    width: parent.width - Theme.content-padding-h * 2;
  }

  // ── M-022: Secondary tray slides up from bottom ───────────────────────────
  // M-018: visible-tray driven by both local toggle and Rust-controlled property
  OsdTray {
    y: parent.height - self.height;
    width: parent.width;
    visible-tray: root.show-tray || PlayerState.show-secondary-controls;
  }

  // ── 3.9: Quality/resolution badge (top-right) ─────────────────────────────
  Rectangle {
    x: parent.width - self.width - Theme.content-padding-h;
    y: Theme.spacing-md;
    width: res-label.preferred-width + Theme.spacing-md;
    height: 28px;
    border-radius: Theme.radius-sm;
    background: Theme.surface-glass;
    border-width: 1px;
    border-color: Theme.border-subtle;

    res-label := Text {
      text: PlayerState.current-resolution == "" ? "Auto" : PlayerState.current-resolution;
      color: Theme.text-primary;
      font-family: Theme.font-body;
      font-size: Theme.font-size-small;
      font-weight: 600;
      horizontal-alignment: center;
      vertical-alignment: center;
    }
  }
}

// ─── TrackRow ─────────────────────────────────────────────────────────────────
// Single selectable track entry inside AudioSubtitlePanel

component TrackRow inherits FocusScope {
  in property <string> label: "";
  in property <bool> active: false;
  callback selected();

  height: 48px;
  width: 100%;

  key-pressed(event) => {
    if event.text == Key.Return || event.text == " " {
      root.selected();
      return accept;
    }
    return reject;
  }

  bg := Rectangle {
    width: 100%; height: 100%;
    background: root.has-focus
      ? Theme.focus-bg
      : (root.active ? Theme.surface-highlight : transparent);
    border-width: root.has-focus ? Theme.focus-ring-width : 0px;
    border-color: root.has-focus ? Theme.focus-ring : transparent;
    animate background { duration: 120ms; }
    animate border-width { duration: 120ms; }

    HorizontalLayout {
      padding-left: Theme.spacing-md;
      padding-right: Theme.spacing-md;
      spacing: Theme.spacing-sm;
      alignment: start;

      // Checkmark — visible when active
      Text {
        text: root.active ? "✓" : " ";
        color: Theme.text-primary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        font-weight: 700;
        vertical-alignment: center;
        width: 20px;
      }

      Text {
        text: root.label;
        color: root.active ? Theme.text-primary : Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        font-weight: root.active ? 600 : 400;
        vertical-alignment: center;
        overflow: elide;
        horizontal-stretch: 1;
      }
    }

    TouchArea { clicked => { root.selected(); } }
  }
}

// ─── AudioSubtitlePanel (3.15) ────────────────────────────────────────────────
// Slide-in panel from the right showing audio and subtitle track lists.
// Visibility driven by PlayerState.show-tracks-panel.
// Track data populated via [string] model properties from Rust.

component AudioSubtitlePanel inherits FocusScope {
  in property <length> panel-width: 300px;
  // Panel slides from right edge
  y: 0;
  height: 100%;

  animate x { duration: 220ms; easing: ease-in-out; }

  // Close on Escape
  key-pressed(event) => {
    if event.text == Key.Escape {
      PlayerState.show-tracks-panel = false;
      return accept;
    }
    return reject;
  }

  Rectangle {
    width: 100%; height: 100%;
    background: Theme.surface-glass;
    border-width: 1px;
    border-color: Theme.border-subtle;
    clip: true;

    VerticalLayout {
      padding: Theme.spacing-lg;
      spacing: Theme.spacing-md;

      // ── Audio section ──────────────────────────────────────────────────
      Text {
        text: "Audio";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-body;
        font-weight: 700;
      }

      // Divider
      Rectangle { height: 1px; background: Theme.border-subtle; }

      for track-label[idx] in PlayerState.audio-track-labels: TrackRow {
        label: track-label;
        active: idx == PlayerState.active-audio-track;
        selected => { PlayerState.select-audio-track(idx); }
      }

      if PlayerState.audio-track-labels.length == 0: Text {
        text: "No audio tracks";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 400;
      }

      // ── Subtitles section ──────────────────────────────────────────────
      Rectangle { height: Theme.spacing-sm; background: transparent; }

      Text {
        text: "Subtitles";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-body;
        font-weight: 700;
      }

      // Divider
      Rectangle { height: 1px; background: Theme.border-subtle; }

      for track-label[idx] in PlayerState.subtitle-track-labels: TrackRow {
        label: track-label;
        active: idx == PlayerState.active-subtitle-track;
        selected => { PlayerState.select-subtitle-track(idx); }
      }

      if PlayerState.subtitle-track-labels.length == 0: Text {
        text: "No subtitle tracks";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 400;
      }
    }
  }
}

// ─── PlayerScreen (3.7: opacity-animated OSD) ─────────────────────────────

export component PlayerScreen inherits Rectangle {
  // MUST be transparent — mpv OpenGL underlay renders BEHIND the Slint canvas.
  background: transparent;
  width: 100%;
  height: 100%;


  // Video surface — transparent to let underlay through
  Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    if PlayerState.is-buffering: VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-sm;

      Text {
        text: "Buffering…";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
      }
    }
  }

  // Tap/click on hidden OSD area to reveal controls (only when OSD is hidden)
  if (PlayerState.is-playing || PlayerState.is-paused) && !PlayerState.show-osd: TouchArea {
    clicked => { PlayerState.show-controls(); }
  }

  // ── OSD overlay — 3.7: smooth fade in/out via opacity ────────────────────
  // Opacity is driven by show-osd (Rust sets it to false after 3s inactivity).
  // Fade-in: 0.2s  Fade-out: 0.3s  (separate durations require property trick)
  // Strategy: always render, drive opacity 0→1 / 1→0 so animate works on a
  // single continuous property. interactive is false when opacity==0 so
  // buttons don't intercept clicks while invisible.
  if PlayerState.is-playing || PlayerState.is-paused: Rectangle {
    // 3.7: OSD auto-hide fade animation
    opacity: (PlayerState.show-osd || PlayerState.is-paused) ? 1.0 : 0.0;
    animate opacity {
      duration: (PlayerState.show-osd || PlayerState.is-paused) ? 200ms : 300ms;
      easing: ease-in-out;
    }

    width: 100%;
    height: 100%;
    background: transparent;

    OsdControls {
      width: 100%;
      height: 100%;
    }
  }

  // ── 3.8: "Go Live" pill — timeshift mode only ────────────────────────────
  // Visible when live stream is shifted behind live edge (position < duration - 5)
  if PlayerState.is-live && PlayerState.duration > 0 && PlayerState.position < PlayerState.duration - 5: FocusScope {
    x: parent.width / 2 - self.width / 2;
    y: parent.height - 120px;
    width: go-live-label.preferred-width + Theme.spacing-lg;
    height: 36px;

    key-pressed(event) => {
      if event.text == Key.Return || event.text == " " {
        PlayerState.seek(PlayerState.duration);
        return accept;
      }
      return reject;
    }

    Rectangle {
      width: 100%; height: 100%;
      border-radius: Theme.radius-pill;
      background: parent.has-focus ? Theme.focus-bg : Theme.live-badge;
      border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
      border-color: Theme.focus-ring;
      animate background { duration: 150ms; }
      animate border-width { duration: 150ms; }

      go-live-label := Text {
        text: "● LIVE";
        color: Theme.btn-secondary-fg;
        font-family: Theme.font-display;
        font-size: Theme.font-size-caption;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }

      TouchArea { clicked => { PlayerState.seek(PlayerState.duration); } }
    }
  }

  // ── 3.11: Skip Intro overlay ──────────────────────────────────────────────
  if PlayerState.show-skip-intro: FocusScope {
    x: parent.width - self.width - Theme.content-padding-h;
    y: parent.height - 140px;
    width: skip-intro-label.preferred-width + Theme.spacing-xl;
    height: 44px;

    key-pressed(event) => {
      if event.text == Key.Return || event.text == " " {
        PlayerState.skip-intro();
        return accept;
      }
      return reject;
    }

    Rectangle {
      width: 100%; height: 100%;
      border-radius: Theme.radius-pill;
      background: parent.has-focus ? Theme.focus-bg : Theme.surface-glass;
      border-width: parent.has-focus ? Theme.focus-ring-width : 1px;
      border-color: parent.has-focus ? Theme.focus-ring : Theme.border-subtle;
      animate background { duration: 150ms; }
      animate border-width { duration: 150ms; }

      skip-intro-label := Text {
        text: "Skip Intro ▸";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-body;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }

      TouchArea { clicked => { PlayerState.skip-intro(); } }
    }
  }

  // ── 3.12: Auto-play next episode countdown card ───────────────────────────
  if PlayerState.show-next-episode: Rectangle {
    x: parent.width - self.width - Theme.content-padding-h;
    y: parent.height / 2 - self.height / 2;
    width: 320px;
    height: next-ep-layout.preferred-height + Theme.spacing-xl;
    border-radius: Theme.radius-md;
    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.card-border;

    next-ep-layout := VerticalLayout {
      padding: Theme.spacing-lg;
      spacing: Theme.spacing-sm;

      Text {
        text: "Next Episode";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-caption;
        font-weight: 600;
      }

      Text {
        text: PlayerState.next-episode-title;
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-body;
        font-weight: 700;
        wrap: word-wrap;
      }

      Text {
        text: "Starting in " + PlayerState.next-countdown + "s";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-small;
      }

      HorizontalLayout {
        spacing: Theme.spacing-sm;

        // Play Now
        FocusScope {
          width: play-now-label.preferred-width + Theme.spacing-lg;
          height: 40px;

          key-pressed(event) => {
            if event.text == Key.Return || event.text == " " {
              PlayerState.play-next();
              return accept;
            }
            return reject;
          }

          Rectangle {
            width: 100%; height: 100%;
            border-radius: Theme.radius-sm;
            background: parent.has-focus ? Theme.focus-ring : Theme.btn-primary-bg;
            border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
            border-color: Theme.focus-ring;
            animate background { duration: 150ms; }

            play-now-label := Text {
              text: "Play Now";
              color: Theme.btn-primary-fg;
              font-family: Theme.font-display;
              font-size: Theme.font-size-caption;
              font-weight: 700;
              horizontal-alignment: center;
              vertical-alignment: center;
            }

            TouchArea { clicked => { PlayerState.play-next(); } }
          }
        }

        // Cancel
        FocusScope {
          width: cancel-next-label.preferred-width + Theme.spacing-lg;
          height: 40px;

          key-pressed(event) => {
            if event.text == Key.Return || event.text == " " {
              PlayerState.cancel-next();
              return accept;
            }
            return reject;
          }

          Rectangle {
            width: 100%; height: 100%;
            border-radius: Theme.radius-sm;
            background: parent.has-focus ? Theme.focus-bg : Theme.btn-secondary-bg;
            border-width: parent.has-focus ? Theme.focus-ring-width : 1px;
            border-color: parent.has-focus ? Theme.focus-ring : Theme.border-subtle;
            animate background { duration: 150ms; }

            cancel-next-label := Text {
              text: "Cancel";
              color: Theme.btn-secondary-fg;
              font-family: Theme.font-body;
              font-size: Theme.font-size-caption;
              font-weight: 600;
              horizontal-alignment: center;
              vertical-alignment: center;
            }

            TouchArea { clicked => { PlayerState.cancel-next(); } }
          }
        }
      }
    }
  }

  // ── 3.13: "Still Watching?" prompt ───────────────────────────────────────
  if PlayerState.show-still-watching: Rectangle {
    // Dim scrim behind the card
    width: 100%; height: 100%;
    background: Theme.overlay;

    Rectangle {
      x: parent.width / 2 - self.width / 2;
      y: parent.height / 2 - self.height / 2;
      width: 360px;
      height: still-layout.preferred-height + Theme.spacing-xl;
      border-radius: Theme.radius-md;
      background: Theme.surface;
      border-width: 1px;
      border-color: Theme.card-border;

      still-layout := VerticalLayout {
        padding: Theme.spacing-xl;
        spacing: Theme.spacing-md;
        alignment: center;

        Text {
          text: "Are you still watching?";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: Theme.font-size-h2;
          font-weight: 700;
          horizontal-alignment: center;
        }

        // Continue button
        FocusScope {
          x: parent.width / 2 - self.width / 2;
          width: continue-label.preferred-width + Theme.spacing-xl;
          height: 48px;

          key-pressed(event) => {
            if event.text == Key.Return || event.text == " " {
              PlayerState.dismiss-still-watching();
              return accept;
            }
            return reject;
          }

          Rectangle {
            width: 100%; height: 100%;
            border-radius: Theme.radius-sm;
            background: parent.has-focus ? Theme.focus-ring : Theme.btn-primary-bg;
            border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
            border-color: Theme.focus-ring;
            animate background { duration: 150ms; }

            continue-label := Text {
              text: "Continue";
              color: Theme.btn-primary-fg;
              font-family: Theme.font-display;
              font-size: Theme.font-size-body;
              font-weight: 700;
              horizontal-alignment: center;
              vertical-alignment: center;
            }

            TouchArea { clicked => { PlayerState.dismiss-still-watching(); } }
          }
        }
      }
    }
  }

  // ── 3.15: Audio + Subtitles panel (slide-in from right) ─────────────────
  // Always rendered — x-position animation drives slide in/out.
  // Width fixed at 300px; height and x derived from parent inside component.
  AudioSubtitlePanel {
    x: PlayerState.show-tracks-panel ? parent.width - 300px : parent.width;
    width: 300px;
    height: parent.height;
  }

  // ── 3.14: Post-play screen ────────────────────────────────────────────────
  if !PlayerState.is-playing && PlayerState.show-post-play: Rectangle {
    width: 100%; height: 100%;
    background: Theme.overlay-dark;

    VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-xl;

      Text {
        text: "Up Next";
        color: Theme.text-secondary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h2;
        font-weight: 700;
        horizontal-alignment: center;
      }

      Rectangle {
        x: parent.width / 2 - self.width / 2;
        width: 400px;
        height: post-play-inner.preferred-height + Theme.spacing-xl;
        border-radius: Theme.radius-md;
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.card-border;

        post-play-inner := VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          Text {
            text: PlayerState.post-play-next-title;
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-body;
            font-weight: 700;
            wrap: word-wrap;
            horizontal-alignment: center;
          }

          HorizontalLayout {
            alignment: center;
            spacing: Theme.spacing-md;

            // Play
            FocusScope {
              width: pp-play-label.preferred-width + Theme.spacing-xl;
              height: 48px;

              key-pressed(event) => {
                if event.text == Key.Return || event.text == " " {
                  PlayerState.post-play-play();
                  return accept;
                }
                return reject;
              }

              Rectangle {
                width: 100%; height: 100%;
                border-radius: Theme.radius-sm;
                background: parent.has-focus ? Theme.focus-ring : Theme.btn-primary-bg;
                border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
                border-color: Theme.focus-ring;
                animate background { duration: 150ms; }

                pp-play-label := Text {
                  text: "Play";
                  color: Theme.btn-primary-fg;
                  font-family: Theme.font-display;
                  font-size: Theme.font-size-body;
                  font-weight: 700;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }

                TouchArea { clicked => { PlayerState.post-play-play(); } }
              }
            }

            // Back to Browse
            FocusScope {
              width: pp-back-label.preferred-width + Theme.spacing-xl;
              height: 48px;

              key-pressed(event) => {
                if event.text == Key.Return || event.text == " " {
                  PlayerState.post-play-back();
                  return accept;
                }
                return reject;
              }

              Rectangle {
                width: 100%; height: 100%;
                border-radius: Theme.radius-sm;
                background: parent.has-focus ? Theme.focus-bg : Theme.btn-secondary-bg;
                border-width: parent.has-focus ? Theme.focus-ring-width : 1px;
                border-color: parent.has-focus ? Theme.focus-ring : Theme.border-subtle;
                animate background { duration: 150ms; }

                pp-back-label := Text {
                  text: "Back to Browse";
                  color: Theme.btn-secondary-fg;
                  font-family: Theme.font-body;
                  font-size: Theme.font-size-body;
                  font-weight: 600;
                  horizontal-alignment: center;
                  vertical-alignment: center;
                }

                TouchArea { clicked => { PlayerState.post-play-back(); } }
              }
            }
          }
        }
      }
    }
  }
}
