import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";

// Player state exposed from Rust
export global PlayerState {
  in-out property <bool> is-playing: false;
  in-out property <bool> is-paused: false;
  in-out property <bool> is-buffering: false;
  in-out property <string> current-title: "";
  in-out property <string> current-group: "";
  in-out property <string> current-channel-id: "";
  in-out property <float> position: 0.0;
  in-out property <float> duration: 0.0;
  in-out property <float> volume: 1.0;
  in-out property <bool> is-muted: false;
  in-out property <bool> show-osd: true;
  in-out property <bool> is-live: true;

  // OSD auto-hide timer managed by Rust
  callback play-pause();
  callback stop();
  callback seek(/* position */ float);
  callback set-volume(/* volume */ float);
  callback toggle-mute();
  callback show-controls();
}

component VolumeSlider inherits Rectangle {
  width: 120px;
  height: 4px;
  border-radius: 2px;
  background: rgba(255, 255, 255, 0.3);

  Rectangle {
    x: 0;
    width: parent.width * PlayerState.volume;
    height: 100%;
    border-radius: 2px;
    background: #FFFFFF;
  }

  TouchArea {
    clicked => {
      PlayerState.set-volume(self.mouse-x / parent.width);
    }
  }
}

component SeekBar inherits Rectangle {
  height: 4px;
  border-radius: 2px;
  background: rgba(255, 255, 255, 0.3);

  // Progress
  Rectangle {
    x: 0;
    width: PlayerState.duration > 0 ? parent.width * (PlayerState.position / PlayerState.duration) : 0;
    height: 100%;
    border-radius: 2px;
    background: Theme.accent;
  }

  // Seek knob
  if PlayerState.duration > 0: Rectangle {
    x: parent.width * (PlayerState.position / PlayerState.duration) - 8px;
    y: -6px;
    width: 16px;
    height: 16px;
    border-radius: 8px;
    background: #FFFFFF;
  }

  TouchArea {
    clicked => {
      if PlayerState.duration > 0 {
        PlayerState.seek(self.mouse-x / parent.width * PlayerState.duration);
      }
    }
  }
}

component OsdControls inherits Rectangle {
  // Gradient overlay at bottom
  Rectangle {
    y: parent.height - 250px;
    height: 250px;
    width: parent.width;
    background: @linear-gradient(180deg, rgba(10,10,12,0) 0%, rgba(10,10,12,0.85) 100%);
  }

  VerticalLayout {
    y: parent.height - 160px;
    height: 140px;
    padding-left: 40px;
    padding-right: 40px;
    padding-bottom: 24px;
    alignment: end;
    spacing: Theme.spacing-md;

    // Transport controls
    HorizontalLayout {
      alignment: center;
      spacing: Theme.spacing-xl;

      // Play/Pause
      FocusScope {
        width: 56px;
        height: 56px;
        key-pressed(event) => {
          if event.text == Key.Return || event.text == " " {
            PlayerState.play-pause();
            return accept;
          }
          return reject;
        }
        Rectangle {
          width: 100%; height: 100%;
          border-radius: 28px;
          background: rgba(255, 255, 255, 0.15);
          border-width: parent.has-focus ? 2px : 0px;
          border-color: #FFFFFF;

          Text {
            text: PlayerState.is-paused ? "▶" : "⏸";
            color: #FFFFFF;
            font-size: 24px;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
          TouchArea { clicked => { PlayerState.play-pause(); } }
        }
      }

      // Stop
      FocusScope {
        width: 48px;
        height: 48px;
        key-pressed(event) => {
          if event.text == Key.Return || event.text == Key.Escape {
            PlayerState.stop();
            return accept;
          }
          return reject;
        }
        Rectangle {
          width: 100%; height: 100%;
          border-radius: 24px;
          background: rgba(255, 255, 255, 0.1);
          border-width: parent.has-focus ? 2px : 0px;
          border-color: #FFFFFF;

          Text {
            text: "⏹";
            color: #FFFFFF;
            font-size: 20px;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
          TouchArea { clicked => { PlayerState.stop(); } }
        }
      }

      // Volume
      HorizontalLayout {
        spacing: Theme.spacing-sm;
        FocusScope {
          width: 36px;
          height: 36px;
          key-pressed(event) => {
            if event.text == Key.Return {
              PlayerState.toggle-mute();
              return accept;
            }
            return reject;
          }
          Rectangle {
            width: 100%; height: 100%;
            border-radius: 18px;
            Text {
              text: PlayerState.is-muted ? "🔇" : "🔊";
              color: #FFFFFF;
              font-size: 18px;
              horizontal-alignment: center;
              vertical-alignment: center;
            }
            TouchArea { clicked => { PlayerState.toggle-mute(); } }
          }
        }
        VolumeSlider { }
      }
    }

    // Seek bar (hidden for live, shown for VOD/catchup)
    if !PlayerState.is-live: SeekBar {}

    // Metadata
    HorizontalLayout {
      alignment: start;
      spacing: Theme.spacing-sm;

      if PlayerState.is-live: Rectangle {
        width: 48px;
        height: 22px;
        border-radius: 4px;
        background: Theme.accent;
        Text {
          text: "LIVE";
          color: #FFFFFF;
          font-size: 11px;
          font-weight: 700;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
      }

      VerticalLayout {
        spacing: 2px;
        Text {
          text: PlayerState.current-title;
          color: #FFFFFF;
          font-family: Theme.font-display;
          font-size: Theme.font-size-h2;
          font-weight: 700;
        }
        if PlayerState.current-group != "": Text {
          text: PlayerState.current-group;
          color: rgba(255, 255, 255, 0.6);
          font-size: Theme.font-size-caption;
        }
      }
    }
  }
}

export component PlayerScreen inherits Rectangle {
  background: #000000;
  width: 100%;
  height: 100%;

  // Video surface placeholder (Layer 0 — libmpv underlay goes here in Phase 3.1)
  Rectangle {
    width: 100%;
    height: 100%;
    background: #000000;

    if PlayerState.is-buffering: Text {
      text: "Buffering...";
      color: rgba(255, 255, 255, 0.6);
      font-size: Theme.font-size-body;
      horizontal-alignment: center;
      vertical-alignment: center;
    }

    if !PlayerState.is-playing && !PlayerState.is-buffering: Text {
      text: "No stream playing";
      color: rgba(255, 255, 255, 0.4);
      font-size: Theme.font-size-body;
      horizontal-alignment: center;
      vertical-alignment: center;
    }
  }

  // OSD overlay (Layer 2)
  if PlayerState.show-osd: OsdControls {
    width: 100%;
    height: 100%;
  }

  // Touch/click to show/hide OSD
  TouchArea {
    clicked => { PlayerState.show-controls(); }
  }
}
