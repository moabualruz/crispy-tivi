import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { IconCheck } from "../components/icons.slint";
import { ActionButton } from "../components/action-button.slint";
import { InputField } from "../components/input-field.slint";
import { Dropdown } from "../components/dropdown.slint";
import { ScrollView } from "std-widgets.slint";
import { FilterChip } from "../components/filter-chip.slint";

export global OnboardingState {
  // 0=Welcome, 1=CreateProfile, 2=AddSource, 3=Preferences, 4=Done
  in-out property <int> step: 0;
  in-out property <bool> is-active: false;

  // Profile creation state (used by step 1)
  in-out property <string> profile-name: "";
  in-out property <int> avatar-index: 0;

  callback complete();
}

// Step indicator dots — accent for active, subtle for inactive
component StepIndicator inherits HorizontalLayout {
  in property <int> current-step;

  spacing: Theme.spacing-sm;
  alignment: center;

  for i in [0, 1, 2, 3, 4]: Rectangle {
    width: i == current-step ? 28px : 8px;
    height: 8px;
    border-radius: Theme.radius-xs;
    background: i == current-step ? Theme.accent-gradient : Theme.focus-glow;

    animate width { duration: 250ms; easing: ease-in-out; }
    animate background { duration: 250ms; }
  }
}

// ─── Step 0: Welcome ───
component WelcomeStep inherits Rectangle {
  background: transparent;
  min-height: layout.min-height;

  // Centered content card
  layout := VerticalLayout {
    alignment: center;
    spacing: Theme.spacing-2xl;

    // App icon + branding
    VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-lg;

      // Logo circle — brand accent gradient
      Rectangle {
        width: 96px;
        height: 96px;
        border-radius: 48px;
        background: Theme.accent-gradient;

        Text {
          text: "CT";
          color: Theme.btn-secondary-fg;
          font-family: Theme.font-display;
          font-size: 36px;
          font-weight: 800;
          horizontal-alignment: center;
          vertical-alignment: center;
        }
      }

      // Title
      Text {
        text: "Welcome to CrispyTivi";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: 40px;
        font-weight: 800;
        horizontal-alignment: center;
      }

      // Subtitle
      Text {
        text: "Your unified streaming experience.\nLet\u{2019}s set up in a few quick steps.";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
        wrap: word-wrap;
      }
    }

    // CTA
    HorizontalLayout {
      alignment: center;
      ActionButton {
        label: "Get Started";
        is-primary: true;
        width: 220px;
        clicked => { OnboardingState.step = 1; }
      }
    }
  }
}

// ─── Step 1: Create Profile ───
component CreateProfileStep inherits Rectangle {
  background: transparent;
  min-height: layout.min-height;

  // 9 avatar colour swatches (index 0–8) matching AVATAR_COLORS in event_bridge.rs
  // colours: red, orange, amber, green, teal, sky, indigo, purple, pink
  property <[color]> avatar-colors: [
    #E53935, #FB8C00, #FFB300,
    #43A047, #00897B, #039BE5,
    #3949AB, #8E24AA, #D81B60,
  ];

  layout := VerticalLayout {
    alignment: center;
    spacing: Theme.spacing-xl;

    // Header
    VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-sm;

      Text {
        text: "Create Your Profile";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
        font-weight: 700;
        horizontal-alignment: center;
      }
      Text {
        text: "Pick a name and avatar to personalise your experience.";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
      }
    }

    // Profile card — glassmorphic
    HorizontalLayout {
      alignment: center;

      Rectangle {
        width: 440px;
        border-radius: Theme.radius-lg;
        background: Theme.card-surface;
        border-width: 1px;
        border-color: Theme.card-border;

        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-lg;

          // Name field
          InputField {
            label: "Your Name";
            placeholder-text: "e.g. Alex";
            edited(val) => { OnboardingState.profile-name = val; }
          }

          // Avatar grid label
          Text {
            text: "Choose Avatar";
            color: Theme.text-secondary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-caption;
            font-weight: 500;
          }

          // 3×3 avatar colour grid — D-pad navigable via FocusScope per cell
          GridLayout {
            spacing: Theme.spacing-sm;

            for color-val[idx] in root.avatar-colors: FocusScope {
              row: floor(idx / 3);
              col: mod(idx, 3);
              width: 72px;
              height: 72px;

              property <bool> is-selected: OnboardingState.avatar-index == idx;
              property <bool> is-focused: self.has-focus;

              key-pressed(event) => {
                if event.text == Key.Return || event.text == " " {
                  OnboardingState.avatar-index = idx;
                  return accept;
                }
                reject
              }

              // Outer ring: focus = white border, selected = accent, default = subtle
              Rectangle {
                width: 100%; height: 100%;
                border-radius: 36px;
                border-width: is-selected ? 3px : (is-focused ? Theme.focus-ring-width : 1px);
                border-color: is-focused ? Theme.focus-ring : (is-selected ? #FFFFFF : Theme.border-subtle);
                background: is-focused ? Theme.focus-bg : transparent;

                animate border-width { duration: 150ms; }
                animate border-color { duration: 150ms; }

                // Coloured circle with initial letter
                Rectangle {
                  x: (parent.width - 56px) / 2;
                  y: (parent.height - 56px) / 2;
                  width: 56px;
                  height: 56px;
                  border-radius: 28px;
                  background: color-val;

                  Text {
                    width: 100%; height: 100%;
                    // Slint strings are not indexable — show "?" as placeholder initial
                    text: "?";
                    color: #FFFFFF;
                    font-family: Theme.font-display;
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                  }
                }

                // Selected tick overlay
                if is-selected: Rectangle {
                  x: parent.width - 20px;
                  y: 0px;
                  width: 20px;
                  height: 20px;
                  border-radius: 10px;
                  background: #FFFFFF;

                  Text {
                    width: 100%; height: 100%;
                    text: "\u{2713}";
                    color: #000000;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                  }
                }
              }

              // Tap/click to select
              TouchArea {
                width: 100%; height: 100%;
                clicked => { OnboardingState.avatar-index = idx; }
              }
            }
          }
        }
      }
    }

    // CTA
    HorizontalLayout {
      alignment: center;
      ActionButton {
        label: "Continue";
        is-primary: true;
        width: 220px;
        clicked => {
          AppState.create-profile(OnboardingState.profile-name, false);
          OnboardingState.step = 2;
        }
      }
    }
  }
}

// ─── Step 2: Add Source ───
component AddSourceStep inherits Rectangle {
  background: transparent;
  min-height: layout.min-height;

  in-out property <string> src-name: "";
  in-out property <int> src-type-idx: 0;
  in-out property <string> field-url: "";
  in-out property <string> field-user: "";
  in-out property <string> field-pass: "";

  layout := VerticalLayout {
    alignment: center;
    spacing: Theme.spacing-xl;

    // Header
    VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-sm;

      Text {
        text: "Add Your First Source";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
        font-weight: 700;
        horizontal-alignment: center;
      }
      Text {
        text: "Connect your IPTV provider to start watching.";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
      }
    }

    // Form card — glassmorphic
    HorizontalLayout {
      alignment: center;

      Rectangle {
        width: 540px;
        border-radius: Theme.radius-lg;
        background: Theme.card-surface;
        border-width: 1px;
        border-color: Theme.card-border;

        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-md;

          // Name
          InputField {
            label: "Source Name";
            placeholder-text: "My IPTV Provider";
            edited(val) => { root.src-name = val; }
          }

          // Type selector
          Dropdown {
            label: "Source Type";
            model: ["M3U", "Xtream", "Stalker"];
            current-index <=> root.src-type-idx;
            selected => {
              root.field-url = "";
              root.field-user = "";
              root.field-pass = "";
            }
          }

          // M3U fields
          if root.src-type-idx == 0: InputField {
            label: "Playlist URL";
            placeholder-text: "http://example.com/playlist.m3u";
            edited(val) => { root.field-url = val; }
          }

          // Xtream fields
          if root.src-type-idx == 1: InputField {
            label: "Server URL";
            placeholder-text: "http://provider.com:8080";
            edited(val) => { root.field-url = val; }
          }
          if root.src-type-idx == 1: InputField {
            label: "Username";
            placeholder-text: "username";
            edited(val) => { root.field-user = val; }
          }
          if root.src-type-idx == 1: InputField {
            label: "Password";
            placeholder-text: "password";
            // Slint TextInput currently doesn't natively support password masking directly out of standard properties!
            // Wait, standard LineEdit had input-type: InputType.password. Our custom one overrides it directly.
            input-type: InputType.password;
            edited(val) => { root.field-pass = val; }
          }

          // Stalker fields
          if root.src-type-idx == 2: InputField {
            label: "Portal URL";
            placeholder-text: "http://portal.example.com/c/";
            edited(val) => { root.field-url = val; }
          }
          if root.src-type-idx == 2: InputField {
            label: "MAC Address";
            placeholder-text: "00:1A:79:XX:XX:XX";
            edited(val) => { root.field-user = val; }
          }
        }
      }
    }

    // Actions
    HorizontalLayout {
      alignment: center;
      spacing: Theme.spacing-md;

      ActionButton {
        label: "Add & Continue";
        is-primary: true;
        width: 220px;
        clicked => {
          AppState.save-source(
            root.src-name,
            root.src-type-idx == 0 ? "m3u" : root.src-type-idx == 1 ? "xtream" : "stalker",
            root.field-url,
            root.field-user,
            root.field-pass,
          );
          OnboardingState.step = 3;
        }
      }
    }
  }
}

// ─── Step 3: Preferences ───
component PreferencesStep inherits Rectangle {
  background: transparent;
  min-height: layout.min-height;

  layout := VerticalLayout {
    alignment: center;
    spacing: Theme.spacing-xl;

    // Header
    VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-sm;

      Text {
        text: "Personalize";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: Theme.font-size-h1;
        font-weight: 700;
        horizontal-alignment: center;
      }
      Text {
        text: "Choose your preferred look and language.";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
      }
    }

    // Theme card
    HorizontalLayout {
      alignment: center;

      Rectangle {
        width: 440px;
        border-radius: Theme.radius-lg;
        background: Theme.card-surface;
        border-width: 1px;
        border-color: Theme.card-border;

        VerticalLayout {
          padding: Theme.spacing-lg;
          spacing: Theme.spacing-lg;

          // Theme choice
          VerticalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Theme";
              color: Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-caption;
              font-weight: 500;
            }

            HorizontalLayout {
              spacing: Theme.spacing-sm;
              alignment: start;

              for item in [
                { label: "System", mode: 0 },
                { label: "Dark", mode: 1 },
                { label: "Light", mode: 2 },
              ]: FilterChip {
                label: item.label;
                active: Theme.theme-mode == item.mode;
                activated => {
                  Theme.theme-mode = item.mode;
                  AppState.set-theme(item.mode);
                }
              }
            }
          }

          // Language choice
          VerticalLayout {
            spacing: Theme.spacing-md;
            Text {
              text: "Language";
              color: Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-caption;
              font-weight: 500;
            }

            GridLayout {
              spacing: Theme.spacing-xs;

              for lang[idx] in [
                { code: "en", label: "English" },
                { code: "ar", label: "العربية" },
                { code: "de", label: "Deutsch" },
                { code: "fr", label: "Français" },
                { code: "es", label: "Español" },
              ]: FilterChip {
                row: floor(idx / 3);
                col: mod(idx, 3);
                label: lang.label;
                active: AppState.active-language == lang.code;
                activated => {
                  AppState.set-language(lang.code);
                  AppState.active-language = lang.code;
                }
              }
            }
          }
        }
      }
    }

    // CTA
    HorizontalLayout {
      alignment: center;
      ActionButton {
        label: "Continue";
        width: 180px;
        is-primary: true;
        clicked => { OnboardingState.step = 4; }
      }
    }
  }
}

// ─── Step 4: Done ───
component DoneStep inherits Rectangle {
  background: transparent;
  min-height: layout.min-height;

  layout := VerticalLayout {
    alignment: center;
    spacing: Theme.spacing-2xl;

    // Checkmark circle
    HorizontalLayout {
      alignment: center;
      Rectangle {
        width: 96px;
        height: 96px;
        border-radius: 48px;
        background: Theme.btn-primary-bg;

        VerticalLayout {
          alignment: center;
          HorizontalLayout {
            alignment: center;
            IconCheck {
              width: 48px;
              height: 48px;
              fill: Theme.btn-primary-fg;
            }
          }
        }
      }
    }

    VerticalLayout {
      alignment: center;
      spacing: Theme.spacing-sm;

      Text {
        text: "You\u{2019}re All Set!";
        color: Theme.text-primary;
        font-family: Theme.font-display;
        font-size: 40px;
        font-weight: 800;
        horizontal-alignment: center;
      }
      Text {
        text: "Your sources are syncing. Enjoy your streaming experience.";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
        wrap: word-wrap;
      }
    }

    HorizontalLayout {
      alignment: center;
      ActionButton {
        label: "Start Watching";
        width: 220px;
        is-primary: true;
        clicked => { OnboardingState.complete(); }
      }
    }
  }
}

// ─── Main Onboarding Screen ───
export component OnboardingScreen inherits Rectangle {
  background: Theme.background;

  // Subtle gradient backdrop
  Rectangle {
    width: 100%; height: 100%;
    background: @linear-gradient(160deg, rgba(255, 255, 255, 0.05) 0%, rgba(10, 10, 12, 1.0) 40%, rgba(200, 210, 220, 0.04) 100%);
  }

  // M-008: Root FocusScope captures keyboard so D-pad/Enter can advance steps.
  // Steps 0, 3, 4 have no form fields — Enter triggers the primary action directly.
  // Step 1 (CreateProfile): avatar FocusScopes handle Enter internally; name field also captures it.
  // Step 2 (AddSource): the ActionButton inside AddSourceStep handles Key.Return itself when focused.
  root-focus := FocusScope {
    width: 100%;
    height: 100%;

    init => { root-focus.focus(); }

    key-pressed(event) => {
      if event.text == Key.Return {
        if OnboardingState.step == 0 { OnboardingState.step = 1; return accept; }
        if OnboardingState.step == 3 { OnboardingState.step = 4; return accept; }
        if OnboardingState.step == 4 { OnboardingState.complete(); return accept; }
      }
      // C-024/C-025: Escape goes back one step; step 0 is mandatory — cannot exit
      if event.text == Key.Escape {
        if OnboardingState.step > 0 { OnboardingState.step = OnboardingState.step - 1; return accept; }
        return accept; // step 0: swallow Escape, no exit allowed
      }
      reject
    }

    ScrollView {
      width: 100%;
      height: 100%;

      VerticalLayout {
        // Ensure the content area always spans at least the height of the screen for centering
        min-height: root.height;
        width: root.width;
        alignment: center;
        padding-top: Theme.spacing-2xl;
        padding-bottom: Theme.spacing-2xl;

        VerticalLayout {
          alignment: center;
          spacing: Theme.spacing-xl;

          if OnboardingState.step == 0: WelcomeStep {  }
          if OnboardingState.step == 1: CreateProfileStep {  }
          if OnboardingState.step == 2: AddSourceStep {  }
          if OnboardingState.step == 3: PreferencesStep {  }
          if OnboardingState.step == 4: DoneStep {  }

          // Step indicator at bottom
          HorizontalLayout {
            alignment: center;
            padding-top: Theme.spacing-xl;
            StepIndicator { current-step: OnboardingState.step; }
          }
        }
      }
    }
  }
}
