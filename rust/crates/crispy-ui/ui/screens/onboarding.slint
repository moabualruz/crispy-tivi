import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { LineEdit, ComboBox } from "std-widgets.slint";

export global OnboardingState {
  // 0=Welcome, 1=AddSource, 2=Preferences, 3=Done
  in-out property <int> step: 0;
  in-out property <bool> is-active: false;

  callback complete();
}

component StepIndicator inherits HorizontalLayout {
  in property <int> current-step;

  spacing: Theme.spacing-sm;
  alignment: center;

  for i in [0, 1, 2, 3]: Rectangle {
    width: i == current-step ? 24px : 8px;
    height: 8px;
    border-radius: 4px;
    background: i == current-step ? Theme.accent : Theme.border-subtle;

    animate width { duration: 200ms; easing: ease-in-out; }
    animate background { duration: 200ms; }
  }
}

component WelcomeStep inherits VerticalLayout {
  alignment: center;
  spacing: Theme.spacing-xl;

  Text {
    text: "📺";
    font-size: 72px;
    horizontal-alignment: center;
  }
  Text {
    text: "Welcome to CrispyTivi";
    color: Theme.text-primary;
    font-family: Theme.font-display;
    font-size: Theme.font-size-h1;
    horizontal-alignment: center;
  }
  Text {
    text: "Your unified streaming experience.\nLet's get you set up in a few steps.";
    color: Theme.text-secondary;
    font-family: Theme.font-body;
    font-size: Theme.font-size-body;
    horizontal-alignment: center;
    wrap: word-wrap;
  }

  FocusScope {
    width: 200px;
    height: 48px;
    key-pressed(event) => {
      if event.text == Key.Return { OnboardingState.step = 1; return accept; }
      return reject;
    }
    Rectangle {
      width: 100%; height: 100%;
      border-radius: Theme.radius-pill;
      background: Theme.accent;
      border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
      border-color: Theme.focus-ring;
      Text {
        text: "Get Started";
        color: #FFFFFF;
        font-weight: 600;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea { clicked => { OnboardingState.step = 1; } }
    }
  }
}

component AddSourceStep inherits VerticalLayout {
  // Properties to collect form values (avoids Slint scoping issue with if-block IDs)
  in-out property <string> src-name: "";
  in-out property <int> src-type-idx: 0;
  in-out property <string> field-url: "";
  in-out property <string> field-user: "";
  in-out property <string> field-pass: "";

  alignment: center;
  spacing: Theme.spacing-lg;

  Text {
    text: "Add Your First Source";
    color: Theme.text-primary;
    font-family: Theme.font-display;
    font-size: Theme.font-size-h2;
    horizontal-alignment: center;
  }
  Text {
    text: "Enter your IPTV source details below.";
    color: Theme.text-secondary;
    font-size: Theme.font-size-body;
    horizontal-alignment: center;
  }

  // Form card — glassmorphic
  Rectangle {
    width: 440px;
    border-radius: 16px;
    background: rgba(28, 28, 32, 0.95);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);

    VerticalLayout {
      padding: 24px;
      spacing: 16px;

      // Name (all types)
      VerticalLayout {
        spacing: 6px;
        Text { text: "Source Name"; color: Theme.text-secondary; font-size: 13px; }
        LineEdit {
          placeholder-text: "My IPTV Provider";
          edited => { root.src-name = self.text; }
        }
      }

      // Type selector
      VerticalLayout {
        spacing: 6px;
        Text { text: "Source Type"; color: Theme.text-secondary; font-size: 13px; }
        ComboBox {
          model: ["M3U / M3U8", "Xtream Codes", "Stalker Portal"];
          current-index <=> root.src-type-idx;
          selected => {
            // Clear fields on type change
            root.field-url = "";
            root.field-user = "";
            root.field-pass = "";
          }
        }
      }

      // M3U: Playlist URL
      if root.src-type-idx == 0: VerticalLayout {
        spacing: 6px;
        Text { text: "Playlist URL"; color: Theme.text-secondary; font-size: 13px; }
        LineEdit {
          placeholder-text: "http://example.com/playlist.m3u";
          edited => { root.field-url = self.text; }
        }
      }

      // Xtream: Server URL
      if root.src-type-idx == 1: VerticalLayout {
        spacing: 6px;
        Text { text: "Server URL"; color: Theme.text-secondary; font-size: 13px; }
        LineEdit {
          placeholder-text: "http://provider.com:8080";
          edited => { root.field-url = self.text; }
        }
      }
      // Xtream: Username
      if root.src-type-idx == 1: VerticalLayout {
        spacing: 6px;
        Text { text: "Username"; color: Theme.text-secondary; font-size: 13px; }
        LineEdit {
          placeholder-text: "username";
          edited => { root.field-user = self.text; }
        }
      }
      // Xtream: Password
      if root.src-type-idx == 1: VerticalLayout {
        spacing: 6px;
        Text { text: "Password"; color: Theme.text-secondary; font-size: 13px; }
        LineEdit {
          placeholder-text: "password";
          input-type: password;
          edited => { root.field-pass = self.text; }
        }
      }

      // Stalker: Portal URL
      if root.src-type-idx == 2: VerticalLayout {
        spacing: 6px;
        Text { text: "Portal URL"; color: Theme.text-secondary; font-size: 13px; }
        LineEdit {
          placeholder-text: "http://portal.example.com/c/";
          edited => { root.field-url = self.text; }
        }
      }
      // Stalker: MAC Address
      if root.src-type-idx == 2: VerticalLayout {
        spacing: 6px;
        Text { text: "MAC Address"; color: Theme.text-secondary; font-size: 13px; }
        LineEdit {
          placeholder-text: "00:1A:79:XX:XX:XX";
          edited => { root.field-user = self.text; }
        }
      }
    }
  }

  // Add & Continue — primary button (white)
  FocusScope {
    width: 200px;
    height: 48px;
    key-pressed(event) => {
      if event.text == Key.Return {
        AppState.save-source(
          root.src-name,
          root.src-type-idx == 0 ? "m3u" : root.src-type-idx == 1 ? "xtream" : "stalker",
          root.field-url,
          root.field-user,
          root.field-pass,
        );
        OnboardingState.step = 2;
        return accept;
      }
      return reject;
    }
    Rectangle {
      width: 100%; height: 100%;
      border-radius: 8px;
      background: #FFFFFF;
      border-width: parent.has-focus ? 2px : 0px;
      border-color: Theme.accent;

      Text {
        text: "Add & Continue";
        color: #000000;
        font-family: Theme.font-display;
        font-size: 16px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
      TouchArea {
        clicked => {
          AppState.save-source(
            root.src-name,
            root.src-type-idx == 0 ? "m3u" : root.src-type-idx == 1 ? "xtream" : "stalker",
            root.field-url,
            root.field-user,
            root.field-pass,
          );
          OnboardingState.step = 2;
        }
      }
    }
  }
}

component PreferencesStep inherits VerticalLayout {
  alignment: center;
  spacing: Theme.spacing-lg;

  Text {
    text: "Preferences";
    color: Theme.text-primary;
    font-family: Theme.font-display;
    font-size: Theme.font-size-h2;
    horizontal-alignment: center;
  }

  // Theme choice
  VerticalLayout {
    spacing: Theme.spacing-md;
    alignment: center;

    Text { text: "Choose your theme"; color: Theme.text-secondary; font-size: Theme.font-size-body; horizontal-alignment: center; }

    HorizontalLayout {
      spacing: Theme.spacing-md;
      alignment: center;

      for item in [
        { label: "System", mode: 0 },
        { label: "Dark", mode: 1 },
        { label: "Light", mode: 2 },
      ]: FocusScope {
        width: 90px;
        height: 40px;
        key-pressed(event) => {
          if event.text == Key.Return {
            Theme.theme-mode = item.mode;
            AppState.set-theme(item.mode);
            return accept;
          }
          return reject;
        }
        Rectangle {
          width: 100%; height: 100%;
          border-radius: Theme.radius-pill;
          background: Theme.theme-mode == item.mode ? Theme.accent : Theme.surface;
          border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
          border-color: Theme.focus-ring;
          Text {
            text: item.label;
            color: Theme.theme-mode == item.mode ? #FFFFFF : Theme.text-secondary;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
          }
          TouchArea {
            clicked => {
              Theme.theme-mode = item.mode;
              AppState.set-theme(item.mode);
            }
          }
        }
      }
    }
  }

  FocusScope {
    width: 160px;
    height: 44px;
    key-pressed(event) => {
      if event.text == Key.Return { OnboardingState.step = 3; return accept; }
      return reject;
    }
    Rectangle {
      width: 100%; height: 100%;
      border-radius: Theme.radius-pill;
      background: Theme.accent;
      border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
      border-color: Theme.focus-ring;
      Text { text: "Continue"; color: #FFFFFF; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
      TouchArea { clicked => { OnboardingState.step = 3; } }
    }
  }
}

component DoneStep inherits VerticalLayout {
  alignment: center;
  spacing: Theme.spacing-xl;

  Text { text: "🎉"; font-size: 72px; horizontal-alignment: center; }
  Text {
    text: "You're All Set!";
    color: Theme.text-primary;
    font-family: Theme.font-display;
    font-size: Theme.font-size-h1;
    horizontal-alignment: center;
  }
  Text {
    text: "Enjoy your streaming experience.";
    color: Theme.text-secondary;
    font-size: Theme.font-size-body;
    horizontal-alignment: center;
  }

  FocusScope {
    width: 200px;
    height: 48px;
    key-pressed(event) => {
      if event.text == Key.Return { OnboardingState.complete(); return accept; }
      return reject;
    }
    Rectangle {
      width: 100%; height: 100%;
      border-radius: Theme.radius-pill;
      background: Theme.accent;
      border-width: parent.has-focus ? Theme.focus-ring-width : 0px;
      border-color: Theme.focus-ring;
      Text { text: "Start Watching"; color: #FFFFFF; font-weight: 600; font-size: Theme.font-size-body; horizontal-alignment: center; vertical-alignment: center; }
      TouchArea { clicked => { OnboardingState.complete(); } }
    }
  }
}

export component OnboardingScreen inherits Rectangle {
  background: Theme.background;

  VerticalLayout {
    alignment: center;
    spacing: Theme.spacing-xl;

    if OnboardingState.step == 0: WelcomeStep {}
    if OnboardingState.step == 1: AddSourceStep {}
    if OnboardingState.step == 2: PreferencesStep {}
    if OnboardingState.step == 3: DoneStep {}

    StepIndicator { current-step: OnboardingState.step; }
  }
}
