import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { EmptyState } from "../components/empty-state.slint";
import { VodCard } from "../components/vod-card.slint";
import { LoadingIndicator } from "../components/loading-indicator.slint";
import { IconMovie } from "../components/icons.slint";
import { ActionButton } from "../components/action-button.slint";
import { ScrollView } from "std-widgets.slint";

export component MoviesScreen inherits Rectangle {
  background: transparent;

  if AppState.is-loading-vod && AppState.movies.length == 0: LoadingIndicator {
    message: "Loading movies...";
  }

  if !AppState.is-loading-vod && AppState.movies.length == 0: EmptyState {
    title: "No Movies";
    subtitle: "Movies from your IPTV and media server sources will appear here.";
    cta-text: "Add Source";
    cta-clicked => {
      AppState.active-screen = 6;
      AppState.navigate(6);
    }
    IconMovie { size: 32px; fill: Theme.text-secondary; }
  }

  if AppState.movies.length > 0: VerticalLayout {
    padding-top: Theme.screen-padding-top;
    padding-left: Theme.content-padding-h;
    padding-right: Theme.content-padding-h;
    padding-bottom: Theme.spacing-lg;
    spacing: Theme.spacing-md;

    Text {
      text: "Movies";
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-h1;
      font-weight: 700;
    }

    ScrollView {
      VerticalLayout {
        spacing: Theme.spacing-md;

    ScrollView {
      height: 310px; // Provide explicit bounded height because of VerticalLayout inside a Horizontal ScrollView! Wait, is our parent ScrollView or VerticalLayout? Let's check.
      // Ah, wait! The parent here was ScrollView -> VerticalLayout -> HorizontalLayout.
      // So let's wrap HorizontalLayout in a ScrollView!
      // But we already have a ScrollView encompassing the whole screen!
      // If we change it to a lane, we can keep the outer vertical ScrollView, and inner horizontal ScrollView
      HorizontalLayout {
        spacing: Theme.spacing-md;
        alignment: start;

        for movie[idx] in AppState.movies: VodCard {
          visible: idx < 30; // increase limit
          item: movie;
          clicked => { AppState.play-channel(movie.id); }
        }
      }
    }

        // Load more
        if AppState.has-more-movies: ActionButton {
          label: "Load More";
          clicked => { AppState.load-more-movies(); }
        }
      }
    }
  }
}
