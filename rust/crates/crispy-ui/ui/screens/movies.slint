import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { EmptyState } from "../components/empty-state.slint";
import { VodCard } from "../components/vod-card.slint";
import { LoadingIndicator } from "../components/loading-indicator.slint";
import { IconMovie } from "../components/icons.slint";
import { ScrollView } from "std-widgets.slint";

export component MoviesScreen inherits Rectangle {
  background: transparent;

  if AppState.is-loading-vod && AppState.movies.length == 0: LoadingIndicator {
    message: "Loading movies...";
  }

  if !AppState.is-loading-vod && AppState.movies.length == 0: EmptyState {
    title: "No Movies";
    subtitle: "Movies from your IPTV and media server sources will appear here.";
    cta-text: "Add Source";
    cta-clicked => {
      AppState.active-screen = 6;
      AppState.navigate(6);
    }
    IconMovie { size: 32px; fill: Theme.text-secondary; }
  }

  if AppState.movies.length > 0: VerticalLayout {
    padding-top: Theme.screen-padding-top;
    padding-left: Theme.content-padding-h;
    padding-right: Theme.content-padding-h;
    padding-bottom: Theme.spacing-lg;
    spacing: Theme.spacing-md;

    Text {
      text: "Movies";
      color: Theme.text-primary;
      font-family: Theme.font-display;
      font-size: Theme.font-size-h1;
      font-weight: 700;
    }

    HorizontalLayout {
      vertical-stretch: 1;

      Rectangle {
        horizontal-stretch: 1;

        FocusScope {
          width: 100%;
          height: 100%;

          key-pressed(event) => {
            if event.text == Key.DownArrow {
              AppState.scroll-movies(1);
              return accept;
            }
            if event.text == Key.UpArrow {
              AppState.scroll-movies(-1);
              return accept;
            }
            return reject;
          }

          sv := ScrollView {
            width: 100%;
            height: 100%;

            VerticalLayout {
              spacing: Theme.spacing-md;

              // Responsive columns calculation
              // 160px card width + 16px spacing = ~176px per card
              property <int> columns: max(2, floor((root.width - Theme.content-padding-h * 2 + Theme.spacing-md) / 176px));

              GridLayout {
                spacing: Theme.spacing-md;

                for movie[idx] in AppState.movies: VodCard {
                  row: floor(idx / columns);
                  col: mod(idx, columns);
                  item: movie;
                  clicked => { AppState.play-vod(movie.id); }
                }
              }
            }
          }
        }

        // Mouse/touch scroll: shift window when near edges
        TouchArea {
          width: 100%;
          height: 100%;
          scroll-event(event) => {
            if event.delta-y < 0px
              && sv.viewport-height > 0px
              && (-sv.viewport-y + sv.height > sv.viewport-height - 200px) {
              AppState.scroll-movies(5);
            }
            if event.delta-y > 0px
              && sv.viewport-y < 0px
              && (-sv.viewport-y < 200px)
              && AppState.movie-window-start > 0 {
              AppState.scroll-movies(-5);
            }
            return reject;
          }
        }
      }

    }
  }
}
