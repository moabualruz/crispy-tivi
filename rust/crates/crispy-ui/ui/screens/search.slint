import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { ChannelCard } from "../components/channel-card.slint";
import { VodCard } from "../components/vod-card.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

export component SearchScreen inherits Rectangle {
  background: transparent;

  VerticalLayout {
    padding: Theme.spacing-xl;
    spacing: Theme.spacing-md;

    // Search input
    FocusScope {
      width: 100%;
      height: 44px;
      key-pressed(event) => {
        if event.text == Key.Return {
          AppState.search-text = search-input.text;
          AppState.perform-search(search-input.text);
          return accept;
        }
        return reject;
      }
      Rectangle {
        width: 100%; height: 100%;
        border-radius: 30px;
        background: rgba(255, 255, 255, 0.1);
        border-width: parent.has-focus ? 2px : 2px;
        border-color: parent.has-focus ? #FFFFFF : rgba(255, 255, 255, 0.1);

        HorizontalLayout {
          padding-left: Theme.spacing-md;
          padding-right: Theme.spacing-md;

          search-input := LineEdit {
            placeholder-text: "Search channels, movies, series...";
            accepted => {
              AppState.search-text = self.text;
              AppState.perform-search(self.text);
            }
            edited => {
              if self.text.character-count >= 2 {
                AppState.search-text = self.text;
                AppState.perform-search(self.text);
              }
            }
          }
        }
      }
    }

    // Results
    if AppState.search-text == "": Rectangle {
      vertical-stretch: 1;
      Text {
        text: "Type to search across all sources";
        color: Theme.text-secondary;
        font-family: Theme.font-body;
        font-size: Theme.font-size-body;
        horizontal-alignment: center;
        vertical-alignment: center;
      }
    }

    if AppState.search-text != "": ScrollView {
      VerticalLayout {
        spacing: Theme.spacing-md;

        // Channel results
        if AppState.search-channels.length > 0: VerticalLayout {
          spacing: Theme.spacing-sm;

          Text {
            text: "Channels";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }

          for ch in AppState.search-channels: ChannelCard {
            channel: ch;
            clicked => { AppState.play-channel(ch.id); }
          }
        }

        // VOD results
        if AppState.search-vod.length > 0: VerticalLayout {
          spacing: Theme.spacing-sm;

          Text {
            text: "Movies & Series";
            color: Theme.text-primary;
            font-family: Theme.font-body;
            font-size: Theme.font-size-body;
            font-weight: 600;
          }

          HorizontalLayout {
            spacing: Theme.spacing-md;

            for item in AppState.search-vod: VodCard {
              item: item;
            }
          }
        }

        // No results
        if AppState.search-channels.length == 0 && AppState.search-vod.length == 0: Text {
          text: "No results found";
          color: Theme.text-secondary;
          font-family: Theme.font-body;
          font-size: Theme.font-size-body;
          horizontal-alignment: center;
        }
      }
    }
  }
}
