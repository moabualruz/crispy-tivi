import { Theme } from "../globals/theme.slint";
import { AppState } from "../globals/app-state.slint";
import { ChannelCard } from "../components/channel-card.slint";
import { VodCard } from "../components/vod-card.slint";
import { LoadingIndicator } from "../components/loading-indicator.slint";
import { IconSearch } from "../components/icons.slint";
import { ScrollView } from "std-widgets.slint";
import { SearchBar } from "../components/search-bar.slint";
import { FilterChip } from "../components/filter-chip.slint";

export component SearchScreen inherits Rectangle {
  background: transparent;

  // M-018: Escape navigates back to Home
  FocusScope {
    width: 0; height: 0;
    key-pressed(event) => {
      if event.text == Key.Escape {
        AppState.navigate(0);
        return accept;
      }
      return reject;
    }
  }

  VerticalLayout {
    padding-top: Theme.screen-padding-top;
    padding-left: Theme.content-padding-h;
    padding-right: Theme.content-padding-h;
    padding-bottom: Theme.spacing-xl;
    spacing: Theme.spacing-md;

    // Search input — pill shape per design spec
    SearchBar {
      placeholder: "Search channels, movies, series...";
      accepted(v) => {
        AppState.search-text = v;
        AppState.perform-search(v);
      }
      edited(v) => {
        if v.character-count >= 2 {
          AppState.search-text = v;
          AppState.perform-search(v);
        }
      }
    }

    // J-23 Step 3: Trending / Popular section when search field is empty
    if AppState.search-text == "": VerticalLayout {
      spacing: Theme.spacing-lg;

      // ── Recent Searches row ──────────────────────────────────────────────
      VerticalLayout {
        spacing: Theme.spacing-sm;

        Text {
          text: "Recent Searches";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: Theme.font-size-h2;
          font-weight: 700;
        }

        // J-25: persisted recent search chips — populated from DB on startup
        if AppState.recent-searches.length > 0: HorizontalLayout {
          spacing: Theme.spacing-sm;

          for chip in AppState.recent-searches: FilterChip {
            label: chip;
            active: false;
            activated => {
              AppState.search-text = chip;
              AppState.perform-search(chip);
            }
          }
        }

        // Fallback genre chips when no recent searches exist yet
        if AppState.recent-searches.length == 0: HorizontalLayout {
          spacing: Theme.spacing-sm;

          for chip in ["Sports", "News", "Movies", "Kids", "Music"]: FilterChip {
            label: chip;
            active: false;
            activated => {
              AppState.search-text = chip;
              AppState.perform-search(chip);
            }
          }
        }
      }

      // ── Popular Channels row ─────────────────────────────────────────────
      if AppState.home-channels.length > 0: VerticalLayout {
        spacing: Theme.spacing-sm;

        Text {
          text: "Popular Channels";
          color: Theme.text-primary;
          font-family: Theme.font-display;
          font-size: Theme.font-size-h2;
          font-weight: 700;
        }

        // Show first 12 home-channels as a vertical list (same pattern as channel results)
        for ch[idx] in AppState.home-channels: ChannelCard {
          visible: idx < 12;
          channel: ch;
          clicked => { AppState.play-channel(ch.id); }
        }
      }

      Rectangle { vertical-stretch: 1; }
    }

    // Searching indicator
    if AppState.is-searching: LoadingIndicator {
      message: "Searching...";
    }

    if AppState.search-text != "" && !AppState.is-searching: ScrollView {
      VerticalLayout {
        spacing: Theme.spacing-lg;

        // Channel results
        if AppState.search-channels.length > 0: VerticalLayout {
          spacing: Theme.spacing-sm;

          Text {
            text: "Channels";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          for ch in AppState.search-channels: ChannelCard {
            channel: ch;
            clicked => { AppState.play-channel(ch.id); }
          }
        }

        // VOD results
        if AppState.search-vod.length > 0: VerticalLayout {
          spacing: Theme.spacing-sm;

          Text {
            text: "Movies & Series";
            color: Theme.text-primary;
            font-family: Theme.font-display;
            font-size: Theme.font-size-h2;
            font-weight: 700;
          }

          VerticalLayout {
            property <int> columns: max(2, floor((root.width - Theme.spacing-md) / 176px));
            GridLayout {
              spacing: Theme.spacing-md;

              for item[idx] in AppState.search-vod: VodCard {
                row: floor(idx / columns);
                col: mod(idx, columns);
                item: item;
                clicked => { AppState.play-vod(item.id); }
              }
            }
          }
        }

        // No results
        if AppState.search-channels.length == 0 && AppState.search-vod.length == 0: Rectangle {
          height: 100px;
          VerticalLayout {
            alignment: center;
            Text {
              text: "No results found";
              color: Theme.text-secondary;
              font-family: Theme.font-body;
              font-size: Theme.font-size-body;
              horizontal-alignment: center;
            }
          }
        }
      }
    }
  }
}
