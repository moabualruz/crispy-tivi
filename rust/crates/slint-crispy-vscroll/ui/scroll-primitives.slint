// ui/scroll-primitives.slint
// Low-level input capture layer.
// Consumers do not use this directly — VirtualScrollBase inherits it.

export component ScrollPrimitives inherits Rectangle {

    // ── Input callbacks (Rust side handles all logic) ──────────────────────
    callback on-pointer-pressed(/* x */ float, /* y */ float);
    callback on-pointer-moved(/* dx */ float, /* dy */ float);
    callback on-pointer-released(/* velocity-x */ float, /* velocity-y */ float);
    callback on-wheel(/* delta-x */ float, /* delta-y */ float);
    callback on-key-pressed(/* key */ string) -> bool;
    callback on-key-released(/* key */ string);

    // ── Scrollbar visibility (Rust sets, Slint renders) ────────────────────
    in property <bool> show-scrollbar: false;
    in property <float> scrollbar-position: 0.0;    // 0..1
    in property <float> scrollbar-thumb-size: 0.1;  // 0..1, fraction of track

    // ── Input capture ──────────────────────────────────────────────────────
    FocusScope {
        width: 100%; height: 100%;

        key-pressed(event) => {
            if (root.on-key-pressed(event.text)) {
                return accept;
            }
            return reject;
        }

        key-released(event) => {
            root.on-key-released(event.text);
            return accept;
        }

        TouchArea {
            width: 100%; height: 100%;

            pointer-event(event) => {
                if (event.kind == PointerEventKind.down) {
                    root.on-pointer-pressed(self.mouse-x / 1px, self.mouse-y / 1px);
                } else if (event.kind == PointerEventKind.up) {
                    root.on-pointer-released(0.0, 0.0);
                }
            }

            moved => {
                root.on-pointer-moved(
                    self.mouse-x / 1px - self.pressed-x / 1px,
                    self.mouse-y / 1px - self.pressed-y / 1px,
                );
            }

            scroll-event(event) => {
                root.on-wheel(event.delta-x / 1px, event.delta-y / 1px);
                return accept;
            }
        }
    }

    // ── Optional scrollbar track ───────────────────────────────────────────
    if show-scrollbar : Rectangle {
        x: root.width - 6px;
        y: 0;
        width: 6px;
        height: root.height;
        background: #ffffff22;
        border-radius: 3px;

        // Thumb
        Rectangle {
            x: 0;
            y: root.scrollbar-position * (parent.height - self.height);
            width: parent.width;
            height: root.scrollbar-thumb-size * parent.height;
            background: #ffffff88;
            border-radius: 3px;
        }
    }
}
