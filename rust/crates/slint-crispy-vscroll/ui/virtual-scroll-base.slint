// ui/virtual-scroll-base.slint
import { ScrollPrimitives } from "scroll-primitives.slint";

// SlotDescriptor as a Slint struct — must match src/bridge/slot_model.rs field names.
// Rust snake_case ↔ Slint kebab-case (slint::include_modules!() handles this mapping).
export struct SlotDescriptorSlint {
    slot-id: int,
    index: int,          // dataset index, -1 = unassigned

    // Position
    x: float,
    y: float,
    width: float,
    height: float,

    // Z-depth / visual transforms
    scale: float,
    opacity: float,
    rotation-x: float,
    rotation-y: float,
    translate-x: float,
    translate-y: float,
    z-offset: float,
    shadow-radius: float,
    shadow-opacity: float,
    border-width: float,
    border-opacity: float,
    blur: float,

    // State
    is-focused: bool,
    visible: bool,
    ready: bool,
}

// Base component. Consumer inherits this and adds the item template.
component VirtualScrollBase inherits ScrollPrimitives {

    // ── REQUIRED — must be set from Rust before first tick ────────────────
    in property <int> item-count: -1;       // sentinel: -1 = unset
    in property <int> direction: -1;        // 0=Vertical, 1=Horizontal, -1=unset
    in property <[SlotDescriptorSlint]> slot-model; // bound to Rc<VecModel>

    // ── OPTIONAL configuration ─────────────────────────────────────────────
    in property <bool>  snap-enabled: false;
    in property <float> snap-interval: 0.0;
    in property <bool>  rubber-band-enabled: true;
    in property <bool>  reduced-motion: false;
    in property <int>   focused-index: 0;

    // ── READ-ONLY output (Rust writes, consumer reads) ─────────────────────
    out property <float> scroll-position: 0.0;  // logical px from origin
    out property <int>   item-offset: 0;        // index of first visible item
    out property <bool>  is-scrolling: false;
    out property <float> velocity: 0.0;

    // ── Lifecycle callbacks ────────────────────────────────────────────────
    // Fires on every scroll update: new-position (logical px)
    callback on-scroll-changed(/* position */ float);
    // Fires when focused slot changes: new-index
    callback on-focus-changed(/* index */ int);
    // Fires when focus would move beyond first/last item: direction (-1=before, +1=after)
    callback on-focus-overflow(/* direction */ int);
    // Fires when a scroll gesture begins
    callback on-scroll-start();
    // Fires when scroll settles (velocity < threshold)
    callback on-scroll-end(/* final-position */ float);
}

// Compile-time entry point — Slint requires exported components to inherit Window.
// App code never instantiates this directly; consumers inherit VirtualScrollBase instead.
export component VScrollPreview inherits Window {
    background: #0a0a0c;
    VirtualScrollBase { }
}
