<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Crispy.UI.ViewModels"
             xmlns:controls="using:Crispy.UI.Controls"
             x:Class="Crispy.UI.Views.PlayerView"
             x:DataType="vm:PlayerViewModel"
             Background="Black">

  <!-- Full-screen player.
       VideoView fills the grid. OSD is injected via OverlayLayer in code-behind
       to avoid the NativeControlHost airspace clipping issue.

       Handoff block overlay: covers the entire surface when IsHandoffInProgress is true
       so that accidental pointer events during player handoff are swallowed (PLR-24). -->

  <Grid x:Name="PlayerRoot"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <!-- VideoView placeholder — code-behind assigns LibVLCSharp VideoView here
         as a native control child after AttachedToVisualTree. -->
    <Border x:Name="VideoSurface"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="Black"
            IsVisible="{Binding !IsAudioOnly}" />

    <!-- Radio mode: audio-only UI visible when IsAudioOnly=true -->
    <Grid IsVisible="{Binding IsAudioOnly}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="24">
        <!-- Waveform visualizer for audio-only streams -->
        <controls:WaveformVisualizer Height="80" Width="320"
                                     HorizontalAlignment="Center" />
        <!-- Large station logo -->
        <Border Width="160" Height="160" CornerRadius="80"
                Background="#1AFFFFFF">
          <Image Source="{Binding ChannelLogoUrl}"
                 Width="120" Height="120"
                 Stretch="Uniform" />
        </Border>
        <TextBlock Text="{Binding ChannelName}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="White"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding CurrentProgramme}"
                   FontSize="14"
                   Foreground="#B3FFFFFF"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Grid>

    <!-- Handoff input blocker (PLR-24): transparent fill, no hit-test passthrough -->
    <Border IsVisible="{Binding IsHandoffInProgress}"
            Background="#80000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsHitTestVisible="True">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock Text="Switching player..."
                   Foreground="White"
                   FontSize="18"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

  </Grid>

</UserControl>
