<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Crispy.UI.ViewModels"
             xmlns:enums="using:Crispy.Domain.Enums"
             x:Class="Crispy.UI.Views.AddSourceView"
             x:DataType="vm:AddSourceViewModel">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16"
                MaxWidth="480"
                HorizontalAlignment="Left"
                Margin="24">

      <!-- Header -->
      <TextBlock Text="Add Source"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />

      <!-- Source Type -->
      <StackPanel Spacing="4">
        <TextBlock Text="Source Type"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <ComboBox ItemsSource="{Binding AvailableSourceTypes}"
                  SelectedItem="{Binding SelectedSourceType}"
                  MinWidth="240" />
      </StackPanel>

      <!-- Display Name -->
      <StackPanel Spacing="4">
        <TextBlock Text="Display Name"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox Text="{Binding Name}"
                 Watermark="Display name" />
      </StackPanel>

      <!-- URL -->
      <StackPanel Spacing="4">
        <TextBlock Text="URL / Server Address"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox Text="{Binding Url}"
                 Watermark="URL / Server address" />
      </StackPanel>

      <!-- Username (hidden for M3U) -->
      <StackPanel Spacing="4"
                  IsVisible="{Binding AreCredentialsVisible}">
        <TextBlock Text="Username"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox Text="{Binding Username}"
                 Watermark="Username" />
      </StackPanel>

      <!-- Password (hidden for M3U) -->
      <StackPanel Spacing="4"
                  IsVisible="{Binding AreCredentialsVisible}">
        <TextBlock Text="Password"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox Text="{Binding Password}"
                 Watermark="Password"
                 PasswordChar="•" />
      </StackPanel>

      <!-- Error message -->
      <TextBlock Text="{Binding ErrorMessage}"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 Foreground="{DynamicResource ErrorBrush}"
                 FontSize="13"
                 TextWrapping="Wrap" />

      <!-- Action buttons -->
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <Button Content="Save"
                Command="{Binding SaveCommand}"
                IsDefault="True"
                MinWidth="80" />
        <Button Content="Cancel"
                Command="{Binding CancelCommand}"
                MinWidth="80" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
