<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Crispy.UI.ViewModels"
             xmlns:controls="using:Crispy.UI.Controls"
             xmlns:conv="using:Crispy.UI.Converters"
             x:Class="Crispy.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <Grid ColumnDefinitions="256,*"
        Background="{DynamicResource SurfacePrimaryBrush}">

    <!-- Left panel: Category list -->
    <Border Grid.Column="0"
            Background="{DynamicResource SurfaceSecondaryBrush}"
            Padding="8">
      <controls:SettingsCategoryList DataContext="{Binding}" />
    </Border>

    <!-- Right panel: Selected category settings -->
    <ScrollViewer Grid.Column="1"
                  Padding="24,16">
      <Panel>

        <!-- ═══ General ═══ -->
        <StackPanel Spacing="16"
                    IsVisible="{Binding SelectedCategory, Converter={x:Static conv:CategoryMatchConverter.Instance}, ConverterParameter=General}">

          <!-- Theme picker -->
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="Theme"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <ComboBox ItemsSource="{Binding AvailableThemes}"
                        SelectedItem="{Binding SelectedTheme}"
                        MinWidth="200" />
            </StackPanel>
          </Border>

          <!-- Language picker -->
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="Language"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <ComboBox ItemsSource="{Binding AvailableLocales}"
                        SelectedItem="{Binding SelectedLocaleOption}"
                        MinWidth="200">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:LocaleOption">
                    <TextBlock Text="{Binding NativeName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Border>

          <!-- Accent color picker -->
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="Accent Color"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <ListBox ItemsSource="{Binding AccentPalette}"
                       SelectedIndex="{Binding SelectedAccentIndex}"
                       Background="Transparent"
                       BorderThickness="0">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="CornerRadius" Value="20" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Width" Value="40" />
                    <Setter Property="Height" Value="40" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                  </Style>
                  <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="Transparent" />
                  </Style>
                  <Style Selector="ListBoxItem:selected">
                    <Setter Property="BorderBrush" Value="White" />
                    <Setter Property="BorderThickness" Value="3" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Width="32"
                            Height="32"
                            CornerRadius="16"
                            Cursor="Hand">
                      <Border.Background>
                        <SolidColorBrush Color="{Binding}" />
                      </Border.Background>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Border>

          <!-- Reduced motion toggle -->
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0"
                          Spacing="4">
                <TextBlock Text="Reduced Motion"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Disable animations for accessibility"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1"
                            IsChecked="{Binding IsReducedMotion}"
                            VerticalAlignment="Center" />
            </Grid>
          </Border>
        </StackPanel>

        <!-- ═══ Sources ═══ -->
        <StackPanel Spacing="16"
                    IsVisible="{Binding SelectedCategory, Converter={x:Static conv:CategoryMatchConverter.Instance}, ConverterParameter=Sources}">
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <TextBlock Text="Source management will be available in Phase 2."
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>
        </StackPanel>

        <!-- ═══ Playback ═══ -->
        <StackPanel Spacing="16"
                    IsVisible="{Binding SelectedCategory, Converter={x:Static conv:CategoryMatchConverter.Instance}, ConverterParameter=Playback}">
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <TextBlock Text="Playback settings will be available in Phase 3."
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>
        </StackPanel>

        <!-- ═══ Data & Sync ═══ -->
        <StackPanel Spacing="16"
                    IsVisible="{Binding SelectedCategory, Converter={x:Static conv:CategoryMatchConverter.Instance}, ConverterParameter=Data &amp; Sync}">
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <TextBlock Text="Data &amp; Sync settings will be available in a future phase."
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>
        </StackPanel>

        <!-- ═══ Advanced ═══ -->
        <StackPanel Spacing="16"
                    IsVisible="{Binding SelectedCategory, Converter={x:Static conv:CategoryMatchConverter.Instance}, ConverterParameter=Advanced}">
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <TextBlock Text="Advanced settings will be available in a future phase."
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>
        </StackPanel>

        <!-- ═══ About ═══ -->
        <StackPanel Spacing="16"
                    IsVisible="{Binding SelectedCategory, Converter={x:Static conv:CategoryMatchConverter.Instance}, ConverterParameter=About}">
          <Border Background="{DynamicResource SurfaceElevatedBrush}"
                  CornerRadius="8"
                  Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="About"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock FontSize="13"
                         Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="Version: " />
                <Run Text="{Binding AppVersion}" />
              </TextBlock>
              <TextBlock FontSize="13"
                         Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="Build: " />
                <Run Text="{Binding BuildDate}" />
              </TextBlock>
              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          Margin="0,8,0,0">
                <Button Content="Reset Category"
                        Command="{Binding ResetCategoryCommand}" />
                <Button Content="Factory Reset"
                        Command="{Binding FactoryResetCommand}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

      </Panel>
    </ScrollViewer>
  </Grid>

</UserControl>
