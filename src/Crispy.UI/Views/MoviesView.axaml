<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Crispy.UI.ViewModels"
             x:Class="Crispy.UI.Views.MoviesView"
             x:DataType="vm:MoviesViewModel">

  <DockPanel>

    <!-- Source filter bar -->
    <Border DockPanel.Dock="Top"
            Padding="12,8"
            Background="{DynamicResource SurfaceBrush}">
      <ListBox ItemsSource="{Binding SourceFilters}"
               SelectedItem="{Binding SelectedSourceFilter, Mode=TwoWay}"
               SelectionMode="Single">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}"
                       Padding="12,6" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <!-- Content grid -->
    <Grid>

      <!-- Movie grid -->
      <ScrollViewer IsVisible="{Binding !IsLoading}">
        <ItemsControl ItemsSource="{Binding Movies}"
                      Margin="12">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Width="160"
                      Height="260"
                      Margin="6"
                      CornerRadius="8"
                      Background="{DynamicResource SurfaceBrush}"
                      ClipToBounds="True">
                <StackPanel>
                  <Image Source="{Binding Thumbnail}"
                         Height="200"
                         Stretch="UniformToFill" />
                  <Border Padding="8,4"><StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding Year}"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel></Border>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Loading overlay -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  IsVisible="{Binding IsLoading}"
                  Spacing="12">
        <ProgressBar IsIndeterminate="True"
                     Width="200" />
        <TextBlock Text="Loading..."
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
      </StackPanel>

    </Grid>

  </DockPanel>

</UserControl>
