<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Surface Colors (light for accessibility) -->
  <Color x:Key="SurfacePrimary">#FAFAFA</Color>
  <Color x:Key="SurfaceSecondary">#F0F0F0</Color>
  <Color x:Key="SurfaceTertiary">#E5E5E5</Color>
  <Color x:Key="SurfaceElevated">#FFFFFF</Color>

  <!-- Text Colors -->
  <Color x:Key="TextPrimary">#1A1A1A</Color>
  <Color x:Key="TextSecondary">#525252</Color>
  <Color x:Key="TextDisabled">#A3A3A3</Color>

  <!-- Accent Colors -->
  <Color x:Key="AccentPrimary">#6366F1</Color>
  <Color x:Key="AccentSecondary">#818CF8</Color>

  <!-- Semantic Colors -->
  <Color x:Key="SemanticError">#EF4444</Color>
  <Color x:Key="SemanticSuccess">#22C55E</Color>
  <Color x:Key="SemanticWarning">#F59E0B</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="SurfacePrimaryBrush" Color="{StaticResource SurfacePrimary}" />
  <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="{StaticResource SurfaceSecondary}" />
  <SolidColorBrush x:Key="SurfaceTertiaryBrush" Color="{StaticResource SurfaceTertiary}" />
  <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevated}" />

  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
  <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}" />

  <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}" />
  <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}" />

  <SolidColorBrush x:Key="SemanticErrorBrush" Color="{StaticResource SemanticError}" />
  <SolidColorBrush x:Key="SemanticSuccessBrush" Color="{StaticResource SemanticSuccess}" />
  <SolidColorBrush x:Key="SemanticWarningBrush" Color="{StaticResource SemanticWarning}" />

  <!-- Overlay -->
  <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#000000" Opacity="0.4" />

  <!-- Glass Panel -->
  <SolidColorBrush x:Key="GlassPanelBrush" Color="{StaticResource SurfacePrimary}" Opacity="0.7" />

</ResourceDictionary>
