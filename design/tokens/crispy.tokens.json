{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "background": {
      "immersive": {
        "$type": "color",
        "$value": "#000000"
      },
      "surface": {
        "$type": "color",
        "$value": "#121212"
      },
      "raised": {
        "$type": "color",
        "$value": "#1E1E1E"
      }
    },
    "brand": {
      "red": {
        "$type": "color",
        "$value": "#E50914"
      }
    },
    "status": {
      "success": {
        "$type": "color",
        "$value": "#4CAF50"
      },
      "warning": {
        "$type": "color",
        "$value": "#FF9800"
      },
      "error": {
        "$type": "color",
        "$value": "#F44336"
      },
      "live": {
        "$type": "color",
        "$value": "#FF5252"
      }
    },
    "text": {
      "high": {
        "$type": "color",
        "$value": "#FFFFFF"
      },
      "medium": {
        "$type": "color",
        "$value": "#B3B3B3"
