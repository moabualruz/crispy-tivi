    "sheet": { "$type": "dimension", "$value": "10px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "motion": {
    "focus": { "$type": "duration", "$value": "120ms" },
    "panel": { "$type": "duration", "$value": "220ms" },
    "page": { "$type": "duration", "$value": "360ms" }
  }
